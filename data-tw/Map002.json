,0,0,2,"皇后白飘飘"]},{"code":401,"indent":0,"parameters":["月儿，快跑。"]},{"code":231,"indent":0,"parameters":[2,"1-XSH",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["母后... ..."]},{"code":250,"indent":0,"parameters":[{"name":"Close2","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[30]},{"code":250,"indent":0,"parameters":[{"name":"Close2","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":0,"parameters":[1,"13HG4",0,0,0,0,100,100,255,0]},{"code":231,"indent":0,"parameters":[2,"2-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"皇后白飘飘"]},{"code":401,"indent":0,"parameters":["别怕，母后自然有自己的办法，会跟上月儿的。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"皇后白飘飘"]},{"code":401,"indent":0,"parameters":["所以月儿快走，不要回头，母后会跟着你的背影追上来。\\C[0]"]},{"code":231,"indent":0,"parameters":[2,"1-XSH",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["母后... ..."]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["女儿知道了，母后一定要跟上来。"]},{"code":250,"indent":0,"parameters":[{"name":"Open1","volume":90,"pitch":100,"pan":0}]},{"code":250,"indent":0,"parameters":[{"name":"Close1","volume":90,"pitch":100,"pan":0}]},{"code":235,"indent":0,"parameters":[2]},{"code":111,"indent":0,"parameters":[0,10,0]},{"code":231,"indent":1,"parameters":[2,"HS",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["强忍着心中的回头的冲动。"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\n[1]眼角早已经湿润，快速的着冲向前方跑去。"]},{"code":201,"indent":1,"parameters":[0,3,15,5,2,0]},{"code":235,"indent":1,"parameters":[2]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["说完，\\n[1]头也不回的跑，只听后面是母亲带着诱惑的声音。"]},{"code":250,"indent":1,"parameters":[{"name":"Splash","volume":90,"pitch":100,"pan":0}]},{"code":241,"indent":1,"parameters":[{"name":"DHCM1_BGM02_Opening1","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":1,"parameters":[1,"13HG3",0,0,0,0,100,100,255,0]},{"code":231,"indent":1,"parameters":[2,"2-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]皇后白飘飘：你们想要的都有，只要你们想，现在就能有。"]},{"code":235,"indent":1,"parameters":[2]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]昏暗的烛光，男人的停住的脚步，眼前的女人浑身微微颤抖，却伸手打开了自己的衣服。"]},{"code":231,"indent":1,"parameters":[2,"2-CG1",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]那绝美的身材与美艳的脸，是男人没有见到过，而这时，大家都明白了她说的意思。"]},{"code":231,"indent":1,"parameters":[2,"2-CG2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]等待众人的是一场香艳而美好的盛宴，男人们放下的武器，一个个朝着女人走去。"]},{"code":235,"indent":1,"parameters":[1]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ1",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]皇后白飘飘：啊~~你们轻点~~"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]乱兵周达：能上了一国之后，就算下一秒死了，也值得。"]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]众人本来就是四处流散的混混，被抓来皇城附近守护，现在国破家亡，人也危在旦夕，不由心中歹念丛生，一个个肮脏的肉棒抵着皇后。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]皇后白飘飘：慢一点~~本宫会满足你们所有人的。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]这娇媚的语音，只听的众人魂不守舍，恨不得立马就插入她身体，品味这成熟诱人的身躯。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]乱兵王希：原以为六周国的皇后是一个坚强的女性，没想到也只是一个母狗而已。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]乱兵李宇：哈，这就是皇后吗？怎么搞的和妓女一样，想到皇上的女人现在就如同一只母狗，就让老子兴奋了。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]乱兵周达：虽说月儿公主美貌，但这皇后如此绝美，让人移不开眼睛。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]长年保养在深宫，那曼妙的身姿，早就让众人的肉棒硬得不能再硬，皇后本就有心想让女儿脱逃，自然放下了身段，不做抵抗。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]皇后白飘飘：嘤~~有了本宫还想那什么都不懂的吗？哪会有本宫会伺候人？"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]乱兵王希：哟，这皇后的小嘴说的真让人心动，那兄弟们可就不客气了。"]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ3",0,0,0,0,100,100,255,0]},{"code":250,"indent":1,"parameters":[{"name":"4-DLPYKJ","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]恶臭的肉棒插入嘴里，皇后来不及说什么，就被无情的抽插，众人对着皇后那成熟诱人的身体，上下其手，那细腻的手感，让众人更是享受其中。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]皇后白飘飘：（自从生了太子后，皇上就很少来了，我... ...）"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]感受到自己身体的变化，小穴流出的淫水，舌头开始舔着那恶臭的肉棒，一旁的男子早就忍不住。"]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ4",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]乱兵李宇：什么一国皇后，原来也只是一只母狗而已。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]说完，肉棒就无情的插入了皇后白飘飘小穴之中。"]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ5",0,0,0,0,100,100,255,0]},{"code":250,"indent":1,"parameters":[{"name":"2-SFCR","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]好久没有被使用的小穴，即使生过孩子，依旧有些紧致，何况皇后如今还风华正茂。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]皇后白飘飘：（嗯...好大...好疼...不对...我在想什么...只要月儿能逃出，我什么都愿意做。）"]},{"code":250,"indent":1,"parameters":[{"name":"4-PPH1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]这样想着，身上的人依旧受不了的一顿猛冲，这种事情也许是他们这辈子最后能做到。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]便是如同野兽般吞噬了身下的女人，并让她全身都留有属于他们的印记，这样，他们仿佛还留在这个人间一样。"]},{"code":250,"indent":1,"parameters":[{"name":"2-SFQPH1","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ6",0,0,0,0,100,100,255,0]},{"code":230,"indent":1,"parameters":[30]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ5",0,0,0,0,100,100,255,0]},{"code":230,"indent":1,"parameters":[30]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ6",0,0,0,0,100,100,255,0]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ8",0,0,0,0,100,100,255,0]},{"code":250,"indent":1,"parameters":[