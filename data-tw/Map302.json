{"id":12,"name":"剧情","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>女孩：我终于死了吗？"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["女孩单薄的身体，宛如风中的树叶，原本还算红润的脸，已经苍白一片，瘦的脸颊都凹陷下来。"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["她还记得自己进入刘家，怎么被磋磨，怎么无奈的伺候刘老爷，她以为这辈子就这样了，她胆小又不会说话，本不应该会被针对。"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["但是，因为不太被重视，她无法给家里更多的钱，结果嫂子就告诉刘老爷，她和猎户的事情。"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["因为嫂子发现哥哥很没用，她走后，大部分家务都是她来做，而自己过得还不错，她愤怒，不管不顾，告诉了刘老爷。"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["于是，愤怒的刘老爷根本不去调查，就把她关在破旧的屋子里，活活饿死。"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>女孩：还要继续下一世吗？还要在做人吗？"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["女孩只感觉不甘和痛苦充实全身，她很害怕，害怕下一次会更惨，这么苦的人生，她实在不想再次品尝。"]},{"code":117,"indent":0,"parameters":[53]},{"code":231,"indent":0,"parameters":[1,"44-YSLH1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"妖僧"]},{"code":401,"indent":0,"parameters":["死亡真的最后终结吗？仙子，你认为修士为他人欲望而死是不是应该的？"]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]（这应该是最后一个问题了，那么我该如何回复？）"]},{"code":401,"indent":0,"parameters":["当前道心：\\C[10]\\V[675]\\C[0]"]},{"code":102,"indent":0,"parameters":[["如果众人所向，那么为了大义而赴死是应该的。","如果只是单纯的面子，那么我觉得没有任何必须为了别人的想法和面子去牺牲自我。"],-1,0,1,0]},{"code":402,"indent":0,"parameters":[0,"如果众人所向，那么为了大义而赴死是应该的。"]},{"code":231,"indent":1,"parameters":[1,"44-YSLH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"妖僧"]},{"code":401,"indent":1,"parameters":["众人所向就是对的吗？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"妖僧"]},{"code":401,"indent":1,"parameters":["为了众人的想法，而牺牲自我，谁又会感谢自己？不过是自我感动而已。"]},{"code":231,"indent":1,"parameters":[1,"44-YSLH3",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"妖僧"]},{"code":401,"indent":1,"parameters":["仙子也是这样自动感动自己的人吗？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"妖僧"]},{"code":401,"indent":1,"parameters":["如果是，那仙子也太可悲了，这样道心，真的能走到最后吗？"]},{"code":235,"indent":1,"parameters":[1]},{"code":122,"indent":1,"parameters":[675,675,2,0,15]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[2]（他说的似乎是正确的，我...的内心有了一些动摇。）"]},{"code":401,"indent":1,"parameters":["当前道心：\\C[10]\\V[675]\\C[0]"]},{"code":117,"indent":1,"parameters":[52]},{"code":201,"indent":1,"parameters":[0,303,12,12,8,0]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"如果只是单纯的面子，那么我觉得没有任何必须为了别人的想法和面子去牺牲自我。"]},{"code":231,"indent":1,"parameters":[1,"44-YSLH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"妖僧"]},{"code":401,"indent":1,"parameters":["不错，仙子居然有所觉悟，那么仙子的道心必然坚定不移。"]},{"code":235,"indent":1,"parameters":[1]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[6]（内心有一丝不详的感觉... ...）"]},{"code":117,"indent":1,"parameters":[52]},{"code":201,"indent":1,"parameters":[0,303,12,12,8,0]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":f