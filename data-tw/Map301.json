":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[2]（修士...说的是无情道吗？但...无情道已经很少有人修炼了？）"]},{"code":401,"indent":0,"parameters":["当前道心：\\C[10]\\V[675]\\C[0]"]},{"code":102,"indent":0,"parameters":[["修炼无情道，砍断七情六欲，可超凡脱俗。","人因为七情六欲才不断前进，修仙只是逆天，为命一搏，而不是逃避人性，迟早会反噬。"],-1,0,1,0]},{"code":402,"indent":0,"parameters":[0,"修炼无情道，砍断七情六欲，可超凡脱俗。"]},{"code":231,"indent":1,"parameters":[1,"44-YSLH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"妖僧"]},{"code":401,"indent":1,"parameters":["仙子难道忘记了，前五十年，上个纪元，不知怎么流行杀妻证道，无情飞升。"]},{"code":231,"indent":1,"parameters":[1,"44-YSLH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"妖僧"]},{"code":401,"indent":1,"parameters":["结果又如何，飞升之后，不久就痛苦陨落，所谓的无情，不过是暂时压制所有情感，但是因果轮回，怎么能逃离？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"妖僧"]},{"code":401,"indent":1,"parameters":["不过是自欺欺人，仙子，也想这样骗自己吗？"]},{"code":235,"indent":1,"parameters":[1]},{"code":122,"indent":1,"parameters":[675,675,2,0,15]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[11]（差点忘记这事，毕竟这些年已经好久没有出现无情道修士。）"]},{"code":401,"indent":1,"parameters":["当前道心：\\C[10]\\V[675]\\C[0]"]},{"code":117,"indent":1,"parameters":[52]},{"code":201,"indent":1,"parameters":[0,302,9,7,6,0]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"人因为七情六欲才不断前进，修仙只是逆天，为命一搏，而不是逃避人性，迟早会反噬。"]},{"code":231,"indent":1,"parameters":[1,"44-YSLH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"妖僧"]},{"code":401,"indent":1,"parameters":["没错，上个纪元修的无情道修士，就是被忽悠的压制七情六欲，以为真的成功，结果飞升全部遭到反噬，因果不会消失。"]},{"code":235,"indent":1,"parameters":[1]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[11]（还剩的不多了，一定要坚持到最后，看样子，那些失踪的修士绝对和他有关。）"]},{"code":117,"indent":1,"parameters":[52]},{"code":201,"indent":1,"parameters":[0,302,9,7,6,0]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"inde