ent":4,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":4,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":4,"parameters":["小姐... ..."]},{"code":117,"indent":4,"parameters":[22]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["如此柔弱又哭泣的\\n[1]让阿欢想起第一次在皇宫中看到的白嫩又可爱的公主，那时候因为丢失了最爱的小狗，在众人环绕中哭泣。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["所有人都疼爱的，怜爱的小公主，逐渐一个人忍受着欺骗长大，所谓的师兄、师傅和师姐变态的想占有着她的一切。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["即便已经长大，看过这世界的黑暗，内心深处，仍然是那个可爱又天真的女孩，只是不会在如当年那般纯粹了。"]},{"code":117,"indent":4,"parameters":[22]},{"code":117,"indent":4,"parameters":[116]},{"code":0,"indent":4,"parameters":[]},{"code":411,"indent":3,"parameters":[]},{"code":117,"indent":4,"parameters":[22]},{"code":231,"indent":4,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":4,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":4,"parameters":["奴婢非常感激他们，因为他们，奴婢才能再次遇到小姐。"]},{"code":117,"indent":4,"parameters":[22]},{"code":101,"indent":4,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":4,"parameters":["师傅、师兄和师姐对我很好，只是凌霄宫很穷，大家都是丹修，战斗力不是很强。"]},{"code":101,"indent":4,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":4,"parameters":["我太过弱小了，他们都舍不得我出去外面，直到我的心魔开始滋生。"]},{"code":117,"indent":4,"parameters":[22]},{"code":117,"indent":4,"parameters":[116]},{"code":0,"indent":4,"parameters":[]},{"code":412,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[1,"对桃花村的看法"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["这个世界真的有全是桃花妖怪的村子啊，那是不是隐世的一个美好的小村庄。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["那到没有，这天地之间，一饮一啄已有天定，有树木就有天敌虫子。"]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["而虫子自然也有天敌鸟类，所以哪怕那么好的地方，也有很大很大的虫子呢。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["那么大的虫子真的好可怕，小姐就会吓我。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["不过还好，这一趟收获也颇多，得到了一些有用的信息。"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[116]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[2,"对黑蛟的看法"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["不是什么好人，也不是什么坏人，不过是利益刚好相同的合作人而已。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["他应该不会伤害小姐吧？"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["利益不冲突前自然不会，未来就不知道了。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["就算他是一头蛟龙，但要伤害小姐，阿欢第一个不答应，踩过阿欢的尸体再去。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["阿欢，我不会让你受伤的，哪怕是黑蛟，我也只会保护你。"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[116]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[3,"对朱雀的看法"]},{"code":111,"indent":3,"parameters":[0,479,0]},{"code":117,"indent":4,"parameters":[22]},{"code":231,"indent":4,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":4,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":4,"parameters":["小姐，小姐，你没事吧！"]},{"code":117,"indent":4,"parameters":[22]},{"code":101,"indent":4,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":4,"parameters":["我没事... ..."]},{"code":117,"indent":4,"parameters":[22]},{"code":231,"indent":4,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":4,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":4,"parameters":["！！！小姐，你...有什么心事。"]},{"code":117,"indent":4,"parameters":[22]},{"code":101,"indent":4,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":4,"parameters":["那个朱雀应该认识我，甚至...国破家亡都是她想见到，她浑身怨气，根本不是什么神兽。"]},{"code":117,"indent":4,"parameters":[22]},{"code":231,"indent":4,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":4,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":4,"parameters":["不对啊，小姐从小就没出过皇城，怎么会惹到呢？"]},{"code":117,"indent":4,"parameters":[22]},{"code":101,"indent":4,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":4,"parameters":["我不知道，但...宇文玉...我心里很乱，但是，我一定要杀了朱雀，一定。"]},{"code":117,"indent":4,"parameters":[22]},{"code":117,"indent":4,"parameters":[116]},{"code":0,"indent":4,"parameters":[]},{"code":411,"indent":3,"parameters":[]},{"code":117,"indent":4,"parameters":[22]},{"code":101,"indent":4,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":4,"parameters":["不知道它从何而来，为什么要帮助宇文卿，我个人觉得宇文卿并没那么大的人格魅力。"]},{"code":117,"indent":4,"parameters":[22]},{"code":231,"indent":4,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":4,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":4,"parameters":["两人应该有什么交易，但是，朱雀不是神兽吗？宇文卿到底是付出了多大的代价。"]},{"code":117,"indent":4,"parameters":[22]},{"code":101,"indent":4,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":4,"parameters":["我虽然不知道，但那一定是我们想不到的代价。"]},{"code":101,"indent":4,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":4,"parameters":["（虽然各为其主，不过朱雀乃神兽，怎么会听从宇文卿的要求，这其中肯定有什么不为人知的事情。）"]},{"code":117,"indent":4,"parameters":[22]},{"code":117,"indent":4,"parameters":[53]},{"code":0,"indent":4,"parameters":[]},{"code":412,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[4,"下一页"]},{"code":102,"indent":3,"parameters":[["对宇文卿的看法","对宇文玉的看法","上一页","离开"],3,0,1,0]},{"code":402,"indent":3,"parameters":[0,"对宇文卿的看法"]},{"code":117,"indent":4,"parameters":[22]},{"code":101,"indent":4,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":4,"parameters":["那时候我也才十多岁，被他骗的给了当时看不懂的军队部署图给他，让我们大败，其中还有朱雀帮助。"]},{"code":101,"indent":4,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":4,"parameters":["好狠，既然我活下来了，那他就得死。"]},{"code":117,"indent":4,"parameters":[22]},{"code":117,"indent":4,"parameters":[116]},{"code":0,"indent":4,"parameters":[]},{"code":402,"indent":3,"parameters":[1,"对宇文玉的看法"]},{"code":111,"indent":4,"parameters":[0,479,0]},{"code":111,"indent":5,"parameters":[0,472,0]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["小姐，你怎么了，从凤临阁回来，你和黑蛟就感觉怪怪的。"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["宇文玉居然知道我会找朱雀，又在朱雀那救下了我... ..."]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["他为什么会救小姐？难道是想小姐放过他？"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["他很强大，非常强大，就算没有朱雀，我也根本杀不死他。"]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["那就奇怪了，难道他真的喜欢小姐？"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["喜欢？爱？这不应该出现在皇室，是他们宇文家教会我利益至上，他不会以为他帮了我几次，我就不会杀了宇文卿？"]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["宇文卿和朱雀必须死，我不杀他，只是不想天下大乱，让他替我好好照顾六周国的百姓而已。"]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["那小姐为什么要跟他去江南？"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["我想知道他的执政能力，然后，我想知道他为什么这样对我，如果是为了爱，我觉得可笑。"]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["小姐，你的心有些乱了，如果你们没有血海深仇，阿欢觉得你们真的天生一对。"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["阿欢，你也说是如果，这世界没有如果，宇文家踩着我父皇母后哥哥的尸体上位，既然留的我一口气，我怎么会让他们一点代价都不付出。"]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["阿欢相信小姐。"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["嗯，哪怕是宇文玉如何的帮助，宇文卿和朱雀必死。"]},{"code":117,"indent":6,"parameters":[22]},{"code":117,"indent":6,"parameters":[116]},{"code":0,"indent":6,"parameters":[]},{"code":411,"indent":5,"parameters":[]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["小姐，你怎么了，从凤临阁回来，你和黑蛟就感觉怪怪的。"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["我本以为宇文玉和宇文卿一样，是自私自利者，只是，宇文玉比宇文卿更在意天下百姓。"]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["但是...他为什么会为了救我而死亡，阿欢我不懂，我们只不过几面之缘，他为什么会这样？"]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["小姐...虽然阿欢也觉得很离谱，但...小姐你长的这么美，谁能抵抗？"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["即便我长得好看，我们一个北明国王爷，一个六周国前公主，他以为我会为他放弃仇恨？"]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["小姐，阿欢虽然不明白，但阿欢知道，他可能是真的心悦小姐，若不是心悦小姐，为什么会舍得付出自己生命？"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["喜欢？爱？这不应该出现在皇室，是他们宇文家教会我利益至上，他不会以为他死了，我就不会杀了宇文卿？"]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["但是...小姐，你心有些乱了。"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["我乱是想不通，我虽然好看，但并没有让他做到如此的地步，他不是个傻子，他也在宫廷内斗之中活下来，怎么会是良善之人。"]},{"code":117,"indent":6,"parameters":[22]},{"code":231,"indent":6,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":6,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":6,"parameters":["小姐，也许一切事情的真相可能会再魔界中。"]},{"code":117,"indent":6,"parameters":[22]},{"code":101,"indent":6,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":6,"parameters":["嗯，但是不论什么样的真相，宇文卿和朱雀必死。"]},{"code":117,"indent":6,"parameters":[22]},{"code":117,"indent":6,"parameters":[116]},{"code":0,"indent":6,"parameters":[]},{"code":412,"indent":5,"parameters":[]},{"code":0,"indent":5,"parameters":[]},{"code":411,"indent":4,"parameters":[]},{"code":117,"indent":5,"parameters":[22]},{"code":231,"indent":5,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":5,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":5,"parameters":["我看他是个好人，只是，当年他为什么不阻止他哥消灭我国。"]},{"code":117,"indent":5,"parameters":[22]},{"code":101,"indent":5,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":5,"parameters":["利益即得者，消灭六周国，他北明国国力大增，他有什么拒绝的道理... ..."]},{"code":101,"indent":5,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":5,"parameters":["我只是不想百姓在受苦，不然，宇文玉他也得死。"]},{"code":117,"indent":5,"parameters":[22]},{"code":117,"indent":5,"parameters":[116]},{"code":0,"indent":5,"parameters":[]},{"code":412,"indent":4,"parameters":[]},{"code":0,"indent":4,"parameters":[]},{"code":402,"indent":3,"parameters":[2,"上一页"]},{"code":119,"indent":4,"parameters":["1"]},{"code":0,"indent":4,"parameters":[]},{"code":402,"indent":3,"parameters":[3,"离开"]},{"code":117,"indent":4,"parameters":[22]},{"code":117,"indent":4,"parameters":[116]},{"code":0,"indent":4,"parameters":[]},{"code":404,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[5,"离开"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[116]},{"code":0,"indent":3,"parameters":[]},{"code":404,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"回忆六周国的一些事情"]},{"code":102,"indent":2,"parameters":[["母后的秘密","哥哥的私密","离开"],2,0,1,0]},{"code":402,"indent":2,"parameters":[0,"母后的秘密"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["皇后娘娘的秘密，小姐应该比我更懂。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["我目前就知道母后应该是某个修仙宗门里出来的，应该是没有灵根。"]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["而我是天灵根的修士，天灵根算是比较顶尖的灵根，我感觉，哥哥会不会也有灵根？"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["小姐也觉得太子也能修仙？"]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["既然我都有灵根，那哥哥也大概率有灵根。"]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["母后的镯子也是一个法宝，能自创一方天地，还能不断变化。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["那简直太棒了，都是皇后娘娘对小姐的疼爱。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["他们太溺爱我了，我应该早点成熟，早点懂事，就不会出事。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["小姐... ..."]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["（希望有生之年能遇到母亲的兄弟吧。）"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[116]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[1,"哥哥的私密"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["太子殿下简直完美，我觉得太子殿下比宇文玉更加好。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["那是，哥哥自然是最好的。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["（但是太子殿下看公主，那眼神太过炙热，那是男人看女人的眼光... ...）"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[116]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[2,"离开"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[116]},{"code":0,"indent":3,"parameters":[]},{"code":404,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[2,"北明国的一些传闻"]},{"code":102,"indent":2,"parameters":[["北明国太上皇的秘闻","宇文卿的一些过往","宇文玉的一些过往","离开"],3,0,1,0]},{"code":402,"indent":2,"parameters":[0,"北明国太上皇的秘闻"]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["其实当年我曾经听丞相嫡女王玥娥小姐说过，其实北明国上任皇帝宇文峰似乎更喜欢二皇子宇文玉，有意废除太子宇文卿。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["当年我被宇文卿假装的温柔欺骗，但现在回想起来，也能隐约抓住一些回忆。"]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["他对平民虽然表面装的很爱民，但是，他的眼神深处有嫌弃，他对自己的身份非常在意，有一种说不出的高傲感。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["我想起来了，有一次，他约小姐外出，小姐似乎遗漏了什么，转身回去取，让我在外面等着。"]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["那天一个小孩子不下心撞到他，他的脸色一下就黑了，不过就一瞬间，我当时有点震惊，正在细看，他早已经回复了温文儒雅的样子。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["难怪不得他父皇喜欢，是我没有想到他是隔壁皇子，当年都拿假名秦乐来忽悠我。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["这是不知道为什么最后那皇位会落到他手中，真是老天不长眼。"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[116]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[1,"宇文卿的一些过往"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["当年我被父皇母后哥哥宠坏，觉得我是女孩变从来没有教导我权谋之术，现在想想，宇文卿到的深得此中精髓。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["可不是，我当年以为...以为他是个好的，根本看不出来，他那么卑鄙无耻。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["当年不知道他对自己父皇承诺了什么，我记得他并不得宠，最后皇位却成为了他的。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["小姐...我觉得他承诺的可能就是六周国，只有这样大的利益才能让原本不喜欢他的父亲改变心意。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["好狠的心思，以我全家去开拓他称帝之路。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["如此心思之人，却能把两国的百姓安排的明明白白，小姐，太诡异了，简直就是一个傻子能写出华丽诗词一样。"]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["难道是朱雀干的？这灵兽这么大能耐吗？"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["朱雀虽然是神兽，完全控制所有的百姓对她来说消耗很大，不值当，而且我也看到了他发布的条例，是没有问题的。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["可恶，这北明国的皇帝，凭什么答应那畜生的要求，不是说他喜欢二皇子。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["我想...应该是北明国前任皇帝没想到宇文卿会成功，不然不会承诺皇位这种事情。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["真是老天不长眼，坏人活得长。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["迟早会让他付出代价。"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[116]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[2,"宇文玉的一些过往"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["当年听说过宇文玉乃是天仙下凡，长得俊美无双，天资聪慧，虽说与大皇子宇文卿一母同胞，但为人天差地别。"]},{"code":117,"indent":3,"parameters":[22]},{"code":101,"indent":3,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":3,"parameters":["当时去皇城却也是看到过，确实。"]},{"code":117,"indent":3,"parameters":[22]},{"code":231,"indent":3,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["当年据说北明国的皇帝一直中意宇文玉，不知道为什么还是宇文卿继承皇位。"]},{"code":101,"indent":3,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":3,"parameters":["不过，对于宇文玉，有一些离谱传说，说他乃无量天尊转世，当年北明皇后生下他的时候，梦到麒麟。"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[116]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[3,"离开"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[116]},{"code":0,"indent":3,"parameters":[]},{"code":404,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[3,"离开"]},{"code":117,"indent":2,"parameters":[22]},{"code":117,"indent":2,"parameters":[116]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":231,"indent":1,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":1,"parameters":["小姐，一定要注意安全。"]},{"code":117,"indent":1,"parameters":[22]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["你放心，对了，阿欢离开皇宫之后去了哪里？"]},{"code":117,"indent":1,"parameters":[22]},{"code":231,"indent":1,"parameters":[1,"3-LH",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"阿欢"]},{"code":401,"indent":1,"parameters":["白杨村，小姐。"]},{"code":117,"indent":1,"parameters":[22]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[11]（那天捡到阿欢的时候，阿欢一定是遇到什么不好的事情，那白杨村，肯定有什么，有空可以去，有恩报恩，有仇报仇。）"]},{"code":117,"indent":1,"parameters":[22]},{"code":117,"indent":1,"parameters":[116]},{"code":122,"indent":1,"parameters":[293,293,0,0,1]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":6,"y":6},
