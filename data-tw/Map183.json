{"id":7,"name":"EV007","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"","direction":2,"pattern":1,"characterIndex":4},"list":[{"code":231,"indent":0,"parameters":[1,"58-GYLGLH2",0,0,0,0,100,100,255,0]},{"code":111,"indent":0,"parameters":[1,970,0,1,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"神秘老头"]},{"code":401,"indent":1,"parameters":["仙子下次再来啊。"]},{"code":117,"indent":1,"parameters":[22]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2,"神秘老头"]},{"code":401,"indent":1,"parameters":["这位仙子，来到这里，老道我最会给人按摩了，仙子要不要试试？"]},{"code":102,"indent":1,"parameters":[["按摩（100灵石一次）","离开"],1,0,1,0]},{"code":402,"indent":1,"parameters":[0,"按摩（100灵石一次）"]},{"code":122,"indent":2,"parameters":[16,16,0,3,0,53,0]},{"code":111,"indent":2,"parameters":[1,16,0,100,1]},{"code":101,"indent":3,"parameters":["",0,0,2,"神秘老头"]},{"code":401,"indent":3,"parameters":["嘻嘻，仙子真是慧眼识珠。有眼力。你且随我来。"]},{"code":117,"indent":3,"parameters":[22]},{"code":221,"indent":3,"parameters":[]},{"code":121,"indent":3,"parameters":[795,795,0]},{"code":211,"indent":3,"parameters":[0]},{"code":204,"indent":3,"parameters":[8,4,4,true]},{"code":231,"indent":3,"parameters":[1,"58-GYLGLH1",0,0,0,0,100,100,255,0]},{"code":222,"indent":3,"parameters":[]},{"code":101,"indent":3,"parameters":["",0,0,2,"神秘老头"]},{"code":401,"indent":3,"parameters":["仙子真是有机缘。我这秘技，是通过外部刺激，舒筋活络，既能治愈沉疴旧疾，让灵力运行更顺，有助修行一日千里呀。"]},{"code":101,"indent":3,"parameters":["",0,0,2,"神秘老头"]},{"code":401,"indent":3,"parameters":["只是需要仙子脱出外衫，在这床上上躺好，闭目养神。我这秘技，可不能外传出去。"]},{"code":117,"indent":3,"parameters":[22]},{"code":117,"indent":3,"parameters":[115]},{"code":243,"indent":3,"parameters":[]},{"code":357,"indent":3,"parameters":["TitleCg","openLock","解锁指定Cg",{"id":"181"}]},{"code":657,"indent":3,"parameters":["CgId = 181"]},{"code":241,"indent":3,"parameters":[{"name":"DHCM1_BGM02_Opening1","volume":90,"pitch":100,"pan":0}]},{"code":221,"indent":3,"parameters":[]},{"code":122,"indent":3,"parameters":[971,971,0,0,1]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]这床有趣，居然是温温的，光躺上去，就已经不自觉放松了下来，空气中有股淡淡的花香。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]眼睛轻轻闭上。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]一会儿，有双手覆上身体，\\n[1]身体微僵，那双手却只是搭在她的肩膀，揉捏起来，用力适度，肩膀处似乎真的有些轻松柔软下来。"]},{"code":231,"indent":3,"parameters":[1,"58-GYLGMY1-1",0,0,0,0,100,100,255,0]},{"code":222,"indent":3,"parameters":[]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]那双手又顺着往下，\\n[1]有些紧张，手却又只是掐在腰上，开始揉捏，先前，有些酸痛的腰部居然真的在这番操作下，消散了酸胀。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]就在\\n[1]被揉捏得昏昏欲睡时，那手居然覆上了，她的巨乳，她惊得想睁眼。"]},{"code":231,"indent":3,"parameters":[1,"58-GYLGMY1-2",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]神秘老头：仙子勿怪，只是不是说好，不可睁眼嘛，这可是我的秘技。要全身经络通畅，自然得全身揉搓化开，仙子稍安勿躁。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]说完，老鬼头的手，又只是不急不缓地揉捏了几下白嫩的乳肉。"]},{"code":231,"indent":3,"parameters":[1,"58-GYLGMY1-3",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]手抬了起来，又回到腰上，顺着腰线来回按揉。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]再一会儿，跳过胯部，仔仔细细揉捏，美丽的双腿，饱满的大腿和线条流畅笔直的小腿。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]\\n[1]睫毛轻轻微颤，自然看不到，老鬼头眼中快喷出的欲火。他露出恶意的笑，掏出一瓶怪异的药来。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]神秘老头：仙子，这会儿是特调的药水来。不额外收费呢。你且试试。"]},{"code":231,"indent":3,"parameters":[1,"58-GYLGMY1-2",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]冰冷的液体倒在乳房上时，激了\\n[1]一下，那液体又倒了一些在腹部。"]},{"code":231,"indent":3,"parameters":[1,"58-GYLGMY1-3",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]老鬼头的手又回到腰腹，把那冰冰的液体抹匀在\\n[1]的身体之上。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]这药水有一点甜腻的味道，初始是冰凉的触感，莫名其妙地开始烫了起来。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]无人触碰的乳房有点烫了，\\n[1]不适地扭了扭，乳肉漾起漂亮的浪波。老鬼头适时又去按揉起一手无法掌握的饱满。"]},{"code":231,"indent":3,"parameters":[1,"58-GYLGMY1-2",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]这就舒服多了，有些烫人的液体，在老鬼头的手法下，变成暖暖的，舒适的味道。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]配合着力度适中的揉捏，身体轻轻飘忽了起来。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]老鬼头的手又那么安分，都不会去触碰她又硬又烫的乳尖。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]糟糕，她怎么会突然起了色心。主动地，她用乳尖去蹭老鬼头的手，微微的酥麻，聊胜于无了。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]修长的双腿并紧，搅在一起。老鬼头又放开她的双乳，摁上她的双腿，掰开。"]},{"code":231,"indent":3,"parameters":[1,"58-GYLGMY1-5",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]偏瘦的，有些皮包骨的手，揉着她的大腿肉，揉着揉着，揉到最柔软的内侧。手指状似不经意擦过饱满的阴埠。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]\\n[1]微微皱起了眉。乳肉似乎又烫了起来，被老鬼头揉过得大腿肉也开始慢慢发烫。不知不觉间，双腿之间，隐秘处的仙境，有缓缓流出的爱液。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]\\n[1]咬了咬下唇，有了不当有的期待。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]老鬼头的手，终于从两腿间探了下去，指腹正压着敏感重大起来的蜜豆。"]},{"code":231,"indent":3,"parameters":[1,"58-GYLGMY1-4",0,0,0,0,100,100,255,0]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]另一只手也没有得闲，驾轻就熟地覆在\\n[1]一侧的乳房上，白嫩的乳肉从指缝中溢出，艳色的硬硬的乳尖也被夹住，被坏心眼拉拽。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]甜腻腻的娇喘也从\\n[1]的口中溢了出来。"]},{"code":111,"indent":3,"parameters":[0,8,0]},{"code":117,"indent":4,"parameters":[115]},{"code":101,"indent":4,"parameters":["",0,1,2,""]},{"code":401,"indent":4,"parameters":[""]},{"code":401,"indent":4,"parameters":["\\CT[1]乳房胀胀的，且总有一方被冷落，\\n[1]有些着急。"]},{"code":231,"indent":4,"parameters":[1,"58-GYLGMY2-2",0,0,0,0,100,100,255,0]},{"code":101,"indent":4,"parameters":["",0,1,2,""]},{"code":401,"indent":4,"parameters":[""]},{"code":401,"indent":4,"parameters":["\\CT[1]黑暗中，有两双小小的，冰冰的手贴上了鼓胀的胸脯。"]},{"code":101,"indent":4,"parameters":["",0,1,2,""]},{"code":401,"indent":4,"parameters":[""]},{"code":401,"indent":4,"parameters":["\\CT[1]紧接着，两张小小的嘴，急急把挺立的乳尖含进嘴里，十分用力地吮吸起来。"]},{"code":101,"indent":4,"parameters":["",0,1,2,""]},{"code":401,"indent":4,"parameters":[""]},{"code":401,"indent":4,"parameters":["\\CT[1]那是尖锐的疼痛，却没疼上多久。"]},{"code":101,"indent":4,"parameters":["",0,1,2,""]},{"code":401,"indent":4,"parameters":[""]},{"code":401,"indent":4,"parameters":["\\CT[1]乳房突然一阵轻松，有什么从乳尖喷了出去，还在被吸着，一股一股往外涌。"]},{"code":231,"indent":4,"parameters":[1,"58-GYLGMY2-1",0,0,0,0,100,100,255,0]},{"code":101,"indent":4,"parameters":["",0,1,2,""]},{"code":401,"indent":4,"parameters":[""]},{"code":401,"indent":4,"parameters":["\\CT[1]在药物和鬼婴吮吸的刺激下，\\n[1]居然平白地就产了洁白的母乳。"]},{"code":101,"indent":4,"parameters":["",0,1,2,""]},{"code":401,"indent":4,"parameters":[""]},{"code":401,"indent":4,"parameters":["\\CT[1]那两张贪婪的小嘴，大口大口吮吸着母乳，不管不顾地？"]},{"code":231,"indent":4,"parameters":[1,"58-GYLGMY2-3",0,0,0,0,100,100,255,0]},{"code":101,"indent":4,"parameters":["",0,1,2,""]},{"code":401,"indent":4,"parameters":[""]},{"code":401,"indent":4,"parameters":["\\CT[1]神秘老头的手也还未停，继续刺激着敏感的蜜豆。\\n[1]已经经不起挑逗了。"]},{"code":101,"indent":4,"parameters":["",0,1,2,""]},{"code":401,"indent":4,"parameters":[""]},{"code":401,"indent":4,"parameters":["\\CT[1]穴口翕张，渴望着被进入，被填满。"]},{"code":221,"indent":4,"parameters":[]},{"code":122,"indent":4,"parameters":[970,970,0,0,1]},{"code":122,"indent":4,"parameters":[23,23,1,0,5]},{"code":122,"indent":4,"parameters":[4,4,1,0,3]},{"code":117,"indent":4,"parameters":[22]},{"code":121,"indent":4,"parameters":[795,795,1]},{"code":122,"indent":4,"parameters":[971,971,0,0,0]},{"code":204,"indent":4,"parameters":[2,4,4,false]},{"code":211,"indent":4,"parameters":[1]},{"code":222,"indent":4,"parameters":[]},{"code":117,"indent":4,"p