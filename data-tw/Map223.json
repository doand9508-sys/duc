{"id":10,"name":"EV010","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":357,"indent":0,"parameters":["TitleCg","openLock","解锁指定Cg",{"id":"85"}]},{"code":657,"indent":0,"parameters":["CgId = 85"]},{"code":223,"indent":0,"parameters":[[-68,-68,0,68],60,false]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]浑浑噩噩的，\\n[1]轻飘飘的，意识都感觉晕乎乎的，似乎是有人牵着她的手... ..."]},{"code":222,"indent":0,"parameters":[]},{"code":241,"indent":0,"parameters":[{"name":"DHCM1_BGM02_Opening1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]热闹非凡的街道上，女子面无表情的走着，摇摇晃晃，让人不由担忧的看着。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]人越来越多，女子无神的眼睛抬起来，似乎有些抗拒，但是又拒接不了。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]众人一看，哟！这不是之前那个骚气冲天，愿意给众人看胸的女菩萨吗？"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]这一次，\\n[1]不仅仅露出胸部，她还提起了裙子，一双洁白如玉的大长腿，还有那柔软光滑的蜜穴，让众人沸腾了起来。"]},{"code":231,"indent":0,"parameters":[1,"47-KZLCXX1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]丰满的胸部，白皙的大腿，躁动的人群。"]},{"code":101,"indent":0,"parameters":["",1,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]官二代：好美，那小穴要是能深入，一定是一件很棒的事情。"]},{"code":101,"indent":0,"parameters":["",3,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]铁匠：太淫荡了，这女人是脸都不要了，妓女都没她这样的露骨。"]},{"code":101,"indent":0,"parameters":["",3,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]乞丐：哈哈哈，这么美如仙子的人，要是被玷污是何等的美好。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]众人的污言秽语全部传入\\n[1]的耳朵里，只让\\n[1]内心一阵烦躁，有一些扭曲的渴望从身体里觉醒。"]},{"code":231,"indent":0,"parameters":[1,"47-KZLCXX2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]渴望被观看，看着他们着急的样子，蜜穴就开始分泌爱液，缓缓的从蜜穴流到大腿。"]},{"code":101,"indent":0,"parameters":["",1,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]官二代：快看，这骚货，居然开始流水了。"]},{"code":101,"indent":0,"parameters":["",4,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]大夫：老朽行医多年，没看到这么骚的，只是被众人注视，就能流水，实在是太骚了。"]},{"code":101,"indent":0,"parameters":["",3,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]乞丐：我话放这里，要是你愿意，我一定用我那肮脏的大屌满足你。没有哪个女子，能抵抗得了大屌的诱惑。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]看着这些人各个看着她，像是多年的饿狼看到香香的肉。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]甚至有些人开始摸着自己的下体，尤其是那乞丐从单薄的衣服看到那硕大的肉棒。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]一想到那些各种各样的肉棒狠狠的插着自己蜜穴，身为高高在上的公主修仙者，多么羞耻。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]巨大的羞耻感，伴随着更多是无法言喻的刺激，被男人们群着，甚至可能一不小心就会被狠狠抽插。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]虽然脑子晕乎乎的，身体是被人控制住的，但是，身体的反应才最为真实。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]这种无耻的露出，胸部和蜜穴给任何人观看，这样想着一股热流直冲蜜穴。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：啊啊啊啊啊~~~❤"]},{"code":231,"indent":0,"parameters":[1,"47-KZLCXX3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]一股股快感直冲天灵盖，蜜穴喷出了更多的蜜汁。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]高潮的快感，让\\n[1]忘记了露出被众人围观的羞耻感。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]这下众人已经无法忍耐，纷纷上来对着\\n[1]上下其手。"]},{"code":231,"indent":0,"parameters":[2,"35-XX2-1",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":231,"indent":0,"parameters":[2,"35-XX2-2",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":231,"indent":0,"parameters":[2,"35-XX2-3",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":231,"indent":0,"parameters":[2,"35-XX2-2",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":231,"indent":0,"parameters":[2,"35-XX2-3",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":231,"indent":0,"parameters":[2,"35-XX2-4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：啊啊啊啊~~~❤"]},{"code":