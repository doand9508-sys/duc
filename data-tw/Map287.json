nt":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]也就说，有些方式其实用在后期反而更好。"]},{"code":231,"indent":0,"parameters":[2,"6-LH5",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["是这个意思，那么我们是现在就去水灾那里还是等到明天。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[2]如果有方法，并且现在就能实施，那么我们现在就去。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["那就在等会，我是有方法，但需要的东西还没到，不过也快了。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["嗯，等你们的人到了就去。"]},{"code":221,"indent":0,"parameters":[]},{"code":235,"indent":0,"parameters":[2]},{"code":117,"indent":0,"parameters":[115]},{"code":231,"indent":0,"parameters":[1,"13-MJJS",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]在等待的过程中，\\n[1]独自一人来到了江南城区里的一片景区，入目的碧波荡漾，莲花绽放。"]},{"code":230,"indent":0,"parameters":[30]},{"code":222,"indent":0,"parameters":[]},{"code":117,"indent":0,"parameters":[53]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["（以前听哥哥说过这里风景不错，因为年纪小一只没能来...现在虽然来了，但是父皇母后都不在身边。）"]},{"code":231,"indent":0,"parameters":[2,"6-LH5",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["这里的风景很不错，但是，你看起来不是很开心。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[2]风景依旧，但是故人不在。"]},{"code":231,"indent":0,"parameters":[2,"6-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["对不起...我... ..."]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]没什么，我先回去了，若你那一切都准备好了，可以来叫我。"]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["就当\\n[1]转身离开的时候，忽然两人同一时间，脑海里似乎多了一个画面。"]},{"code":117,"indent":0,"parameters":[115]},{"code":221,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[1,"11-JNJJ5",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：这到底是什么？"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]宇文玉：似乎是我和\\n[1]... ..."]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]但也只是一瞬间的事情，很快，\\n[1]和宇文玉都清醒过来。"]},{"code":231,"indent":0,"parameters":[1,"13-MJJS",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":222,"indent":0,"parameters":[]},{"code":117,"indent":0,"parameters":[53]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]这是怎么回事？为什么有很强烈的似曾相识的感觉，仿佛曾经经历过。"]},{"code":231,"indent":0,"parameters":[2,"6-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["我也有这样感觉。"]},{"code":235,"indent":0,"parameters":[2]},{"code":117,"indent":0,"parameters":[115]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["两人还想说些什么的时候，似乎有人过来，对着宇文玉汇报了情况，原来是送物资的已经到了。"]},{"code":117,"indent":0,"parameters":[53]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["先去看看，如果有需要我帮忙的地方... ..."]},{"code":231,"indent":0,"parameters":[2,"6-LH1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["不行，不能太依赖修士，不然以后什么都要修士来做，修士为什么要帮我们，肯定会提要求，而且会变得越要越多。"]},{"code":231,"indent":0,"parameters":[2,"6-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["当然，如果这次凡人真的无法抵抗，也只能麻烦了，但是，如果能解决，还是让凡人学会自己解决。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[6]... ..."]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]你说的对，哪怕是我也会有离开的时候，这里总归是凡人的。"]},{"code":235,"indent":0,"parameters":[2]},{"code":117,"indent":0,"parameters":[115]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["说完两人前往了水灾泛滥的地方。"]},{"code":221,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[1,"13-JNHZ1",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["水面波涛汹涌，看不清远方的山体现在是什么样了。"]},{"code":117,"indent":0,"parameters":[53]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]确实棘手。"]},{"code":231,"indent":0,"parameters":[2,"6-LH1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["这样的情况，还是先用石头... ..."]},{"code":235,"indent":0,"parameters":[2]},{"code":117,"indent":0,"parameters":[115]},{"code":101,"indent":0,"parameters":["",0,0,2,"瘦小的老头"]},{"code":401,"indent":0,"parameters":["王爷，万万不可，之前防灾的工程动静太大，导致山体滑坡，现在洪水更加凶猛，与其堵塞，不如寻找适合的下流处开口，让水流向更远的地方。"]},{"code":231,"indent":0,"parameters":[2,"6-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["你说的也有一定道理，先把四周要处理滑坡处的淤泥石头树木等，再打探一些那个方位的下楼适合做切口。"]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,0,2,"瘦小的老头"]},{"code":401,"indent":0,"parameters":["谢谢王爷，小的再多嘴几句，不知道王爷有没有药材来，小的怕洪水去后会有疫病。"]},{"code":117,"indent":0,"parameters":[53]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[5]您很熟悉这里也知道怎么处理，为什么？您还是一个农家老人，上头不应该嘉奖您。"]},{"code":231,"indent":0,"parameters":[2,"6-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["确实很奇怪，不过，老人家放心，药材我自然带了，也带了一些粮食。"]},{"code":235,"indent":0,"parameters":[2]},{"code":117,"indent":0,"parameters":[115]},{"code":101,"indent":0,"parameters":["",0,0,2,"瘦小的老头"]},{"code":401,"indent":0,"parameters":["好好好，那小老头就替乡亲们谢谢王爷了。"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["说完老人鞠了一躬，转身就走，\\n[1]只感觉那老人身上似乎散发着隐隐金光。"]},{"code":117,"indent":0,"parameters":[53]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]是个有功德之人，却活的如此潦草，不对劲。"]},{"code":231,"indent":0,"parameters":[2,"6-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["我们今天才到，先休息，明天探查了现场，再去找这个老人家，我也觉得不对劲。"]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[2]也好。"]},{"code":235,"indent":0,"parameters":[2]},{"code":117,"indent":0,"parameters":[115]},{"code":221,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[1,"13-HKFJ1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]第二天"]},{"code":230,"indent":0,"parameters":[30]},{"code":222,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[2,"6-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["现在就走吗？"]},{"code":235,"indent":0,"parameters":[2]},{"code":117,"indent":0,"parameters":[53]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]可以的，不过有件事我想问你。"]},{"code":231,"indent":0,"parameters":[2,"6-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["可以，只要是你想问的，都可以。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[2]我去了你书房的隐藏房间，我想问，你那些诗是哪来的？？"]},{"code":231,"indent":0,"parameters":[2,"6-LH6",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":231,"indent":0,"parameters":[2,"6-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["那些都是我见过你之后写的，是我自己写的。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]可是，我小时候宇文卿亲手将那些诗送给我，和你写的一字不差。"]},{"code":231,"indent":0,"parameters":[2,"6-LH3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["你意思，当年哥哥去你们那送你的情诗和我现在写的一模一样。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[2]是... ..."]},{"code":231,"indent":0,"parameters":[2,"6-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["不对劲，这一切一定有不对的地方，我向你保证，哥哥和我关系不是很好，他的东西我都没见过。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]也许有什么误会...我知道了，我们先去水灾那吧。"]},{"code":117,"indent":0,"parameters":[115]},{"code":235,"indent":0,"parameters":[2]},{"code":221,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[1,"13-JNHZ1",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[30]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["到了之后，大家都在干劲十足的干活，\\n[1]忍不住想自己上手，却被昨天看到的老头拦住了。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"瘦小的老头"]},{"code":401,"indent":0,"parameters":["王爷，在水流下方的一块空地，有一个只有五六户人家的小村子，那里大小适合，正好可以容纳流下去的水，就是那些人的去留... ..."]},{"code":231,"indent":0,"parameters":[2,"6-LH5",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["不错，我会派人去查看，若如你所说，本王一定给他们安置妥当，给房子外每家再给50两安置费。"]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,0,2,"瘦小的老头"]},{"code":401,"indent":0,"parameters":["谢王爷。"]},{"code":221,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[1,"13-SL1-2",0,0,0,0,100,100,255,0]},{"code":231,"indent":0,"parameters":[2,"11-JNJJ1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]一切都按着计划来实施，有了老人的帮助，更是速度加快。"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]在一切都快要完成时，\\n[1]也逐渐放心下来，有宇文玉在，杀了宇文卿和朱雀，她也能安心的离开。"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]也许会飞升，也许会老死，至少，不会再有亏欠。"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]想着\\n[1]和宇文玉在回城的郊外遇到了山贼，要命不要钱。"]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：看来你说的没错，你和宇文卿确实关系不好。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]宇文玉：这也不是第一次了，不过，有你在，这样的袭击，实在不够看。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]就当两人正准备行动，忽然脑海里又闪过一个片段。"]},{"code":231,"indent":0,"parameters":[3,"11-JNJJ4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：怎么回事？"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]宇文玉：来不及了，只能先杀了他们。"]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]两人与迅雷不及掩耳之势，将所有人的处理完后，来到客栈\\n[1]的房间内。"]},{"code":235,"indent":0,"parameters":[2]},{"code":235,"indent":0,"parameters":[3]},{"code":231,"indent":0,"parameters":[1,"13-HKFJ1",0,0,0,0,100,100,255,0]},{"code":222,"indent":0,"parameters":[]},{"code":117,"indent":0,"parameters":[53]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]现在可以告诉我之前在王府怎么也不愿意说的事情吧？"]},{"code":231,"indent":0,"parameters":[2,"6-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["那是5岁的时候，皇兄已经7岁，父皇本来打算带我们去你们皇朝交谈。"]},{"code":231,"indent":0,"parameters":[2,"6-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["当晚我就高烧不止，差点就没了，父皇心疼我就不让我去了。"]},{"code":231,"indent":0,"parameters":[2,"6-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["在回来，皇兄忽然就说要和父皇打赌，如果他能战胜六周国，合并入北明国，那父皇必须把皇位传给他。"]},{"code":231,"indent":0,"parameters":[2,"6-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["父皇看他当时就7岁，以为是小孩子心性就没在意，答应了...结果... ..."]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[3]就是那个时候，他用各种诗词把我迷惑，我...因此给了一些机密文件... ..."]},{"code":231,"indent":0,"parameters":[2,"6-LH3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["这不是你的错，就算是我的妹妹们，都是被父皇娇宠着，什么也不懂。"]},{"code":231,"indent":0,"parameters":[2,"6-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["而后父皇似乎察觉了什么把我送了出去，直到父皇去世，宇文卿登记，我才被召唤。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["我一直感觉自己缺失了什么，直到，那天你准备杀我，那个人出现后，一切我都明白了。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["所以，你根本没有去过六周国，宇文卿做了什么你也不是很清楚？"]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["他怎么可能让我知道，我一直被打压在朝堂边缘，只有辛苦的事情才会想起我。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[2]（就算如此，杀死父皇母后还有哥哥的就是你们宇文家，但是，要现在的我去管理一个国家，实在是苦手，不如让有能力去，我也好安心修仙。）"]},{"code":231,"indent":0,"parameters":[2,"6-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["我之前也有去了解，那个老人是当地的老秀才，文采不错，而且对于治理河道非常有心得，这样的人却不受重用。"]},{"code":231,"indent":0,"parameters":[2,"6-LH3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["皇兄之前的政策和他自己想出来给县令的大差不差，应该说是更加完整，但不是适合初期，应该是时候中后期。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["所以才会出现开始效果不错，但用的都是死手，导致山体滑坡。"]},{"code":231,"indent":0,"parameters":[2,"6-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["有一种感觉，皇兄似乎未卜先知，又或许应该这样说，他似乎知道最后解决的办法，因为不知道其中变化，直接给了最后结果，导致状况更差。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[6]你的意思是宇文卿可能知道未来发生什么，怎么处理，所以他一直按部就班，而不顾及现实情况，导致本来是好方法结果却是坏的。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]会不会是朱雀... ..."]},{"code":231,"indent":0,"parameters":[2,"6-LH1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["朱雀没有占卜未来的能力..."]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]那这一切？"]},{"code":231,"indent":0,"parameters":[2,"6-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["在那次你袭击我后，我明白了很多，我应该是从上界来的，只为了解决六周国你之后出现的暴君，因为他导致了大规模战争，死了很多人。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["只要成功让事情不发生并且两国统一，我就获得对应功德，从而满足脱离天道条件，前往其他位面或者说其他世界探索。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[5]所以，你和宇文卿也是想欺骗我？"]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["我只想联姻，从而兵不血刃的达到合并，与你一起将两个国家人民好好融合，所以你其实是应劫之人，为了避开后面悲剧。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[5]可是，现在我父皇母后都死了，哥哥也死了，国家也不在了，你跟我说是劫？"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[5]是你联和宇文卿一起骗我对吧。"]},{"code":117,"indent":0,"parameters":[115]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["顿时房间里都是暴走的灵力，只要\\n[1]愿意，这些灵力会绞杀了宇文玉，但\\n[1]明白，他的前身会保护他。"]},{"code":231,"indent":0,"parameters":[2,"6-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["对我来说，这样做没有任何好处，大量的人死亡，只会减少我最后获得的功德。"]},{"code":117,"indent":0,"parameters":[53]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[4]那我现在算什么？我父皇母后都死了，哥哥也死了，而你所说是因为宇文卿知道了未来，他为什么会知道未来？"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[4]如果朱雀不会占卜，但是，一切都因为朱雀出现而改变，是不是有可能朱雀其实是未来之人？"]},{"code":231,"indent":0,"parameters":[2,"6-LH1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"宇文玉"]},{"code":401,"indent":0,"parameters":["你说的对，自从某天开始皇兄就很奇怪，再加上之后出现的朱雀，很有可能朱雀来自未来，将一切未来发生的告诉了皇兄。"]},{"code":101,"indent":0,"parameters":["",0