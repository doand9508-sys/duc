{"id":1,"name":"EV001","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":357,"indent":0,"parameters":["TitleCg","openLock","解锁指定Cg",{"id":"207"}]},{"code":657,"indent":0,"parameters":["CgId = 207"]},{"code":241,"indent":0,"parameters":[{"name":"DHCM1_BGM02_Opening1","volume":90,"pitch":100,"pan":0}]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]一切都按照\\n[1]所想，通过魔尊欲洐的帮助，获得了下界云霓大陆的权柄。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]所有人如同疯了一般，互相残杀，而朱雀身上的冤魂也不断蚕食她，她在痛苦中逐渐消散，连灵魂都不曾留下。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]宇文卿更是被人民造反杀死在皇宫大殿里。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]只有墨轩一直守着阿欢，两人度过了艰难的岁月。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]但这一切还不够，还不够填满被伤害的心。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天尊天洐：你怎么来了？"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：我为什么不能来？"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天尊天洐：你那么恨我，应该巴不得我死在这里吧？"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：不，你不能死，你啊，要满足我，把我那因为你失误而失去的，一个一个填满。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天尊天洐：什么意思？"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：很想知道，高高在上的天尊，被欲望折磨成只会交配的玩意，是多么快乐。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天尊天洐：你不能这样，你... ..."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]衣服被撕开，露出强壮的身躯，硕大的肉棒坚挺不已，\\n[1]坐在天洐腿上，紧紧的握着捆绑着他的锁链。"]},{"code":231,"indent":0,"parameters":[1,"64-TJHJJ1-1",0,0,0,0,100,100,255,0]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：天尊大人，怎么就勃起了，不应该无欲无求。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天尊天洐：我修的不是无情道。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天尊天洐：唔...不要动... ..."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：只是屁股蹭蹭就受不了了，真想看看这大肉棒插进去的时候，天尊大人会变得如何。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天尊天洐：不要... ..."]},{"code":231,"indent":0,"parameters":[1,"64-TJHJJ1-2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]不断挑逗着天洐，两人的身体不断摩擦，气温都开始变得不一样了。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天尊天洐：不要继续了。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：可是天尊大人，你的气息都不稳了，而且，你的肉棒好硬好烫，它很想进来是吧。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]又摇晃了腰杆，那柔软丰益的臀部，摩擦着天洐的肉棒，让他的呼吸都更加急促了。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：天尊大人，好好感受我，成为我的宠物吧。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]说完\\n[1]一屁股坐了下去，那硕大的肉棒被小穴吸入，狠狠的包裹着。"]},{"code":250,"indent":0,"parameters":[{"name":"1-NZCR","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":0,"parameters":[1,"64-TJHJJ1-3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：天尊大人的表情真好看，我的小穴，您喜欢吗？"]},{"code":250,"indent":0,"parameters":[{"name":"1-NZSFH1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天洐感受着肉棒被肉壁紧紧吸附，挤压，只感觉小腹一顿火热，差点就把持不住射了出来。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]根本不在乎天洐会不会回应她，她只想感受当下的快乐，腰杆不断的一上一下，蜜穴将肉棒吸入又吞出，发出了噗呲噗呲的声音。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]蜜汁不断从蜜穴里流出，小穴与肉棒撞击，发出的声音令人面红耳赤。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：天尊大人，如何，我的小穴很棒吧，你的肉棒更加的坚硬了，想内射我吗？"]},{"code":250,"indent":0,"parameters":[{"name":"1-NZSFH2","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天洐：不要再说了，不要再说... ...唔"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]抬起腰杆又狠狠的坐了下去，肉棒被一口气全部插入小穴里，只顶花心，一种难以言喻的快乐充斥两人的身体。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：天尊大人，给我吧，我想要你的精液，充满我的小穴。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天洐：不要，这不对。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：天尊大人，没有什么不对，只要好好感受这个快乐就是。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]在\\n[1]的攻击下，小穴里的肉棒不断跳动，终于一道温热的液体冲出，不断射入小穴，小穴充满了温暖的精液。"]},{"code":231,"indent":0,"parameters":[1,"64-TJHJJ1-4",0,0,0,0,100,100,255,0]},{"code":250,"indent":0,"parameters":[{"name":"1-NZSFGC","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：啊啊啊啊！~~~好棒啊，天尊大人，你还在射精呢？"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天洐：住口... ..."]},{"code":251,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：我好喜欢呢，所以啊，天尊大人不能休息啊，要一直一直满足我。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]天洐：你疯了，你这样...唔...太紧了..."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]没有休息，两人又纠缠在了一起，在不断的冲击中，宛如两头不知疲倦的野兽，相互吞噬着对方的一切。"]},{"code":221,"indent":0,"parameters":[]},{"code":122,"indent":0,"parameters":[1312,1312,0,0,1]},{"code":235,"indent":0,"parameters":[1]},{"code":355,"indent":0,"parameters":["DataManager.SaveVariables()"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\C[10]——EDN—— 天尊是我的禁脔"]},{"code":117,"indent":0,"parameters":[756]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":0,"y":0}
