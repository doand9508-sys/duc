},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":118,"indent":1,"parameters":["btg"]},{"code":357,"indent":1,"parameters":["TitleCg","openLock","解锁指定Cg",{"id":"5"}]},{"code":657,"indent":1,"parameters":["CgId = 5"]},{"code":243,"indent":1,"parameters":[]},{"code":241,"indent":1,"parameters":[{"name":"DHCM1_BGM02_Opening1","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":1,"parameters":[2,"50-SSZBH1",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]似人非人的怪物从背后钳制住\\n[1]，她越挣扎，粗糙的毛发越是摩擦着她娇嫩的肌肤，产生密密细微的疼。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]猿怪胯下一根坚硬的炙热的东西更是毫不客气地抵着她的雪臀。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]毛茸茸的双手紧紧环抱着她，她的酥胸被挤在中间，粉红的乳尖挤得长长凸起，颤巍巍迎着凉风。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]原始的本能使得猿怪急切地寻找着那一方湿润狭窄的小穴，却不得，毫无章法地在\\n[1]的穴外动作。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]正好摩擦到她的蜜豆，来回地快速抽插，磨得那蜜豆开始微微肿胀。"]},{"code":101,"indent":1,"parameters":["",0,1,1,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]又疼又舒服的感觉逼出\\n[1]的一颗泪来，猿怪冒出的透明前液与穴内冒出的蜜汁又正被坚硬。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]的阳具摩擦着涂抹在\\n[1]平坦的小腹之上，亮晶晶一片。乳尖在此时突感瘙痒难耐，脸上燥热。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]红霞飘上娇美的脸庞，轻咬贝齿也挡不住甜美的喘息溢出红唇。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]那一根东西竟然变得更大更硬了一些，约有了一肘见长，猿怪的动作幅度更快更大。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]腥臭急促的呼吸打在\\n[1]的脖颈之上，烧得整个身体都跟着发烫颤抖起来。小腹也跟着忍不住抽动了几下，不知是害怕还是期待。"]},{"code":111,"indent":1,"parameters":[0,15,0]},{"code":231,"indent":2,"parameters":[2,"50-SSZBH2-1",0,0,0,0,100,100,255,0]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]核桃大的头部在这无序地动作下，误打误撞间，终于借着湿滑的蜜汁挤进肖想已久的蜜穴。"]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]圆润湿滑的阳具终于寻到一处不寻常的细缝，期间最为温热湿滑，猿怪知是觅到了肖想之处，更是猴急。"]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]然而却只是蹭进一寸就似乎遇上了什么格挡，猿怪感到疑惑却没有那个脑力多想。"]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]只是更用劲地往内部挤。纯洁的处女膜被可怖的巨物顶弄，抵抗了没有。"]},{"code":231,"indent":2,"parameters":[2,"50-SSZBH3-1",0,0,0,0,100,100,255,0]},{"code":250,"indent":2,"parameters":[{"name":"2-NZQJCR","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]几下，就被破了开，一丝鲜血从穴内缓缓流出，巨疼使\\n[1]的泪水滚落，猿怪却没有给她一丝喘息的机会。"]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]猛烈地抽动起来，她通红了鼻尖，不由地抽泣。猿怪自然不懂什么是怜香惜玉，只是胯下更为卖力。"]},{"code":0,"indent":2,"parameters":[]},{"code":411,"indent":1,"parameters":[]},{"code":231,"indent":2,"parameters":[2,"50-SSZBH2",0,0,0,0,100,100,255,0]},{"code":250,"indent":2,"parameters":[{"name":"2-NZQJH1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]核桃大的头部在这无序地动作下，误打误撞间，终于借着湿滑的蜜汁挤进肖想已久的蜜穴。"]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]猿猴胯下更为卖力，一遍一遍更深地挤进蜜穴的深处，吧嗒吧嗒的水声不绝于耳。"]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]是蜜汁跟着抽出的阳具飞溅出来，更多的蜜汁还没来得及流出又被插回了蜜穴之中。"]},{"code":231,"indent":2,"parameters":[2,"50-SSZBH3",0,0,0,0,100,100,255,0]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":111,"indent":1,"parameters":[0,15,0]},{"code":231,"indent":2,"parameters":[2,"50-SSZBH4-1",0,0,0,0,100,100,255,0]},{"code":0,"indent":2,"parameters":[]},{"code":411,"indent":1,"parameters":[]},{"code":231,"indent":2,"parameters":[2,"50-SSZBH4",0,0,0,0,100,100,255,0]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]猿怪的一只手更是抓握着\\n[1]的腰配合胯间的动作一次次往下摁去。身体被破开，失控的感觉。"]},{"code":250,"indent":1,"parameters":[{"name":"2-NZQJH2","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]让\\n[1]忍不住想夹紧双腿，猿怪的膝盖却抵着\\n[1]的大腿。"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]如手般灵活的足更是握住\\n[1]的脚腕往外拉开，方便自己更轻松更深地进入\\n[1]的身体内部。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]多褶的蜜道紧紧吸吮着长度，尺寸骇人的赭褐色阳具，那猿怪只顾自己的爽快，剧烈而快速地宣泄自己的欲望。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]强烈的快感聚集在腹部，接着一浪一浪冲击起\\n[1]的理智。"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]令人窒息的强大快感，让那可爱的舌尖伸出了唇外，甜美暧昧的娇喘由着抽插的频率无所顾忌地叫出来。"]},{"code":111,"indent":1,"parameters":[0,15,0]},{"code":357,"indent":2,"parameters":["FlyCat_LL_SceneMenu","setTearPeople","设置破处者",{"name":"狌狌","variablesId":""}]},{"code":657,"indent":2,"parameters":["破处者姓名 = 狌狌"]},{"code":657,"indent":2,"parameters":["指定回传破处者姓名的变量 = "]},{"code":122,"indent":2,"parameters":[134,134,0,0,1]},{"code":122,"indent":2,"parameters":[18,18,1,0,1]},{"code":122,"indent":2,"parameters":[34,34,1,0,1]},{"code":122,"indent":2,"parameters":[24,24,1,0,5]},{"code":122,"indent":2,"parameters":[4,4,1,0,5]},{"code":117,"indent":2,"parameters":[17]},{"code":117,"indent":2,"parameters":[18]},{"code":121,"indent":2,"parameters":[15,15,1]},{"code":235,"indent":2,"parameters":[2]},{"code":251,"indent":2,"parameters":[]},{"code":117,"indent":2,"parameters":[341]},{"code":0,"indent":2,"parameters":[]},{"code":411,"indent":1,"parameters":[]},{"code":122,"indent":2,"parameters":[134,134,0,0,1]},{"code":122,"indent":2,"parameters":[18,18,1,0,1]},{"code":122,"indent":2,"parameters":[34,34,1,0,1]},{"code":122,"indent":2,"parameters":[24,24,1,0,5]},{"code":122,"indent":2,"parameters":[4,4,1,0,5]},{"code":117,"indent":2,"parameters":[17]},{"code":117,"indent":2,"parameters":[18]},{"code":235,"indent":2,"parameters":[2]},{"code":251,"indent":2,"parameters":[]},{"code":117,"indent":2,"parameters":[341]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":4,"y":1}
