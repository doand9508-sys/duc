[]},{"code":357,"indent":3,"parameters":["TitleCg","openLock","解锁指定Cg",{"id":"154"}]},{"code":657,"indent":3,"parameters":["CgId = 154"]},{"code":241,"indent":3,"parameters":[{"name":"DHCM1_BGM02_Opening1","volume":90,"pitch":100,"pan":0}]},{"code":221,"indent":3,"parameters":[]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]如今的傲天门虽然在外人眼中并未变化，但实则早已翻天覆地。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]仙路漫漫，为了一线突破的机会，难免弱肉强食，但这一法则往往并不站在常把它挂在嘴上那类人的一边。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]但既然认可了强者为尊，如今技不如人，能保住性命，为奴为犬，就足该感激涕零了。"]},{"code":231,"indent":3,"parameters":[1,"81-ATMLQK3-1",0,0,0,0,100,100,255,0]},{"code":222,"indent":3,"parameters":[]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]\\n[1]一脚将李乾坤踢翻在地，曾经不可一世的傲天门主，如今被脱得赤条条的，仿佛去了毛的鸡一般顺从。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]李乾坤：恭迎仙子大驾光临！主...主人，求您开恩..."]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]面对小辈，说出这般言语，难免无地自容，但谁是刀俎谁为鱼肉，一切都已尘埃落定"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]\\n[1]一脸鄙夷的看着身下人，明明被如此羞辱，却还是勃起了，她冷笑着，坐了下去，那巨大的阳具被小穴包裹。"]},{"code":231,"indent":3,"parameters":[1,"81-ATMLQK3-2",0,0,0,0,100,100,255,0]},{"code":250,"indent":3,"parameters":[{"name":"4-DLPYH2","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]\\n[1]：我还是喜欢你之前那副鼻子翘到天上的样子，怎么了？傲天门门主竟是这番德性了？"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]李乾坤拼命挺起下身，不断的抽插，\\n[1]一边细细品味，一边摇摆着腰杆，不断的吸着肉棒。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]李乾坤：仙子，太紧了，能不能松点？"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]\\n[1]：这点就要不行了？？？"]},{"code":231,"indent":3,"parameters":[1,"81-ATMLQK3-3",0,0,0,0,100,100,255,0]},{"code":250,"indent":3,"parameters":[{"name":"4-DLPYH3","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]李乾坤早已经大汗淋漓，虽然被压在身下很羞耻，但如此美艳的身体和极品小穴，让他感觉到性奋。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]李乾坤：不是...主人...不行了。"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]\\n[1]：再快点，就这点本事，不是合体期大能吗？"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]为了自己面子，李乾坤又加大了进攻，如此，两人只感觉汗汗淋漓，有一种即将上云霄的感觉。"]},{"code":231,"indent":3,"parameters":[1,"81-ATMLQK3-4",0,0,0,0,100,100,255,0]},{"code":250,"indent":3,"parameters":[{"name":"Poison","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]\\n[1]：你还没你的曾孙子厉害呢，不过他那副早泄的样子倒是随你一样！你们李家都是如此？哈哈哈哈！"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":["\\CT[1]李乾坤：可....可恶啊！！！"]},{"code":101,"indent":3,"parameters":["",0,1,2,""]},{"code":401,"indent":3,"paramet