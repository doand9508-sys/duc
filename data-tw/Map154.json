":3,"parameters":[0,535,0]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：你知道凌霄宫的由来吗？"]},{"code":213,"indent":4,"parameters":[-1,8,true]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:0,600,>\\n[1]：这个师傅没讲过。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：凌霄宫的创始人天玄子是隐藏的修仙世家的小儿子，因为是小儿子所以过于溺爱，导致天玄子沉迷炼丹，导致修仙和身体并不好。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：虽然说是不好，但也只是针对修士而已，不过，只要世家不倒，天玄子一辈子沉迷炼丹也无妨。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:0,600,>\\n[1]：难道又是世家倒了？"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：那倒没有，只是新任家主和天玄子有私仇，天玄子为此被赶出世家。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:0,600,>\\n[1]：听你这样说，天玄子根本没有能力胜任家主之位，为什么还要被赶出，有点未免心眼太小。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：其实的事情，说来也有趣，据说有个野史你听不听？"]},{"code":102,"indent":4,"parameters":[["吃瓜，我要吃瓜！","不听。"],1,0,1,0]},{"code":402,"indent":4,"parameters":[0,"吃瓜，我要吃瓜！"]},{"code":101,"indent":5,"parameters":["",0,0,2,""]},{"code":401,"indent":5,"parameters":["<qp:2,600,>器魂：据说那天玄子有一天炼丹，不小心丹炉爆炸，产生了奇怪的气体，偏偏这个时候呢。"]},{"code":101,"indent":5,"parameters":["",0,0,2,""]},{"code":401,"indent":5,"parameters":["<qp:2,600,>器魂：新家主的儿子的未婚妻路过，两人就，嘿嘿嘿。"]},{"code":101,"indent":5,"parameters":["",0,0,2,""]},{"code":401,"indent":5,"parameters":["<qp:2,600,>器魂：那新家主的儿子知道，那能忍下这口气，去老父亲面前，闹着要收拾天玄子。"]},{"code":101,"indent":5,"parameters":["",0,0,2,""]},{"code":401,"indent":5,"parameters":["<qp:2,600,>器魂：天玄子本来就是家里受宠的小儿子，父母坐镇根本不拿新家主当回事。"]},{"code":101,"indent":5,"parameters":["",0,0,2,""]},{"code":401,"indent":5,"parameters":["<qp:2,600,>器魂：据说天玄子还和那女的不清不楚，生了孩子。"]},{"code":119,"indent":5,"parameters":["JX"]},{"code":0,"indent":5,"parameters":[]},{"code":402,"indent":4,"parameters":[1,"不听。"]},{"code":119,"indent":5,"parameters":["JX"]},{"code":117,"indent":5,"parameters":[52]},{"code":0,"indent":5,"parameters":[]},{"code":404,"indent":4,"parameters":[]},{"code":118,"indent":4,"parameters":["JX"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：被赶出来后，天玄子要被人骗的很惨，才知道，光靠炼丹还是只会被欺负。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:0,600,>\\n[1]：所以？"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：天玄子开始学法术和体术，让自己一步一步变得更加强大啊，同时他也发现了很多炼丹术士的通病也就是体弱。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：而且有些大门派和大世家打着保护收留的炼丹术士的旗号，把炼丹术士强行留下专门炼丹，不得出门。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：为了保护炼丹术士，天玄子创造了凌霄宫，专门收留各种落魄的炼丹术士，一时间，凌霄宫声明大旺。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：在凌霄宫成立200年后，天玄子渡劫飞升，但是，天玄子在凌霄宫留下了一丝分神，以便守护凌霄宫。"]},{"code":213,"indent":4,"parameters":[-1,1,false]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:0,600,>\\n[1]：你是说，天玄子那一丝分神，还在凌霄宫。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：对，天玄子虽然私生活我们不了解，但为人正直，他对于哪些魔修、采阴补阳还有鬼修非常不耻。"]},{"code":213,"indent":4,"parameters":[-1,8,true]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：要是让天玄子看到现在的凌霄宫，怕是要从天上硬闯也要下来大义灭亲了。"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:0,600,>\\n[1]：（所以是天玄子在帮我吗？那他的目的应该就是\\C[10]杀了师傅他们\\C[0]，但是，以我现在的能力根本杀不死。）"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:2,600,>器魂：你要是有什么迷茫，可以去禁地那边，不过你那师傅也是个狠人，禁地那边被法阵封印了。"]},