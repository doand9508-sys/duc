e":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]官二代还没说完，只感觉又有人走了进来。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]铁匠：是骚货，水润润的骚货，这大奶子，这大屁股，骚货，是不是想要爷爷我的肉棒！"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]官二代有些不悦的皱眉，这个时候... ..."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：还不够哦，再多来一点~~~❤"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]娇滴滴的说着，声音妩媚又动人，应得刚刚进来的人控制不住就想扑了上去。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]才说着，又一个人进来了。"]},{"code":231,"indent":0,"parameters":[1,"47-KZLUXX4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]不明真相的跟风者也进来了，更多更多的人被吸引过来。"]},{"code":231,"indent":0,"parameters":[1,"47-KZLUXX5",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]看着那么多的人，忍不住双腿发软，想到之后会发生的事情，心脏都怦怦跳。"]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]秦正经：仙子，请随心所欲吧~~~我可爱的玩具，让我更加快乐。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]被日常道德所捆绑的内心，已经破碎，只有做爱的欢愉能让她感受到快乐。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]抬起腿，露出柔软的小穴和粉嫩的菊穴，任君采撷。"]},{"code":231,"indent":0,"parameters":[1,"47-KZLULJ1",0,0,0,0,100,100,255,0]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]之前就进来的官二代早就脱光了，肉棒早早就勃起，只等着进入小穴里狠狠抽插。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：进来吧，狠狠的入肉奴家❤"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]官二代：不愧是骚货，这么孟浪，看我不把你这小蹄子弄的欲生欲死。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]说着官二代就狠狠的插入\\n[1]的小穴里，只感觉自己的肉棒被狠狠的吸入小穴里，紧紧被肉壁包裹起来。"]},{"code":231,"indent":0,"parameters":[1,"47-KZLULJ2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：好棒，公子的肉棒又大又粗，奴家好喜欢，请狠狠的插奴家。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]官二代：你这骚货，看本公子的大肉棒怎么好好揉虐你的小穴。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]说着就狠狠的抽插起来，而这个时候，另一个男人也急吼吼的冲上来。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]铁匠：你这骚货，光是一边一定会很寂寞吧，我也来了！！！"]},{"code":231,"indent":0,"parameters":[1,"47-KZLULJ3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]硕大的肉棒抵在\\n[1]菊穴上，恨不得立刻就插进去。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：啊~~~好哥哥快进去来吧~~~"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]一边被狠狠插着小穴，一边摇晃着屁股诱惑着身后的人。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]铁匠：骚货你怎么引诱我，我现在就插进去，让你好好感受我的大肉棒。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]铁匠狠狠的插入了\\n[1]菊穴，哪怕是菊穴也柔软的包裹着肉棒。"]},{"code":231,"indent":0,"parameters":[1,"47-KZLULJ4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：啊啊啊啊~~~菊穴也被插了~~~好棒~~~"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：嘤~~~快点~~~再快点~~~想要被狠狠的揉虐~~~"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]两人哪一些的娇喘的引诱的话语，更加卖力的抽插，恨不得将这两穴插坏。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]但被那肉壁紧紧包裹，那肉壁就吸得肉棒稍微出去就被狠狠吸进去，爱液润滑着，让人如痴如醉。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：啊啊啊啊~~~要去了~~~"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]铁匠：你这骚货，吸得这么紧，我也要狠狠的浇灌你。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]官二代：我也受不了，这骚货太棒了。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]两人带着\\n[1]一起冲上了巅峰。"]},{"code":231,"indent":0,"parameters":[1,"47-KZLULJ5",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]噗呲噗呲~~~"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]不管是小穴还是菊穴都被精液灌入，温热的精液让\\n[1]瞬间达到了高潮。"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]：啊啊啊啊~~~去了~~去了~~~好棒~~继续~~~继续疼爱奴家~~~"]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]接下来更多的在\\n[1]身上耕耘，很快，\\n[1]一脸高潮红晕的躺在小巷里，身体的愉悦让她快乐的失了神。"]},{"code":111,"indent":0,"parameters":[0,654,0]},{"code":122,"indent":1,"parameters":[4,4,1,0,5]},{"code":117,"indent":1,"parameters":[9]},{"code":121,"indent":1,"parameters":[325,325,1]},{"code":121,"indent":1,"parameters":[652,652,1]},{"code":117,"indent":1,"parameters":[22]},{"code":201,"indent":1,"parameters":[0,93,5,4,2,0]},{"code":211,"indent":1,"parameters":[1]},{"code":223,"indent":1,"parameters":[[0,0,0,0],60,false]},{"code":222,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]秦正经：仙子快乐吧~~想不想继续这样快乐，只要仙子答应，每晚到客栈等待我，我会带着仙子一起享受着极乐的欢愉。"]},{"code":102,"indent":1,"parameters":[["我愿意❤","不，我不想！！！"],-1,0,1,1]},{"code":402,"indent":1,"parameters":[0,"我愿意❤"]},{"code":122,"indent":2,"parameters":[4,4,1,0,5]},{"code":121,"indent":2,"parameters":[654,654,0]},{"code":117,"indent":2,"parameters":[9]},{"code":121,"indent":2,"parameters":[325,325,1]},{"code":121,"indent":2,"parameters":[652,652,1]},{"code":117,"indent":2,"parameters":[22]},{"code":117,"indent":2,"parameters