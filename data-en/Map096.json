ode": 111, "indent": 2, "parameters": [12, "$gameSystem._petActorList&&$gameSystem._petActorList.filter(actor=>actor&&actor.id==2).length>0"]}, {"code": 231, "indent": 3, "parameters": [1, "31-LH", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 3, "parameters": ["Rất tốt. Chúc mừng đã giúp đỡ dân làng. Nhưng… để đến nơi ngươi muốn đi, ngươi sẽ cần một linh sủng phi cầm hộ tống."]}, {"code": 101, "indent": 3, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 3, "parameters": ["Ồ! Ngươi thực sự có một Qingluan!"]}, {"code": 401, "indent": 3, "parameters": ["(Gợi ý: Hãy cho Qingluan \\C[2]triển khai chiến đấu\\C[0]  trước, sau đó nói chuyện lại.)"]}, {"code": 235, "indent": 3, "parameters": [1]}, {"code": 0, "indent": 3, "parameters": []}, {"code": 411, "indent": 2, "parameters": []}, {"code": 111, "indent": 3, "parameters": [12, "$gameSystem._petActorList&&$gameSystem._petActorList.filter(actor=>actor&&actor.id==3).length>0"]}, {"code": 231, "indent": 4, "parameters": [1, "31-LH", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 4, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 4, "parameters": ["Rất tốt. Chúc mừng đã giúp đỡ dân làng. Nhưng… để đến nơi ngươi muốn đi, ngươi sẽ cần một linh sủng phi cầm hộ tống."]}, {"code": 101, "indent": 4, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 4, "parameters": ["Ồ! Ngươi thực sự có một Qingluan!"]}, {"code": 401, "indent": 4, "parameters": ["(Gợi ý: Hãy cho Qingluan \\C[2]triển khai chiến đấu\\C[0]  trước, sau đó nói chuyện lại.)"]}, {"code": 235, "indent": 4, "parameters": [1]}, {"code": 0, "indent": 4, "parameters": []}, {"code": 411, "indent": 3, "parameters": []}, {"code": 111, "indent": 4, "parameters": [0, 982, 0]}, {"code": 231, "indent": 5, "parameters": [1, "31-LH", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 5, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 5, "parameters": ["Ngươi không nhớ sao？ Thì ta nói lại lần nữa. Ta nghe nói ở sào huyệt bọn cướp trên ngọn núi sau làng Lưu Ly trên đảo Lưu Ly, ở phía trên cùng bên phải, có một sợi dây buộc vào cây. Nó dẫn đến một hang động."]}, {"code": 101, "indent": 5, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 5, "parameters": ["Ta nghe nói ở sào huyệt bọn cướp trên ngọn núi sau làng Lưu Ly trên đảo Lưu Ly, ở phía trên cùng bên phải, có một sợi dây buộc vào cây. Nó dẫn đến một hang động."]}, {"code": 101, "indent": 5, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 5, "parameters": ["Bên trong hang động ấy… có một linh thú, một Qingluan."]}, {"code": 235, "indent": 5, "parameters": [1]}, {"code": 0, "indent": 5, "parameters": []}, {"code": 411, "indent": 4, "parameters": []}, {"code": 231, "indent": 5, "parameters": [1, "31-LH", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 5, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 5, "parameters": ["Rất tốt. Chúc mừng đã giúp đỡ dân làng. Nhưng… để đến nơi ngươi muốn đi, ngươi sẽ cần một linh sủng phi cầm hộ tống."]}, {"code": 101, "indent": 5, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 5, "parameters": ["Có vẻ ngươi chưa có linh sủng phi cầm nào. Ta nghe nói ở sào huyệt bọn cướp trên ngọn núi sau làng Lưu Ly trên đảo Lưu Ly, ở phía trên cùng bên phải, có một sợi dây buộc vào cây. Nó dẫn đến một hang động."]}, {"code": 101, "indent": 5, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 5, "parameters": ["Ở đó có một linh sủng tốt—một Qingluan. Nếu ngươi bắt được nó và triển khai nó trong chiến đấu, ta sẽ nói cho ngươi biết tung tích người đó."]}, {"code": 101, "indent": 5, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 5, "parameters": ["(Con Thanh Loan đó… không dễ thuần phục đâu.)"]}, {"code": 235, "indent": 5, "parameters": [1]}, {"code": 101, "indent": 5, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 5, "parameters": [""]}, {"code": 401, "indent": 5, "parameters": ["\\CT[1]Nhiệm vụ phụ được kích hoạt: \\C[5]Thanh Loan\\C[0]. Nhiệm vụ này đã được ghi lại trong Ngọc Giản Nhiệm Vụ ở phần Nhiệm Vụ Phụ. Xin hãy nhớ kiểm tra."]}, {"code": 250, "indent": 5, "parameters": [{"name": "Up1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 357, "indent": 5, "parameters": ["Cat_QuestCore", "addQuest", "添加主线/支线任务", {"type": "支线", "id": "53"}]}, {"code": 657, "indent": 5, "parameters": ["任务类型 = 支线"]}, {"code": 657, "indent": 5, "parameters": ["任务Id号 = 53"]}, {"code": 121, "indent": 5, "parameters": [982, 982, 0]}, {"code": 0, "indent": 5, "parameters": []}, {"code": 412, "indent": 4, "parameters": []}, {"code": 0, "indent": 4, "parameters": []}, {"code": 412, "indent": 3, "parameters": []}, {"code": 0, "indent": 3, "parameters": []}, {"code": 412, "indent": 2, "parameters": []}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 412, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}, {"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 385, "switch1Valid": true, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"tileId": 0, "characterName": "8", "direction": 2, "pattern": 1, "characterIndex": 0}, "list": [{"code": 231, "indent": 0, "parameters": [1, "31-LH", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 0, "parameters": ["Hãy nghỉ ngơi sớm, Tiên tử."]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}, {"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 389, "switch1Valid": true, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}, {"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 390, "switch1Valid": true, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"tileId": 0, "characterName": "NPC15", "direction": 2, "pattern": 1, "characterIndex": 3}, "list": [{"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 0, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Cảm ơn sự giúp đỡ của ngươi. Nhờ đó, ta cũng đã lấy lại được những gì thuộc về mình."]}, {"code": 213, "indent": 0, "parameters": [-1, 7, true]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 0, "parameters": ["<qp:0,600,>\\n[1]: Chúng ta đều có lợi cho nhau."]}, {"code": 213, "indent": 0, "parameters": [0, 6, true]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 0, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Loài người các ngươi thật dễ nổi giận. Này, đây là lời cảm tạ của ta. Thực lòng… cảm ơn ngươi."]}, {"code": 126, "indent": 0, "parameters": [796, 0, 0, 1]}, {"code": 126, "indent": 0, "parameters": [819, 0, 0, 1]}, {"code": 123, "indent": 0, "parameters": ["A", 0]}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}, {"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": true, "switch1Id": 390, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"tileId": 0, "characterName": "NPC15", "direction": 2, "pattern": 1, "characterIndex": 3}, "list": [{"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 0, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Làng Đào Hoa chào đón ngươi. Ngươi có thể đến bất cứ lúc nào."]}, {"code": 102, "indent": 0, "parameters": [["Tìm hiểu về quá khứ của Làng Đào Hoa.", "Tình hình hiện tại.", "Tạm biệt"], 2, 0, 1, 0]}, {"code": 402, "indent": 0, "parameters": [0, "Tìm hiểu về quá khứ của Làng Đào Hoa."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Làng Đào Hoa ban đầu được thành lập bởi một nhóm người chạy trốn. Họ trồng rất nhiều cây đào ở đây, cố gắng dùng cách sắp xếp của gỗ đào để đánh lạc hướng những kẻ truy đuổi."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Thời gian trôi qua, họ phát hiện không còn ai săn đuổi mình nữa. Vì thế, họ dần dần rời khỏi nơi này."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Những cây đào bị bỏ lại… qua thời gian, đã khai mở ý thức và linh tính. Chúng dần dần biến thành yêu quái… và cuối cùng mang hình dạng con người."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Sau đó, chúng đã thành lập Làng Đào Hoa ở vùng ven Rừng Đào Hoa."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Ngươi nghe không nhầm đâu. Nơi này thực ra là bên ngoài Rừng Đào Hoa. Bởi vì mọi người đều muốn bảo vệ tốt bản thể gốc của mình."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Nghe đồn rằng… sâu trong Rừng Đào Hoa, có một cây đào đẹp tuyệt mỹ. Nó tạo ra một quả đào. Nếu ăn vào, sẽ mang lại phần thưởng khó tin."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Mẹ ta từng nói… hình dạng con người của cây đào ấy vô cùng tuấn mỹ xinh đẹp. Và Rượu Đào Hoa nó ủ ra thực sự tuyệt hảo."]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [1, "Tình hình hiện tại."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Bây giờ, Làng Đào Hoa đã tốt hơn trước nhiều. Trước đây chúng ta có phần bài ngoại. Nhưng vì muốn sinh tồn tốt hơn, chúng ta sẽ không còn khép kín như trước nữa."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Và chúng ta cũng bắt đầu sản xuất một số đặc sản địa phương để bán. Thậm chí đã chế tác được vài món trang bị kha khá."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:4,600,>Chu Hiểu Hoa: Ta hi vọng… mọi thứ dần dần sẽ tốt đẹp hơn."]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [2, "Tạm biệt"]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 404, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}], "x": 7, "y": 12}, {"id": 5, "name": "EV005", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 117, "indent": 0, "parameters": [3]}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": false, "through": false, "trigger": 4, "walkAnime": true}], "x": 17, "y": 5}], "parallaxLoopX": false, "parallaxLoopY": false, "parallaxName": "", "parallaxShow": true, "parallaxSx": 0, "parallaxSy": 0}