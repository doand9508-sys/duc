": [1, "31-LH", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 1, "parameters": ["Tại sao ta phải nói cho ngươi biết？"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 1, "parameters": ["Vị đại nhân đó là ân nhân của chúng ta! Bảo chúng ta tùy tiện nói cho ngươi mà không có lý do… Tiên tử, xin hãy giữ lễ nghĩa một chút."]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[2]Vì ngươi biết ta là tu sĩ, ngươi cũng nên biết ta vẫn có chút thực lực chiến đấu. Ta chỉ đơn thuần tìm người này. Ta không muốn gây rắc rối. Hi vọng ngươi có thể hiểu điều đó."]}, {"code": 231, "indent": 1, "parameters": [1, "31-LH", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 1, "parameters": ["Ồ？ Nếu Tiên tử có thể chứng tỏ cho ta thấy chỉ số lớn hơn cả Vương Tư Mỗ… thì ta sẵn lòng nói cho ngươi."]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[11]Xin… hãy nói điều kiện của ngươi. Nếu ta làm được, điều đó chứng tỏ chỉ số của ta. Nếu không, ta cũng sẽ từ bỏ."]}, {"code": 231, "indent": 1, "parameters": [1, "31-LH", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 1, "parameters": ["Được. Hãy giải quyết khó khăn của năm dân làng nơi đây. Sau đó ta sẽ tin ngươi. Tình cờ ta cũng cần chuẩn bị. Nơi ngươi muốn đến… không hẳn an toàn."]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[6]Ý ngươi là sao？"]}, {"code": 231, "indent": 1, "parameters": [1, "31-LH", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Đào Kim Viên"]}, {"code": 401, "indent": 1, "parameters": ["Trước tiên… hãy thể hiện thành ý của ngươi. Giải quyết phiền muộn của năm dân làng. Rồi chúng ta sẽ nói chuyện khác. Nếu không… làm sao ta có thể tin ngươi？"]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[2](Nhìn thái độ của nàng… có vẻ như nàng đang giấu điều gì đó. Ta tưởng tượng sao？ Cứ tạm đồng ý đã.)"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[1]Được."]}, {"code": 117, "indent": 1, "parameters": [52]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\C[6]Nhiệm vụ chính\\C[0] đã hoàn thành. Phần thưởng đã được gửi!~~~"]}, {"code": 250, "indent": 1, "parameters": [{"name": "Up1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 126, "indent": 1, "parameters": [53, 0, 0, 100]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nội dung \\C[6]Nhiệm vụ chính\\C[0] mới đã được cập nhật. Vui lòng kiểm tra \\C[2]Ngọc Thư Nhiệm vụ\\C[0] kịp thời."]}, {"code": 250, "indent": 1, "parameters": [{"name": "Up1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 357, "indent": 1, "parameters": ["Cat_QuestCore", "removeQuest", "主线/支线任务完成", {"type": "主线", "id": "19"}]}, {"code": 657, "indent": 1, "parameters": ["任务类型 = 主线"]}, {"code": 657, "indent": 1, "parameters": ["任务Id号 = 19"]}, {"code": 357, "indent": 1, "parameters": ["Cat_QuestCore", "addQuest", "添加主线/支线任务", {"type": "主线", "id": "20"}]}, {"code": 657, "indent": 1, "parameters": ["任务类型 = 主线"]}, {"code": 657, "indent": 1, "parameters": ["任务Id号 = 20"]}, {"code": 121, "inden