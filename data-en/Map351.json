parameters": ["\\CT[1]\\n[1]Đôi mắt mơ màng, vô tiêu cự. Đôi môi đỏ hé mở. Giọng nói như chuông bạc ấy mang theo dục vọng không thể diễn tả, nghe thôi đã khiến lòng người ngứa ngáy."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]\\n[1]: Tiên Trần Hồng Trần… vẫn là Tiên. Cùng các ngươi chung hưởng khoái lạc… cũng là một lựa chọn tốt."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Mọi người càng đắm chìm hơn trong hiện tại. Không hận thù, không gánh nặng. Chỉ có niềm vui thuần khiết, không pha tạp."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Phấn đấu phi thăng là một kiểu sống. Sống vui vẻ nơi trần thế… cũng là một cách sống."]}, {"code": 221, "indent": 0, "parameters": []}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 355, "indent": 0, "parameters": ["DataManager.SaveVariables()"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]—KẾT THÚC— Hồng Trần Cực Lạc Tiên: Tiên Tử, Hãy Dẫn Ta Lên Mây"]}, {"code": 117, "indent": 0, "parameters": [756]}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": false, "through": false, "trigger": 3, "walkAnime": true}], "x": 10, "y": 2}], "parallaxLoopX": false, "parallaxLoopY": false, "parallaxName": "", "parallaxShow": true, "parallaxSx": 0, "parallaxSy": 0}