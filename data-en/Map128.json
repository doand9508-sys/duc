rameters": ["btg"]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 404, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 411, "indent": 0, "parameters": []}, {"code": 118, "indent": 1, "parameters": ["btg"]}, {"code": 357, "indent": 1, "parameters": ["TitleCg", "openLock", "解锁指定Cg", {"id": "6"}]}, {"code": 657, "indent": 1, "parameters": ["CgId = 6"]}, {"code": 243, "indent": 1, "parameters": []}, {"code": 241, "indent": 1, "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 1, "parameters": [2, "50-LLZBH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Chết tiệt! Ta quá bất cẩn. Bị kéo vào hang nó rồi. Làm sao đây？!"]}, {"code": 111, "indent": 1, "parameters": [0, 8, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: A… Mùi nam tính nồng đậm, dày đặc quá… Ưm, tuyệt quá… …"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Cơ thể đã sớm phát dục và từng trải, thay vì sợ hãi… lúc này lại run rẩy vì hưng phấn nhiều hơn. Chỉ nghĩ đến chuyện sắp xảy ra thôi, bụng dưới của \\n[1] đã tê dại một trận."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Hơi thở từ mũi con quái ly phả vào tai  \\n[1]. Sinh vật này, chẳng có chút nhân tính, nắm chặt eo thon của  \\n[1], sẵn sàng đâm vào."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Lúc nào không hay, huyệt của \\n[1] đã ướt đẫm rồi. Dịch thể trong suốt lấp lánh không ngừng chảy ra, dễ dàng bị Yêu Lực hút đến chỗ sâu nhất."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: A a~~~ Sâu hơn nữa! Nếu mà dày hơn một chút nữa… thì càng tốt."]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 411, "indent": 1, "parameters": []}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: A… cái này… dài quá mức… Nếu nó cứ thế mà vào, chắc chắn tôi… sẽ không chịu nổi…"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Không! Tôi phải trốn! Nếu không tôi sẽ chết!"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Hơi thở từ mũi con quái ly phả vào tai  \\n[1]. Sinh vật này, chẳng có chút nhân tính, nắm chặt eo thon của  \\n[1], sẵn sàng đâm vào."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Bộ lông dày của con thú, mang mùi hôi hoang dại, hăng hắc vì lâu ngày không tắm, khiến ý thức của  \\n[1] có phần tản mát."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Ngh… Tôi đang làm gì vậy… Tôi nên tìm cơ hội trốn thoát… Aaaahhh! Nó… nó vào rồi…"]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 250, "indent": 1, "parameters": [{"name": "2-NZQJCR", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 111, "indent": 1, "parameters": [0, 15, 0]}, {"code": 231, "indent": 2, "parameters": [2, "50-LLZBH2-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Con quái vật theo bản năng, đút dương vật của nó vào huyệt nhỏ yếu đuối của \\n[1]. Huyệt chưa từng trải qua chuyện này của \\n[1] căn bản không chịu nổi sự tấn công như vậy."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Màng trinh yếu ớt bị xé rách ngay lập tức. Một vệt đỏ tươi nở ra ở cửa huyệt. \\n[1] há miệng, suýt nữa thì nôn ra."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Ư ngh… quá căng… quá đầy…"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Cô chẳng cần nhìn cũng biết âm hộ mình đã bị kéo căng đến cực hạn, không thể chứa thêm gì nữa. Một cách đáng thương, nó mút và bú lấy cây gậy của con quái ly."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Ngay cả đường trong cô co thắt vì khô ráo, vậy mà nó cũng bắt đầu tiết ra một chút mật dịch như thể đã nếm được tủy."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]May mắn thay, với chất lỏng bôi trơn đó, sự tiến vào coi như suýt soát trơn tru.  \\n[1]  nín thở và cố gắng thư giãn, cuối cùng cũng làm cho dương vật của con quái ly, dày như cánh tay trẻ con, nằm tương đối ngoan ngoãn bên trong."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"c