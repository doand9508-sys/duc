 "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 221, "indent": 1, "parameters": []}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1] gật đầu đồng ý. Được những mỹ nhân thúc giục, nàng trút bỏ xiêm y và cùng họ bước vào hồ."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nhiệt độ nước vừa phải hoàn hảo. Làn nước sạch sẽ, tinh khiết nhẹ nhàng bao bọc từng cơ thể duyên dáng, quyến rũ. Một làn sương hồng nhạt lơ lửng trên bề mặt."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1] chỉ cảm thấy cơ thể mình dần nằm ngoài tầm kiểm soát. Những người phụ nữ tiến lại gần nàng, ánh mắt họ mập mờ và gợi tình."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Một người phụ nữ ép chặt lấy \\n[1], khiến nàng không thể trốn thoát. Một người khác vươn tay ra, nhắm chạm vào lồn nhỏ của \\n[1]."]}, {"code": 231, "indent": 1, "parameters": [1, "59-HHZZNMY1-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 222, "indent": 1, "parameters": []}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Các người… các người định làm gì？？？"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nữ A: Ngươi tưởng chỉ mặc bộ đồ đó là thành đệ tử của Hợp Hoan Tông chúng ta sao？"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nữ B: Aiya, Sư tỷ, đừng dọa tiểu muội muội chứ."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nữ A: Nếu thân thể ngươi không phải là một Lô Đỉnh cực tốt, thì chúng ta còn để ngươi vào làm gì？"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nữ C: Hì hì. Để chúng ta nếm thử xem Lô Đỉnh Thiên Linh Căn này mạnh đến mức nào, rồi sẽ cho ngươi qua."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Không! Buông ta ra!"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nữ C: Hì hì, chúng ta đông người như vậy. Ngươi đánh lại tất cả bọn ta sao？ Với lại, đây là Hợp Hoan Tông của chúng ta. Xung quanh còn rất nhiều Sư huynh khác nữa."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: ..."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]:(Phải làm sao đây… Vì… vì… Hàn Vũ…)"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Ngươi đã hứa… cuối cùng, sẽ cho ta qua mà."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nữ A: Đương nhiên rồi. Tiểu muội muội, cứ tận hưởng đi."]}, {"code": 231, "indent": 1, "par