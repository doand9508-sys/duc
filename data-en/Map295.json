, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}, {"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1214, "variableValid": true, "variableValue": 1}, "directionFix": false, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}], "x": 6, "y": 4}, {"id": 7, "name": "EV007", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 856, "switch1Valid": true, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": true, "image": {"tileId": 0, "characterName": "$2-BZ1", "direction": 6, "pattern": 1, "characterIndex": 0}, "list": [{"code": 117, "indent": 0, "parameters": [115]}, {"code": 111, "indent": 0, "parameters": [1, 240, 0, 1, 0]}, {"code": 102, "indent": 1, "parameters": [["Bỏ qua cốt truyện.", "Không bỏ qua."], -1, 0, 1, 0]}, {"code": 402, "indent": 1, "parameters": [0, "Bỏ qua cốt truyện."]}, {"code": 221, "indent": 2, "parameters": []}, {"code": 235, "indent": 2, "parameters": [1]}, {"code": 222, "indent": 2, "parameters": []}, {"code": 117, "indent": 2, "parameters": [116]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 402, "indent": 1, "parameters": [1, "Không bỏ qua."]}, {"code": 119, "indent": 2, "parameters": ["1"]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 404, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 411, "indent": 0, "parameters": []}, {"code": 118, "indent": 1, "parameters": ["1"]}, {"code": 111, "indent": 1, "parameters": [1, 1213, 0, 3, 1]}, {"code": 243, "indent": 2, "parameters": []}, {"code": 241, "indent": 2, "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 2, "parameters": [1, "81-ATMLSBXH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Một thân thể nữ nhân duyên dáng, tinh tế quỳ phủ phục sâu trong căn lều nhỏ tối tăm. Làn da khỏe mạnh của nàng không trở nên tái nhợt vì bị giam cầm lâu ngày. Vì lý do nào đó, nàng dường như còn trở nên đầy đặn hơn."]}, {"code": 231, "indent": 2, "parameters": [1, "81-ATMLSBXH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Lý Sảng: Lại đến nữa sao？ Ngài thực sự yêu thích thân thể này của tôi đến vậy, phải không… Tất cả bọn người từ Lăng Tiêu Cung…"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Những lời chua chát sắc bén bị cắt ngang bởi một cú thúc đặc biệt mạnh mẽ, đầy lực."]}, {"code": 231, "indent": 2, "parameters": [1, "81-ATMLSBXH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 2, "parameters": [{"name": "3-PTSNCR", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Lý Sảng: A… tss… n-ngươi… ngươi… hãy nhẹ nhàng hơn!"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Đỗ Vân: Hừ!"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Câu trả lời duy nhất nàng nhận được là một tiếng hừ lạnh khác, và những âm thanh da thịt va chạm."]}, {"code": 250, "indent": 2, "parameters": [{"name": "4-DLPYH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]*Bạch bạch bạch bạch bạch bạch bạch*"]}, {"code": 231, "indent": 2, "parameters": [1, "81-ATMLSBXH4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Lý Sảng: Ngh… ôi a! Ôi a! Chậm lại! A! Nhanh quá! Nó sắp tràn ra ngoài… a~"]}, {"code": 231, "indent": 2, "parameters": [1, "81-ATMLSBXH5", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Những cú thúc nhanh và tàn nhẫn khiến lông mày nàng nhíu chặt. Tuy nhiên, những dòng ái dịch được kéo thành sợi óng ánh bởi sự thúc rút của dương vật đã hoàn toàn phản bội nàng."]}, {"code": 251, "indent": 2, "parameters": []}, {"code": 250, "indent": 2, "parameters": [{"name": "4-DLPYH3", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Lý Sảng: K-Không… không… ngay đó! Một chút nữa… nhanh hơn! Nn a! A! Đừng dừng lại!!!"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Vòng eo và hông đầy đặn, gợi cảm của nàng bắt đầu tự động lắc lư qua lại, háo hức đón nhận mỗi lần thúc vào rút ra của dương vật, chỉ để cho nó vào sâu hơn nữa. Ngay cả khi cây gậy phía sau đã ngừng chuyển động, con đàn bà dâm đãng này vẫn tiếp tục chủ động đưa đẩy thân mình lên nó."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Lý Sảng: Ha a! Sao… tuyệt vậy… Một ha! Nóng quá! Nó ở bên trong! Ta không chịu nổi nữa… Ta… ta sắp… Nngh ngh ngh a!!!"]}, {"code": 231, "indent": 2, "parameters": [1, "81-ATMLSBXH6", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 251, "indent": 2, "parameters": []}, {"code": 250, "indent": 2, "parameters": [{"name": "Poison", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Trong cơn cực khoái, âm hộ của nàng co thắt nhanh chóng và bóp chặt, kéo sâu cây gậy đang phun trào vào bên trong. Một chất lỏng đặc, trắng, đục được đổ vào âm hộ nàng, rồi trượt ra ngoài dọc theo thân cây gậy."]}, {"code": 231, "indent": 2, "parameters": [1, "81-ATMLSBXH7", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Lý Sảng: Ha…. Ha…. Ha…. A…"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Trong dư âm kéo dài của cực khoái, thân thể nàng phản ứng nhanh hơn cả não bộ. Với những cơn co giật nhẹ nhàng, tinh tế, nàng lại cong mông lên, lắc lư qua lại, phát ra một lời mời khác."]}, {"code": 231, "indent": 2, "parameters": [1, "81-ATMLSBXH10", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 2, "parameters": [{"name": "4-DLPYH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Nhóp nhép."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Lý Sảng: Ngh~ A~"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Cây gậy lại được đút vào một lần nữa, gợi ra một tiếng rên rỉ mãn nguyện sâu sắc. Đêm nay… còn dài."]}, {"code": 221, "indent": 2, "parameters": []}, {"code": 235, "indent": 2, "parameters": [1]}, {"code": 122, "indent": 2, "parameters": [4, 4, 1, 0, 5]}, {"code": 122, "indent": 2, "parameters": [1214, 1214, 0, 0, 1]}, {"code": 222, "indent": 2, "parameters": []}, {"code": 244, "indent": 2, "parameters": []}, {"code": 117, "indent": 2, "parameters": [116]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 411, "indent": 1, "parameters": []}, {"code": 111, "indent": 2, "parameters": [1, 1213, 0, 2, 1]}, {"code": 243, "indent": 3, "parameters": []}, {"code": 241, "indent": 3, "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Một thân thể nữ nhân duyên dáng, tinh tế quỳ phủ phục sâu trong căn lều nhỏ tối tăm. Hai tay nàng bị trói chặt. Chỉ có cặp mông căng tròn nhướng lên là có thể vặn vẹo trái phải."]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: Đỗ Vân… tôi cầu xin ngài… thả tôi đi. Tôi sẽ không chống đối ngài nữa."]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Im lặng, không một lời. Chỉ có âm thanh quần áo được nới lỏng. Cảm nhận được cây cột cứng rắn, nóng bỏng áp vào từ phía sau, cặp mông đầy đặn của nàng trước tiên run rẩy, rồi bắt đầu vặn vẹo và đưa đẩy điên cuồng hơn, muốn tránh cuộc xâm lược sắp xảy ra."]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: KHÔNG!! KHÔNG!! Tôi không phải nữ nhân! Đừng chạm vào tôi! Ngài điếc à？! Cút đi! CÚT ĐI!!!"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Giữa những tiếng la hét và chửi rủa, cây gậy đâm thẳng vào trong, không bị cản trở, dễ dàng đến những nơi sâu nhất. Âm thanh da thịt va chạm ngay lập tức cắt ngang những lời thừa thãi của nàng thành hai. Rồi đến cú thúc thứ hai. Thứ ba."]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 3, "parameters": [{"name": "3-PTSNCR", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]*Bạch bạch bạch bạch bạch bạch bạch*"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: A!!!! Ngh…. Đừng vào sâu như vậy! Rút nó ra! Aaaahhh! NHẸ NHÀNG ĐI!!!"]}, {"code": 250, "indent": 3, "parameters": [{"name": "4-DLPYH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Không có kỹ thuật hào nhoáng nào. Mỗi một cú thúc đều là một cú đập mạnh mẽ, nặng nề vào phần sâu nhất của âm hộ nàng, khuấy động những dòng ái dịch trơn tru, dâm đãng, lặp đi lặp lại."]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: A… Aaah… Aaah… Ha… Tss… Ngh… Hmm ngh… A! Không! Không phải ở đó! Nhẹ-… A! Không phải như vậy! Ô! Ha a! Không! Không… Aaaaahhh!"]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH5", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 251, "indent": 3, "parameters": []}, {"code": 250, "indent": 3, "parameters": [{"name": "4-DLPYH3", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Cặp mông căng tròn của nàng, cùng với hai bầu ngực cho lớn trên ngực, bắt đầu rung lắc và nảy lên theo mỗi cú thúc. Khi dòng nước nóng bỏng phun sâu vào chiếc lọ mật của nàng, thịt âm hộ sáng sủa, sống động của nàng cũng co thắt không kiểm soát."]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH6", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 3, "parameters": [{"name": "Poison", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: Hoo hoo… ngh… Không thêm nữa… xin… Tôi không chịu nổi nữa… Tôi không muốn điều này nữa… Thả tôi đi…"]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH7", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Những lời cầu xin thương xót đều vô ích. Chỉ có một cú thúc tàn nhẫn, không ngừng nghỉ khác theo sau."]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH10", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 3, "parameters": [{"name": "4-DLPYH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]*Bạch bạch bạch bạch bạch bạch bạch*"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: Hoo Ô Ô Ô Ô A!!"]}, {"code": 221, "indent": 3, "parameters": []}, {"code": 235, "indent": 3, "parameters": [1]}, {"code": 122, "indent": 3, "parameters": [4, 4, 1, 0, 5]}, {"code": 122, "indent": 3, "parameters": [1214, 1214, 0, 0, 1]}, {"code": 222, "indent": 3, "parameters": []}, {"code": 244, "indent": 3, "parameters": []}, {"code": 117, "indent": 3, "parameters": [116]}, {"code": 0, "indent": 3, "parameters": []}, {"code": 411, "indent": 2, "parameters": []}, {"code": 243, "indent": 3, "parameters": []}, {"code": 357, "indent": 3, "parameters": ["TitleCg", "openLock", "解锁指定Cg", {"id": "151"}]}, {"code": 657, "indent": 3, "parameters": ["CgId = 151"]}, {"code": 241, "indent": 3, "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: Đỗ Vân! Rốt cuộc ngươi muốn gì？! Đồ chó điên! Bỏ ta ra ngay! Ngạo Thiên Tông sẽ không tha cho ngươi đâu!"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Trần truồng và bị trói tay, Lý Sảng vẫn vùng vẫy, muốn đứng dậy."]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Đỗ Vân: Trước đây, ỷ vào địa vị của ông cố ngươi, ngươi đã cưỡng đoạt vợ con người ta. Vô số kẻ muốn ngươi chết. Giờ đây, ngươi chẳng là gì ngoài gánh nặng. Ai sẽ đến cứu ngươi？"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Đỗ Vân cởi bỏ quần áo. Cây gậy giữa hai chân hắn đã sớm dựng đứng hung mãnh. Hắn tiến đến gần cặp mông mập mạp đang vặn vẹo. Cây gậy cứng rắn của hắn lướt qua nơi mật ngọt của y, khiến y nổi cả da gà."]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: Đồ khốn kiếp! Đỗ Vân, ngươi điên thật rồi sao？! Ta là đàn ông! Nếu có gan thì cứ giết ta đi! Ta đã chơi biết bao nhiêu đàn bà, ta sớm đã chán rồi… A a!"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Đỗ Vân: Câm miệng!"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Cây gậy cứng rắn, mang theo cảm giác nóng rực, đâm thẳng vào sâu trong âm hộ hắn, hung bạo cắt ngang lời chửi rủa của Lý Sảng."]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 3, "parameters": [{"name": "3-PTSNCR", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: A a!"]}, {"code": 250, "indent": 3, "parameters": [{"name": "3-PTSNH1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]*Bạch bạch bạch bạch bạch bạch bạch*"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Tiếng da thịt va chạm vang vọng cùng với tiếng hét. Sự kích thích của nơi mật ngọt chật hẹp bị cưỡng ép banh ra hết lần này đến lần khác suýt khiến Lý Sảng rơi nước mắt."]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: Ư… Đỗ… Đỗ Vân… Đỗ huynh… Làm ơn, dừng lại đi… Tha cho ta… Con Vũ Vũ Vũ Du Du đó xưa nay vốn là đồ đàn bà rẻ tiền. Cho dù ta có không làm những chuyện đó, nó vẫn sẽ… A a!"]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH5", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 251, "indent": 3, "parameters": []}, {"code": 250, "indent": 3, "parameters": [{"name": "3-PTSNH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]*Bạch bạch bạch bạch bạch bạch bạch*"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Phản ứng duy nhất chỉ là cú thúc càng nhanh, càng dữ dội hơn. Cây gậy khổng lồ đâm mở cặp mông mập mạp, đen đúa của y rồi lại rút ra, kéo theo cả phần thịt non hồng hào bên trong. Tiếng nước dâm dục bắt đầu vang vọng."]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Khoái cảm dần xuất hiện từ nỗi đau. Lý Sảng nhắm mắt lại, muốn chạy trốn. Nhưng những tiếng rên rỉ quyến rũ từ chính miệng mình và sợi chỉ bạc dãi chảy dài nơi khóe môi thì không thể che giấu."]}, {"code": 251, "indent": 3, "parameters": []}, {"code": 250, "indent": 3, "parameters": [{"name": "4-DLPYH3", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: Ư ư… A a… Nhẹ… nhẹ hơn thôi… Không… Ta không chịu nổi nữa… A a!!"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]*Bạch bạch bạch bạch bạch bạch bạch*"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Những cú thúc còn mãnh liệt hơn nữa chạm đến nơi sâu nhất của âm huyệt. Một dòng dâm thủy hòa lẫn tinh dịch đặc sệt phun trào ra. Du Vân rút dương vật ra. Âm huyệt bị tàn phá hoàn toàn cùng với hậu huyệt non hồng đỏ mọng, theo nhịp thở dốc của hắn mà đóng mở liên hồi, rỉ ra thêm nhiều thứ dịch trắng đục nữa."]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH6", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 251, "indent": 3, "parameters": []}, {"code": 250, "indent": 3, "parameters": [{"name": "Poison", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Lý Sảng: Em xin… xin anh… tha cho em đi… Không… Aaaaahhh!"]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH7", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 3, "parameters": [30]}, {"code": 231, "indent": 3, "parameters": [1, "81-ATMLSBXH10", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 251, "indent": 3, "parameters": []}, {"code": 250, "indent": 3, "parameters": [{"name": "4-DLPYH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]*Bạch bạch bạch bạch bạch bạch bạch*"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 3, "parameters": [""]}, {"code": 401, "indent": 3, "parameters": ["\\CT[1]Dương vật lại hùng dũng lấp đầy âm huyệt đang run rẩy. Sự kích thích của việc bị kéo căng và khoái cảm tràn đầy lại một lần nữa tấn công anh. Nhưng lần này, anh không còn chút sức lực nào để chống cự hay giãy giụa. Những tiếng rên rỉ nghẹn ngào, chịu đựng lại một lần nữa lan tỏa khắp căn phòng."]}, {"code": 221, "indent": 3, "parameters": []}, {"code": 235, "indent": 3, "parameters": [1]}, {"code": 122, "indent": 3, "parameters": [4, 4, 1, 0, 5]}, {"code": 122, "indent": 3, "parameters": [1214, 1214, 0, 0, 1]}, {"code": 222, "indent": 3, "parameters": []}, {"code": 244, "indent": 3, "parameters": []}, {"code": 122, "indent": 3, "parameters": [240, 240, 0, 0, 1]}, {"code": 117, "indent": 3, "parameters": [116]}, {"code": 0, "indent": 3, "parameters": []}, {"code": 412, "indent": 2, "parameters": []}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 412, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": true, "through": false, "trigger": 1, "walkAnime": true}, {"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch