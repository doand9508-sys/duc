, "indent": 0, "parameters": [-1, 8, true]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[3]Sư phụ… con không thể nào quên được."]}, {"code": 231, "indent": 0, "parameters": [1, "8-LH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Hoàng Ngọc Lưu"]}, {"code": 401, "indent": 0, "parameters": ["Sư phụ hiểu mà. Chuyện năm xưa, con không thể trách bản thân mình mãi. Nhất thời sơ sẩy… Nguyệt nhi, con cần phải buông bỏ."]}, {"code": 117, "indent": 0, "parameters": [22]}, {"code": 213, "indent": 0, "parameters": [-1, 8, true]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[3]Sư phụ… con…"]}, {"code": 231, "indent": 0, "parameters": [1, "8-LH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Hoàng Ngọc Lưu"]}, {"code": 401, "indent": 0, "parameters": ["… Haiz. Xem ra, Nguyệt nhi, con vẫn chưa thể buông bỏ được."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Hoàng Ngọc Lưu"]}, {"code": 401, "indent": 0, "parameters": ["Người tu luyện, nếu tâm thần không thông suốt, ắt sẽ bế tắc. Nguyệt nhi, con cần một cơ duyên để gác lại tất cả những chuyện này."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[6]Sư phụ, con phải buông bỏ như thế nào đây？"]}, {"code": 231, "indent": 0, "parameters": [1, "8-LH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Hoàng Ngọc Lưu"]}, {"code": 401, "indent": 0, "parameters": ["Xuống núi đi. Đến thành Phiêu Vân lịch luyện trước đã. Khi nào đủ thực lực, tiêu diệt hết những kẻ năm xưa, tâm cảnh của con tự nhiên sẽ sáng tỏ."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[2]Thành Phiêu Vân… …"]}, {"code": 231, "indent": 0, "parameters": [1, "8-LH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Hoàng Ngọc Lưu"]}, {"code": 401, "indent": 0, "parameters": ["Ừ. Đó là nơi lui tới của những tu sĩ cấp thấp. Ở đó có một thí luyện bí cảnh rất thích hợp với con. Vả lại, đại sư huynh của con cũng sẽ đi. Có nó ở đó, vi sư cũng yên tâm."]}, {"code": 117, "indent": 0, "parameters": [22]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[2]Đệ tử đã hiểu!"]}, {"code": 231, "indent": 0, "parameters": [1, "8-LH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Hoàng Ngọc Lưu"]}, {"code": 401, "indent": 0, "parameters": ["Bao nhiêu năm nay, đây là lần đầu tiên con xuống núi, Nguyệt nhi à. Cầm lấy những thứ này của vi sư. Chúng đều sẽ hữu ích cho con."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[7]Đa tạ sư phụ! Đệ tử xin xuất phát ngay đây!"]}, {"code": 117, "indent": 0, "parameters": [22]}, {"code": 117, "indent": 0, "parameters": [10]}, {"code": 117, "indent": 0, "parameters": [23]}, {"code": 122, "indent": 0, "parameters": [12, 12, 0, 0, 0]}, {"code": 357, "indent": 0, "parameters": ["FlyCat_LL_MapPicture", "hideMapCg", "隐藏/打开地图立绘", {"type": "false"}]}, {"code": 657, "indent": 0, "parameters": ["开启/关闭 = false"]}, {"code": 201, "indent": 0, "parameters": [0, 10, 24, 25, 8, 0]}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": false, "through": false, "trigger": 3, "walkAnime": true}], "x": 9, "y": 14}], "parallaxLoopX": false, "parallaxLoopY": false, "parallaxName": "", "parallaxShow": true, "parallaxSx": 0, "parallaxSy": 0}