se, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 235, "indent": 0, "parameters": [1]}, {"code": 122, "indent": 0, "parameters": [40, 40, 0, 0, 3]}, {"code": 211, "indent": 0, "parameters": [0]}, {"code": 117, "indent": 0, "parameters": [115]}, {"code": 111, "indent": 0, "parameters": [1, 135, 0, 1, 0]}, {"code": 102, "indent": 1, "parameters": [["Bỏ qua cốt truyện.", "Không bỏ qua."], 1, 0, 1, 0]}, {"code": 402, "indent": 1, "parameters": [0, "Bỏ qua cốt truyện."]}, {"code": 231, "indent": 2, "parameters": [1, "HS", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 2, "parameters": [{"name": "2-NZQJGC", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 111, "indent": 2, "parameters": [0, 15, 0]}, {"code": 121, "indent": 3, "parameters": [15, 15, 1]}, {"code": 357, "indent": 3, "parameters": ["FlyCat_LL_SceneMenu", "setTearPeople", "设置破处者", {"name": "Hổ Kình", "variablesId": ""}]}, {"code": 657, "indent": 3, "parameters": ["破处者姓名 = Hổ Kình"]}, {"code": 657, "indent": 3, "parameters": ["指定回传破处者姓名的变量 = "]}, {"code": 0, "indent": 3, "parameters": []}, {"code": 412, "indent": 2, "parameters": []}, {"code": 230, "indent": 2, "parameters": [60]}, {"code": 251, "indent": 2, "parameters": []}, {"code": 122, "indent": 2, "parameters": [18, 18, 1, 0, 1]}, {"code": 122, "indent": 2, "parameters": [4, 4, 1, 0, 5]}, {"code": 122, "indent": 2, "parameters": [24, 24, 1, 0, 5]}, {"code": 122, "indent": 2, "parameters": [32, 32, 1, 0, 1]}, {"code": 122, "indent": 2, "parameters": [34, 34, 1, 0, 1]}, {"code": 117, "indent": 2, "parameters": [17]}, {"code": 117, "indent": 2, "parameters": [18]}, {"code": 235, "indent": 2, "parameters": [1]}, {"code": 117, "indent": 2, "parameters": [341]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 402, "indent": 1, "parameters": [1, "Không bỏ qua."]}, {"code": 119, "indent": 2, "parameters": ["btg"]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 404, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 411, "indent": 0, "parameters": []}, {"code": 118, "indent": 1, "parameters": ["btg"]}, {"code": 357, "indent": 1, "parameters": ["TitleCg", "openLock", "解锁指定Cg", {"id": "8"}]}, {"code": 657, "indent": 1, "parameters": ["CgId = 8"]}, {"code": 243, "indent": 1, "parameters": []}, {"code": 241, "indent": 1, "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 1, "parameters": [2, "50-HJH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: …Ướt quá."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hổ Kình dưới nước dường như cực kỳ quyến luyến  \\n[1], toàn bộ cơ thể gần như quấn chặt lấy nàng. Cảm giác trơn trượt khiến  \\n[1]  rùng mình."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Nn… Không cử động được… Bất tiện quá."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hổ Kình cọ cọ vào khóe miệng  \\n[1] một cách âu yếm. Nhưng hung khí ở nửa dưới cơ thể nó cũng dần dần ngóc đầu lên."]}, {"code": 231, "indent": 1, "parameters": [2, "50-HJH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Cơ quan thú tính trong huyệt huyệt của nó thò ra, ép vào bụng dưới của  \\n[1]. Thứ ướt át nóng bỏng đó còn có cả gai thịt."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Vảy của sinh vật cọ xát vào mặt trong đùi nàng, có thể để lại vết hằn đỏ trên làn da mỏng manh yếu ớt đó."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Mau kết thúc đi. Tư thế này quá gò bó. Cứ như ta là con mồi vậy…"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Cơ thể Hổ Kình lại trượt thêm vài lần trên người nàng, rồi đột nhiên rụt lại."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nàng cảm thấy chỗ xương cụt, nơi vừa bị cọ xát, giờ trống rỗng. Đang lúc cảm thấy hơi hụt hẫng…"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Không ngờ, cơ quan đó của Hổ Kình ngay lập tức ép lên đỉnh đáy chậu của nàng và đâm vào không chút thương lượng."]}, {"code": 250, "indent": 1, "parameters": [{"name": "2-NZQJCR", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 111, "indent": 1, "parameters": [0, 15, 0]}, {"code": 231, "indent": 2, "parameters": [2, "50-HJH3-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Ngh!"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1] mím chặt môi. Tiểu huyệt của nàng co thắt khó chịu, nhưng vẫn cố gắng đón nhận sự xâm nhập của Hổ Kình."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Màng trinh của cô ấy dễ dàng bị xuyên thủng. Một chút máu chảy ra. Trong cơn đau đớn xen lẫn một khoái cảm vi diệu, kỳ lạ của việc bị cướp đoạt, khiến người ta không biết tự lúc nào chìm vào mê đắm."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Để ta nghỉ… Để ta nghỉ một chút thôi."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Con Hổ Kình đó dường như hiểu được nỗi đau của  \\n[1] và tự dừng lại, vẫn nhẹ nhàng chạm vào má  \\n[1]."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Một sinh vật hiểu lòng người… Hừ."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Đ-được rồi… giờ ổn rồi…"]}, {"code": 231, "indent": 2, "parameters": [2, "50-HJH4-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 411, "indent": 1, "parameters": []}, {"code": 231, "indent": 2, "parameters": [2, "50-HJH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 2, "parameters": [{"name": "2-NZQJH1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Ngh!"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1] mím chặt môi. Tiểu huyệt của nàng co thắt khó chịu, nhưng vẫn cố gắng đón nhận sự xâm nhập của Hổ Kình."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Những chiếc gai cọ xát vào cửa mình non nớt của nàng. Một khoái cảm tinh tế, kỳ diệu hòa lẫn với đau đớn bị cướp đoạt, khiến người ta vô thức chìm vào mê man."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Để ta nghỉ… Để ta nghỉ một chút thôi."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Con Hổ Kình đó dường như hiểu được nỗi đau của  \\n[1] và tự dừng lại, vẫn nhẹ nhàng chạm vào má  \\n[1]."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Một sinh vật hiểu lòng người… Hừ."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Đ-được rồi… giờ ổn rồi…"]}, {"code": 231, "indent": 2, "parameters": [2, "50-HJH4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 250, "indent": 1, "parameters": [{"name": "2-NZQJH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nghe thấy vậy, Hổ Kình không còn kiềm chế nữa, và bắt đầu chậm rãi di chuyển. Ngay sau đó, nó càng lúc càng nhanh, khiến  \\n[1]  nhẹ nhàng lắc lư theo chuyển động của nó."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Một ngh! Di chuyển nhanh quá! Vẫn… vẫn chưa đủ…"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Nhanh hơn! Nhanh hơn…!"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1] không thỏa mãn, hất hông về phía sau để đón nhận sự xâm chiếm của quái vật. Những tiếng rên rỉ mềm mại, hổn hển của nàng ngay lập tức kích thích Hổ Kình hơn nữa. Lực đâm của nó càng mạnh hơn."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Dù sao thì cũng là quái vật. Khi động dục, nó không còn quan tâm đến cảm xúc của người bên dưới nữa, chỉ siết chặt vòng ôm và đâm thật lực. Giữa những đợt tấn công dồn dập,  \\n[1]  phát ra những tiếng rên rỉ nhỏ nhẹ, đứt quãng."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Nn! Nn hah! Ra mất! Ra mất, ra mất!"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Oh! Oh oh oh! Ta đi…"]}, {"code": 250, "indent": 1, "parameters": [{"name": "2-NZQJGC", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 111, "indent": 1, "parameters": [0, 15, 0]}, {"code": 231, "indent": 2, "parameters": [2, "50-HJH5-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 411, "indent": 1, "parameters": []}, {"code": 231, "indent": 2, "parameters": [2, "50-HJH5", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {