de": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Trong một căn phòng tràn ngập mây mù, một mỹ nữ trưởng thành tuyệt đẹp quỳ trên sàn, mút thanh thịt khổng lồ trước mặt."]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông: Quả thật xứng đáng là đệ nhất danh kỹ nơi này. Gương mặt đẹp như vậy."]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người phụ nữ trưởng thành không hề lay động. Đôi mắt vô hồn, mất tập trung nhìn chằm chằm vào con cặc, tham lam nuốt chửng nó bằng miệng."]}, {"code": 250, "indent": 0, "parameters": [{"name": "4-DLPYKJ", "volume": 100, "pitch": 100, "pan": 100}]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Chiếc lưỡi nhỏ xinh cuộn quanh thanh nóng rực trong miệng, mút ra vào như thể đang thưởng thức món cao lương mỹ vị."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông không nhịn được mà chế giễu cô."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông: Ta nghe nói đệ nhất danh kỹ nơi đây từng là Hoàng hậu của một vương quốc. Ngươi có biết gì về chuyện đó không？"]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Cơ thể người phụ nữ trưởng thành đột nhiên run lên một chút, rồi lập tức trở lại bình thường, như chưa từng có chuyện gì xảy ra. Cô tiếp tục mút cặc của người đàn ông, dường như nó co giật nhẹ, ngày càng nóng hơn."]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ5", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông: Đồ đĩ điếm, sợ thừa nhận sao？ Dù gì ngươi cũng từng là Hoàng hậu."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông: Ai mà ngờ Hoàng hậu của một vương quốc lại có thể rơi vào chốn thế này？"]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [60]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ5", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [60]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Dù bị sỉ nhục trắng trợn như vậy, người phụ nữ trưởng thành vẫn không hề hay biết. Đôi mắt đẹp quyến rũ của cô ấy hơi tối lại khi cô khẽ thút thít."]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Mỹ nữ trưởng thành: Ư… a… hãy cho em… hạt giống của anh…"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông: Hừ… đồ đĩ!"]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [60]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ5", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [60]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXRJ4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 251, "indent": 0, "parameters": []}, {"code": 250, "indent": 0, "parameters": [{"name": "Poison", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Vừa nói, người đàn ông đưa tay ấn xuống gáy cô, tăng tốc đẩy vào miệng cô. Mặt người phụ nữ trưởng thành đỏ bừng khi cô mút một cách điên cuồng."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Chỉ có cô biết rằng nước dâm của mình đã thấm ướt quần áo phía dưới. Chỉ cần một cái nhập vào là cô sẽ lên đỉnh."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Tinh trùng quen thuộc phun ra vào miệng cô. Người phụ nữ trưởng thành nuốt theo thói quen. Hạt giống đặc sệt dính chặt cổ họng, nhưng cô lại thưởng thức nó vô cùng."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Chỉ khi con cặc rút ra khỏi miệng, cô mới miễn cưỡng lau khóe môi bằng ngón tay, nơi có chút tinh dịch tràn ra, rồi mút sạch sẽ."]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông cười khẩy với cô. Người phụ nữ trưởng thành lắc eo khi đứng dậy. Chiếc áo khoác ngoài bằng lụa trượt xuống, để lộ bộ ngực căng đầy. Khoảng trống giữa hai chân từ lâu đã ngập nước."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông: Đồ đĩ, thật dâm đãng. Ngươi không thể nhịn được nữa phải không？ Cứ nhìn xem ngươi ướt đến mức nào kìa."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Nói rồi, người đàn ông đưa tay chạm vào lồn cô. Khoảnh khắc những ngón tay anh luồn vào, cái lỗ chật cứng đó đột nhiên siết chặt. Sau đó, người phụ nữ trưởng thành ôm chặt lấy người đàn ông, kêu lên như đang khóc, và lên đỉnh như một đài phun nước tuôn trào."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông: Đồ đĩ, ngươi… …"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Ngay khi người đàn ông chuẩn bị bực tức, người phụ nữ trưởng thành đã quấn chặt lấy anh. Thân hình tuyệt mỹ của cô cọ xát vào anh, khiến cặc anh cương cứng trở lại."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Mỹ nữ trưởng thành: Cho em! Cặc của anh, cặc của anh! Aaaaa~~~~ Nhanh lên, đụ em!"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Giọng nói ngọt ngào của cô mang một sức quyến rũ riêng của phụ nữ. Dù anh có chút khó chịu với sự bộc phát trước đó của cô, nhưng với sự quấn quýt thế này, ngay cả hòa thượng cũng bị cám dỗ."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông cười, vỗ bốp vào cặp mông tròn căng của người phụ nữ trưởng thành, rồi bế cô lên giường… …"]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXZC1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người phụ nữ trưởng thành nằm trên giường, hai chân dang rộng, lồn lộ hẳn ra ngoài. Con cặc cứng ngắc đã sẵn sàng và ở tư thế chuẩn bị."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Mỹ nữ trưởng thành: Anh sẽ cho em cặc của anh chứ~~ Em thích nhất là được đụ ❤"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người phụ nữ trưởng thành dưới thân anh toát ra sức quyến rũ vô tận. Làn da cô được chăm sóc kỹ lưỡng đến mức chỉ cần thở nhẹ cũng có thể vỡ ra. Ánh mắt quyến rũ của cô nhằm mê hoặc anh."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông: Đồ đĩ! Một con đĩ bị vạn người đè! Hôm nay hãy xem ta phá nát ngươi thế nào! Ta sẽ khiến ngươi quỳ gối cầu xin ta dừng lại!"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Nói xong, anh đâm cặc vào lồn cô. Biểu cảm của người phụ nữ lập tức trở nên mặt trờig sướng."]}, {"code": 250, "indent": 0, "parameters": [{"name": "2-SFCR", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXZC2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [60]}, {"code": 250, "indent": 0, "parameters": [{"name": "2-SFSSH1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXZC3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [60]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZXZC2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 0, "parameters": [{"name": "4-DLPYH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Khi con cặc ra vào, người phụ nữ trưởng thành rên rỉ mặt trờig sướng dưới thân anh. Vẻ mặt dâm ô của cô cho thấy cô chỉ là một con điếm thuần túy. Dáng vẻ của quá khứ đâu rồi？"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Người đàn ông: Ngươi đúng là một con đỉ xịn. Cơ thể này của ngươi đã ngủ với bao nhiêu gã đàn ông rồi？ Vừa mềm mại, lại vừa chặt chẽ nữa! Ngươi là một con đĩ bẩm sinh."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Mỹ nữ trưởng thành: A!~~ Tiện thiếp muốn lên đỉnh! Tiện thiếp muốn cặc của anh~~ A~~~"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Cô không trả lời trực tiếp. Chỉ có ánh mắt mượt mà như lụa của cô và những lời nói nhẹ nhàng khiến người đàn ông càng cứng hơn, đẩy nhanh tốc độ. Chẳng bao lâu, căn phòng đầy những âm thanh dâm đãng đến mê mẩn tâm trí."]}, {"code": 250, "indent": 0, "parameters": [{"name": "2-SFSSH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 0, "parameters": [1, "2-ZX