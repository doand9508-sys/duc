leId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}], "x": 13, "y": 8}, {"id": 3, "name": "Mặc Hiên", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"tileId": 0, "characterName": "NPC2", "direction": 8, "pattern": 1, "characterIndex": 0}, "list": [{"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}], "x": 12, "y": 11}, {"id": 4, "name": "EV004", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 117, "indent": 0, "parameters": [115]}, {"code": 222, "indent": 0, "parameters": []}, {"code": 231, "indent": 0, "parameters": [1, "15-LH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Mặc Hiên"]}, {"code": 401, "indent": 0, "parameters": ["Nơi này tràn ngập linh khí dày đặc và những linh hồn vất vưởng. Ngươi có ý định sử dụng chúng… kết hợp với sức mạnh của thân phận khác… để hồi sinh \\n[1]."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Mặc Hiên"]}, {"code": 401, "indent": 0, "parameters": ["Ngươi có điên không？! Hồi sinh phải trả giá đắt! Không phải ai cũng có thể trả được!"]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 205, "indent": 0, "parameters": [2, {"list": [{"code": 16, "indent": null}, {"code": 0}], "repeat": false, "skippable": false, "wait": true}]}, {"code": 505, "indent": 0, "parameters": [{"code": 16, "indent": null}]}, {"code": 231, "indent": 0, "parameters": [1, "6-LH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Vũ Văn Du"]}, {"code": 401, "indent": 0, "parameters": ["Ta có những việc nhất định phải làm. Cô ấy phải sống sót. Bởi vì có những việc chỉ cô ấy mới làm được. Mong ngươi tiếp tục giúp đỡ cô ấy. Nếu ngươi phản bội cô ấy… ta nhất định sẽ tìm và giết ngươi."]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 205, "indent": 0, "parameters": [2, {"list": [{"code": 1, "indent": null}, {"code": 1, "indent": null}, {"code": 1, "indent": null}, {"code": 17, "indent": null}, {"code": 0}], "repeat": false, "skippable": true, "wait": true}]}, {"code": 505, "indent": 0, "parameters": [{"code": 1, "indent": null}]}, {"code": 505, "indent": 0, "parameters": [{"code": 1, "indent": null}]}, {"code": 505, "indent": 0, "parameters": [{"code": 1, "indent": null}]}, {"code": 505, "indent": 0, "parameters": [{"code": 17, "indent": null}]}, {"code": 205, "indent": 0, "parameters": [3, {"list": [{"code": 18, "indent": null}, {"code": 0}], "repeat": false, "skippable": true, "wait": true}]}, {"code": 505, "indent": 0, "parameters": [{"code": 18, "indent": null}]}, {"code": 231, "indent": 0, "parameters": [1, "6-LH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Vũ Văn Du"]}, {"code": 401, "indent": 0, "parameters": ["Nếu ngươi gặp một cậu bé có quan hệ huyết thống với cô ấy… ngươi nhất định phải bí mật cho đứa trẻ uống cái Nguồn Nhân Từ này."]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 213, "indent": 0, "parameters": [3, 1, true]}, {"code": 231, "indent": 0, "parameters": [1, "15-LH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Mặc Hiên"]}, {"code": 401, "indent": 0, "parameters": ["Dựa vào đâu ta phải làm theo lời ngươi？!"]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 212, "indent": 0, "parameters": [2, 142, false]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 212, "indent": 0, "parameters": [3, 64, false]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "15-LH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Mặc Hiên"]}, {"code": 401, "indent": 0, "parameters": ["Ngươi đã làm gì ta？!"]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 231, "indent": 0, "parameters": [1, "6-LH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Vũ Văn Du"]}, {"code": 401, "indent": 0, "parameters": ["Một khế ước. Khế ước cưỡng chế. Nếu ngươi không làm… toàn bộ sức mạnh của ngươi sẽ biến mất hoàn toàn. Đương nhiên, nếu ngươi làm… những thương tổn tiềm ẩn trên cơ thể do lần độ kiếp thất bại trước cũng sẽ tan biến."]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 213, "indent": 0, "parameters": [3, 1, true]}, {"code": 231, "indent": 0, "parameters": [1, "15-LH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Mặc Hiên"]}, {"code": 401, "indent": 0, "parameters": ["Tại sao ta phải tin ngươi？"]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 231, "indent": 0, "parameters": [1, "6-LH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Vũ Văn Du"]}, {"code": 401, "indent": 0, "parameters": ["Không cần… miễn là ngươi chịu nổi hậu quả của kết cục xấu nhất."]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 213, "indent": 0, "parameters": [3, 7, true]}, {"code": 231, "indent": 0, "parameters": [1, "15-LH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Mặc Hiên"]}, {"code": 401, "indent": 0, "parameters": ["Ngươi là một kẻ điên… Một tên khốn tàn nhẫn."]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 205, "indent": 0, "parameters": [2, {"list": [{"code": 4, "indent": null}, {"code": 4, "indent": null}, {"code": 4, "indent": null}, {"code": 17, "indent": null}, {"code": 0}], "repeat": false, "skippable": false, "wait": true}]}, {"code": 505, "indent": 0, "parameters": [{"code": 4, "indent": null}]}, {"code": 505, "indent": 0, "parameters": [{"code": 4, "indent": null}]}, {"code": 505, "indent": 0, "parameters": [{"code": 4, "indent": null}]}, {"code": 505, "indent": 0, "parameters": [{"code": 17, "indent": null}]}, {"code": 357, "indent": 0, "parameters": ["TitleCg", "openLock", "解锁指定Cg", {"id": "102"}]}, {"code": 657, "indent": 0, "parameters": ["CgId = 102"]}, {"code": 231, "indent": 0, "parameters": [1, "11-NZXJ1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Vũ Văn Du:(Xin lỗi, ta đáng lẽ nên tìm nàng sớm hơn. Thì chúng ta đã không ra nông nỗi này.)"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Vũ Văn Du:(Thế gian này cần nàng. Nàng phải kiên trì tiếp tục bước tới, phá bỏ mọi sự lừa dối của chân tướng.)"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Vũ Văn Du:(Ký ức của ta cũng bị ai đó thay đổi. Mãi đến ngày ngươi tấn công ta… ta mới nhớ ra nhiều điều. Có những việc… cả ta và ngươi đều phải đối mặt.)"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Vũ Văn Du:(Chỉ là… trở về lần này cũng coi như một thất bại. Ta sẽ mất hết ký ức về nơi này… Thôi, vậy cũng được. Chỉ cần ngươi sống sót.)"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Vũ Văn Du:(Ta phải thay đổi… kết cục tồi tệ nhất này… …)"]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 212, "indent": 0, "parameters": [2, 118, false]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 212, "indent": 0, "parameters": [1, 119, false]}, {"code": 230, "indent": 0, "parameters": [60]}, {"code": 231, "indent": 0, "parameters": [1, "11-NZXJ2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Vũ Văn Du:(Tạm biệt… mong ngươi sẽ hoàn thành những gì mình phải làm.)"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Vũ Văn Du:(Nếu duyên phận cho phép… chúng ta có thể cùng khám phá tận cùng Tiên Đạo.)"]}, {"code": 121, "indent": 0, "parameters": [467, 467, 0]}, {"code": 221, "indent": 0, "parameters": []}, {"code": 201, "indent": 0, "parameters": [0, 123, 12, 10, 2, 0]}, {"code": 211, "indent": 0, "parameters": [1]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 205, "indent": 0, "parameters": [3, {"list": [{"code": 19, "indent": null}, {"code": 0}], "repeat": false, "skippable": false, "wait": true}]}, {"code": 505, "indent": 0, "parameters": [{"code": 19, "indent": null}]}, {"code": 222, "indent": 0, "parameters": []}, {"code": 117, "indent": 0, "parameters": [53]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[11]… …"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[2]Chẳng phải ta đã chết sao？"]}, {"code": 117, "indent": 0, "parameters": [22]}, {"code": 231, "indent": 0, "parameters": [1, "15-LH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Mặc Hiên"]}, {"code": 401, "indent": 0, "parameters": ["Bổn tọa chưa từng thấy tiên nhân nào điên như vậy. Vị Vương tử đó… đã hồi sinh ngươi."]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 213, "indent": 0, "parameters": [-1, 1, true]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[6]Tại sao hắn làm vậy？ Chúng ta chỉ gặp nhau có vài lần."]}, {"code": 231, "indent": 0, "parameters": [1, "15-LH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Mặc Hiên"]}, {"code": 401, "indent": 0, "parameters": ["Ta không biết. Nhưng ta cảm thấy… hắn có việc muốn hoàn thành. Và việc đó liên quan tới ngươi. Ngươi phải sống sót."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Mặc Hiên"]}, {"code": 401, "indent": 0, "parameters": ["(Thật kỳ lạ… cảm giác như mọi thứ hiện tại đều bị ai đó giật dây.)"]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[11](…Đúng rồi. Hắn luôn muốn nói với ta điều gì đó. Nhưng ta cứ đẩy hắn ra. Rốt cuộc là việc gì mà khiến hắn phải dùng đến cách này… dù giá nào cũng phải hồi sinh ta？)"]}, {"code": 231, "indent": 0, "parameters": [1, "15-LH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Mặc Hiên"]}, {"code": 401, "indent": 0, "parameters": ["Trở về thôi. Chúng ta phải cẩn thận hơn nữa. Với sự tồn tại của chúng ta… Chu Tước đã biết rồi."]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 213, "indent": 0, "parameters": [-1, 8, true]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[2](…Ta vẫn nghĩ rằng trong gia tộc Yuwen không có người tốt. Không ngờ… Nhưng sao trong lòng có một cảm giác mơ hồ khó tả？)"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[11](…Xem ra ta cần trở nên mạnh hơn nữa. Và… tại sao Chu Tước lại nhận ra ta？ Nhất định có điều gì ta chưa biết. Ta phải làm sáng tỏ tất cả những bí ẩn này.)"]}, {"code": 122, "indent": 0, "parameters": [47, 47, 0, 0, 2]}, {"code": 121, "indent": 0, "parameters": [711, 711, 0]}, {"code": 201, "indent": 0, "parameters": [0, 110, 30, 8, 2, 0]}, {"code": 117, "indent": 0, "parameters": [52]}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": false, "through": false, "trigger": 3, "walkAnime": true}], "x": 12, "y": 5}, {"id": 5, "name": "EV005", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": true, "image": {"tileId": 0, "characterName": "!Flame", "direction": 2, "pattern": 1, "characterIndex": 5}, "list": [{"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 1, "priorityType": 1, "stepAnime": true, "through": false, "t