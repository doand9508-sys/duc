parameters": [0, 6, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 0, 2, "Ngô Minh"]}, {"code": 401, "indent": 2, "parameters": ["Thí chủ… nếu đang mang thai, tốt nhất hãy tập trung an thai dưỡng khí. Nếu muốn luận đạo, xin hãy quay lại sau."]}, {"code": 117, "indent": 2, "parameters": [22]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 411, "indent": 1, "parameters": []}, {"code": 111, "indent": 2, "parameters": [1, 674, 0, 1, 0]}, {"code": 231, "indent": 3, "parameters": [1, "44-YSLH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 0, 2, "Ngô Minh"]}, {"code": 401, "indent": 3, "parameters": ["Thí chủ, đã chuẩn bị xong chưa？"]}, {"code": 102, "indent": 3, "parameters": [["Đi đến Huyễn Cảnh Luận Đạo.", "Tạm biệt"], 1, 0, 1, 0]}, {"code": 402, "indent": 3, "parameters": [0, "Đi đến Huyễn Cảnh Luận Đạo."]}, {"code": 117, "indent": 4, "parameters": [22]}, {"code": 117, "indent": 4, "parameters": [52]}, {"code": 201, "indent": 4, "parameters": [0, 247, 12, 7, 8, 0]}, {"code": 0, "indent": 4, "parameters": []}, {"code": 402, "indent": 3, "parameters": [1, "Tạm biệt"]}, {"code": 117, "indent": 4, "parameters": [22]}, {"code": 117, "indent": 4, "parameters": [52]}, {"code": 0, "indent": 4, "parameters": []}, {"code": 404, "indent": 3, "parameters": []}, {"code": 0, "indent": 3, "parameters": []}, {"code": 411, "indent": 2, "parameters": []}, {"code": 231, "indent": 3, "parameters": [1, "44-YSLH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 0, 2, "Ngô Minh"]}, {"code": 401, "indent": 3, "parameters": ["Ngươi tới đây để luận đạo sao？"]}, {"code": 101, "indent": 3, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 3, "parameters": ["\\Face[11]Phải. Ta thỉnh cầu cao tăng cùng ta luận đạo."]}, {"code": 231, "indent": 3, "parameters": [1, "44-YSLH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 3, "parameters": ["", 0, 0, 2, "Ngô Minh"]}, {"code": 401, "indent": 3, "parameters": ["Rất tốt. Nhưng trước tiên phải nói rõ, một khi bắt đầu luận bàn thì không thể bỏ dở giữa chừng. Ngươi sẽ tiến vào huyễn cảnh do ta tạo ra. Khi nào chuẩn bị kỹ càng thì đến tìm ta."]}, {"code": 117, "indent": 3, "parameters": [22]}, {"code": 122, "indent": 3, "parameters": [674, 674, 0, 0, 1]}, {"code": 117, "indent": 3, "parameters": [52]}, {"code": 0, "indent": 3, "parameters": []}, {"code": 412, "indent": 2, "parameters": []}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [1, "Quan sát"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 1, ""]}, {"code": 401, "indent": 1, "parameters": ["Đây là một hòa thượng tu vi Luyện Hư tên là Ngô Minh. Ngài bề ngoài ôn hòa, nhưng lại có một cảm giác bất tường mờ nhạt bao quanh."]}, {"code": 117, "indent": 1, "parameters": [22]}, {"code": 117, "indent": 1, "parameters": [52]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [2, "Tạm biệt"]}, {"code": 117, "indent": 1, "parameters": [22]}, {"code": 117, "indent": 1, "parameters": [52]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 404, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}, {"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 716, "switch1Valid": true, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": true, "image": {"tileId": 0, "characterName": "13", "direction": 2, "pattern": 1, "characterIndex": 6}, "list": [{"code": 231, "indent": 0, "parameters": [1, "44-YSLH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 0, "parameters": ["Quả nhiên ngươi đã tới. Tất cả những chuyện này… cho dù thất bại đi nữa, cũng sẽ không còn cơ hội nào nữa. Ta nhất định sẽ hút cạn ngươi đến giọt cuối cùng."]}, {"code": 401, "indent": 0, "parameters": ["Nhắc nhở: Thất bại sẽ dẫn đến Kết Cục Xấu. Nhớ lưu trò chơi."]}, {"code": 102, "indent": 0, "parameters": [["Bớt nói nhảm đi. Đánh luôn đi.", "Để ta suy nghĩ thêm chút nữa."], 1, 0, 1, 0]}, {"code": 402, "indent": 0, "parameters": [0, "Bớt nói nhảm đi. Đánh luôn đi."]}, {"code": 355, "indent": 1, "parameters": ["$we.saveEnd(this);"]}, {"code": 117, "indent": 1, "parameters": [22]}, {"code": 301, "indent": 1, "parameters": [0, 169, false, true]}, {"code": 601, "indent": 1, "parameters": []}, {"code": 117, "indent": 2, "parameters": [53]}, {"code": 231, "indent": 2, "parameters": [1, "44-YSLH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 2, "parameters": ["Tại sao？! Tại sao ai khác cũng có thể sống, chỉ duy nhất mình ta phải chết？!"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 2, "parameters": ["\\Face[2]Nếu không muốn chết, vậy đừng chết. Đã quyết định chịu chết rồi, bây giờ còn oán thán gì nữa？"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 2, "parameters": ["Ngươi nói thì dễ lắm. Không ai ép buộc ngươi. Còn bọn họ, vì Xá Lợi của ta, dù ta mới chỉ nhiễm bệnh, đã không thể chờ đến ngày ta nhập diệt."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 2, "parameters": ["\\Face[5]Vậy nên ngươi đã giam cầm những người khác đến luận đạo, hoặc dùng bọn họ để kéo dài tuổi thọ cho mình. Bọn họ đâu phải những kẻ đã hại ngươi năm xưa. Ngươi có tư cách gì làm thế？ Ngươi thì khác gì những kẻ đã từng hại ngươ