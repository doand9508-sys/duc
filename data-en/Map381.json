itchCh": "A", "selfSwitchValid": false, "switch1Id": 863, "switch1Valid": true, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"tileId": 0, "characterName": "$2-BZ1", "direction": 6, "pattern": 1, "characterIndex": 0}, "list": [{"code": 117, "indent": 0, "parameters": [115]}, {"code": 221, "indent": 0, "parameters": []}, {"code": 111, "indent": 0, "parameters": [1, 1244, 0, 1, 0]}, {"code": 102, "indent": 1, "parameters": [["Bỏ qua cốt truyện.", "Không bỏ qua."], -1, 0, 1, 0]}, {"code": 402, "indent": 1, "parameters": [0, "Bỏ qua cốt truyện."]}, {"code": 221, "indent": 2, "parameters": []}, {"code": 250, "indent": 2, "parameters": [{"name": "3-PTSNSSGC", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 122, "indent": 2, "parameters": [4, 4, 1, 0, 5]}, {"code": 122, "indent": 2, "parameters": [24, 24, 1, 0, 5]}, {"code": 122, "indent": 2, "parameters": [23, 23, 1, 0, 5]}, {"code": 122, "indent": 2, "parameters": [29, 29, 1, 0, 1]}, {"code": 315, "indent": 2, "parameters": [0, 1, 0, 0, 3500, false]}, {"code": 122, "indent": 2, "parameters": [1244, 1244, 0, 0, 1]}, {"code": 235, "indent": 2, "parameters": [1]}, {"code": 230, "indent": 2, "parameters": [30]}, {"code": 222, "indent": 2, "parameters": []}, {"code": 251, "indent": 2, "parameters": []}, {"code": 117, "indent": 2, "parameters": [116]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 402, "indent": 1, "parameters": [1, "Không bỏ qua."]}, {"code": 119, "indent": 2, "parameters": ["1"]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 404, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 411, "indent": 0, "parameters": []}, {"code": 118, "indent": 1, "parameters": ["1"]}, {"code": 357, "indent": 1, "parameters": ["TitleCg", "openLock", "解锁指定Cg", {"id": "186"}]}, {"code": 657, "indent": 1, "parameters": ["CgId = 186"]}, {"code": 243, "indent": 1, "parameters": []}, {"code": 241, "indent": 1, "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Sư tỷ… Sư phụ, Sư huynh… họ đều không có ở đây. Tỷ… không muốn làm gì vui vẻ sao？"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1] nở một nụ cười tinh nghịch. Ngọn lửa nhiệt trong tim nàng, như ngọn lửa, liếm láp người phụ nữ trước mặt. Không giải thích gì thêm, nàng cởi bỏ quần áo và lăn lên giường cùng với cô ấy."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Hì hì, Sư tỷ. Hôm nọ, tỷ và Sư huynh làm dữ dội quá – suýt khiến muội phát điên vì dục vọng. Hôm nay, muội muốn tự mình nếm thử Sư tỷ."]}, {"code": 231, "indent": 1, "parameters": [1, "59-HHZYYJJH3-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 222, "indent": 1, "parameters": []}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Vừa nói, nàng vừa banh cặp chân ngọc ngà của Sư tỷ trong vòng tay ra, để lộ cái hũ mật mà dù trải qua vô số lần thân mật vẫn hồng tươi mỏng manh."]}, {"code": 250, "indent": 1, "parameters": [{"name": "3-PTSNSSH1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1] nhấc cặp mông săn chắc của mình lên, tách rộng phần kín. Hai miếng thịt non áp vào nhau. Những âm thanh dính nhớp, nhóp nhép của dịch thể bắt đầu vang lên trong phòng với tiếng xẹt xẹt."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Sư tỷ: A~ Aaaa~ Sư muội… của muội… nóng quá…"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Thảo nào Sư huynh cưng chiều tỷ như vậy. Thì ra tỷ giấu bảo vật quý báu như thế. Khi nó chuyển động, nó mút giỏi không thể tưởng…"]}, {"code": 231, "indent": 1, "parameters": [1, "59-HHZYYJJH3-2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]cơn hưng phấn của nàng dâng cao. Nàng bắt đầu vặn eo mạnh mẽ. Hai hạt đậu mật của họ cùng cương cứng, cọ xát và mài vào nhau."]}, {"code": 250, "indent": 1, "parameters": [{"name": "3-PTSNSSH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Dòng nước suối rỉ ra từ hai cái lồn non thậm chí hòa vào nhau, chảy từ cặp mông đẹp của họ và thấm ướt ga giường."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Sư Tỷ: Ah… Sư huynh… Sư huynh và em… chúng em từ nhỏ đã cùng nhau lớn lên… trước khi nhập môn phái, chúng em đã…."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1]: Ha… Vậy ra hai người đã là tình nhân từ nhỏ… Hèn chi lúc nào cũng quấn quýt không rời… Tss… Suýt chút nữa ta đã ghen tị với vị Sư huynh đó. Không chỉ… ha… chiếm lấy đêm đầu của ngươi, mà còn dạy dỗ ngươi thành ra thế này…"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Sư Tỷ: K-Không… không phải như vậy… là Sư phụ… người đã đích thân dạy chúng ta thuật pháp…"]}, {"code": 231, "indent": 1, "parameters": [1, "59-HHZYYJJH3-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 1, "parameters": [{"name": "3-PTSNSSGC", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Chẳng mấy chốc, bốn cái chân trắng ngần như ngọc chồng lên nhau bắt đầu co giật nhẹ. Những tiếng rên rỉ uyển chuyển, hổn hển chuyển thành hơi thở gấp gáp, dồn dập, rồi hai tiếng thở dài."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1] ôm lấy cơ thể mềm nhũn, vô lực của Sư tỷ bên dưới, để lộ nụ cười đầy ẩn ý, mê hoặc."]}, {"code": 221, "indent": 1, "parameters": []}, {"code": 251, "indent": 1, "parameters": []}, {"code": 122, "indent": 1, "parameters": [4, 4, 1, 0, 5]}, {"code": 122, "indent": 1, "parameters": [24, 24, 1, 0, 5]}, {"code": 122, "indent": 1, "parameters": [23, 23, 1, 0, 5]}, {"code": 122, "indent": 1, "parameters": [29, 29, 1, 0, 1]}, {"code": 315, "indent": 1, "parameters": [0, 1, 0, 0, 3500, false]}, {"code": 122, "indent": 1, "parameters": [1244, 1244, 0, 0, 1]}, {"code": 122, "indent": 1, "parameters": [1311, 1311, 0, 0, 1]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 222, "indent": 1, "parameters": []}, {"code": 117, "indent": 1, "parameters": [116]}, {"code": 244, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 412, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through