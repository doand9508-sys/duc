: false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 235, "indent": 0, "parameters": [1]}, {"code": 122, "indent": 0, "parameters": [40, 40, 0, 0, 3]}, {"code": 211, "indent": 0, "parameters": [0]}, {"code": 117, "indent": 0, "parameters": [52]}, {"code": 111, "indent": 0, "parameters": [1, 134, 0, 1, 0]}, {"code": 102, "indent": 1, "parameters": [["Bỏ qua cốt truyện.", "Không bỏ qua."], 1, 0, 1, 0]}, {"code": 402, "indent": 1, "parameters": [0, "Bỏ qua cốt truyện."]}, {"code": 231, "indent": 2, "parameters": [1, "HS", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 111, "indent": 2, "parameters": [0, 15, 0]}, {"code": 121, "indent": 3, "parameters": [15, 15, 1]}, {"code": 357, "indent": 3, "parameters": ["FlyCat_LL_SceneMenu", "setTearPeople", "设置破处者", {"name": "Tinh Tinh", "variablesId": ""}]}, {"code": 657, "indent": 3, "parameters": ["破处者姓名 = Tinh Tinh"]}, {"code": 657, "indent": 3, "parameters": ["指定回传破处者姓名的变量 = "]}, {"code": 0, "indent": 3, "parameters": []}, {"code": 412, "indent": 2, "parameters": []}, {"code": 250, "indent": 2, "parameters": [{"name": "2-NZQJGC", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 230, "indent": 2, "parameters": [60]}, {"code": 251, "indent": 2, "parameters": []}, {"code": 122, "indent": 2, "parameters": [18, 18, 1, 0, 1]}, {"code": 122, "indent": 2, "parameters": [4, 4, 1, 0, 5]}, {"code": 122, "indent": 2, "parameters": [24, 24, 1, 0, 5]}, {"code": 122, "indent": 2, "parameters": [32, 32, 1, 0, 1]}, {"code": 122, "indent": 2, "parameters": [34, 34, 1, 0, 1]}, {"code": 117, "indent": 2, "parameters": [17]}, {"code": 117, "indent": 2, "parameters": [18]}, {"code": 235, "indent": 2, "parameters": [1]}, {"code": 117, "indent": 2, "parameters": [341]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 402, "indent": 1, "parameters": [1, "Không bỏ qua."]}, {"code": 119, "indent": 2, "parameters": ["btg"]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 404, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 411, "indent": 0, "parameters": []}, {"code": 118, "indent": 1, "parameters": ["btg"]}, {"code": 357, "indent": 1, "parameters": ["TitleCg", "openLock", "解锁指定Cg", {"id": "5"}]}, {"code": 657, "indent": 1, "parameters": ["CgId = 5"]}, {"code": 243, "indent": 1, "parameters": []}, {"code": 241, "indent": 1, "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 1, "parameters": [2, "50-SSZBH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Một sinh vật hình người nhưng không hẳn là người giữ chặt  \\n[1]  từ phía sau. Cô càng giãy giụa, bộ lông thô ráp của nó càng cọ xát làn da mỏng manh, gây ra cơn đau âm ỉ dày đặc."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Một vật cứng ngắc, nóng rát giữa chân con hầu tinh thô lỗ áp vào cặp mông trắng như tuyết của cô."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Đôi tay đầy lông lá quấn chặt lấy cô. Cặp vú cô bị ép chặt vào nhau, núm vú hồng nhô ra, dài và nổi bật, run rẩy trong làn gió lạnh."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Bản năng nguyên thủy khiến con hầu tinh khẩn cấp tìm kiếm cái âm đạo ẩm ướt, chật hẹp đó. Thất bại, nó mò mẫm vụng về bên ngoài cửa mình cô mà chẳng có phương pháp gì."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nó cọ xát ngay vào âm vật của cô, đâm nhanh qua lại, mài mòn hạt đậu nhỏ đó đến khi hơi sưng lên."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 1, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Cảm giác vừa đau vừa sướng khiến  \\n[1] rơi nước mắt. Dịch trong suốt từ con hầu tinh rỉ ra hòa lẫn với mật dịch từ âm hộ cô tiết ra, đặc lại."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Cây cặc của nó cọ xát và bôi bẩn khắp bụng phẳng của  \\n[1], một mớ hỗn độn lấp lánh. Núm vú cô đột nhiên ngứa không chịu nổi, và khuôn mặt cô nóng bừng."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Những đám mây hồng trôi qua khuôn mặt xinh đẹp của cô. Cắn chặt hàm răng trắng ngọc trai cũng không ngăn được những tiếng rên ngọt ngào, hổn hển tràn ra khỏi đôi môi đỏ."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Thứ đó thực sự còn lớn và cứng hơn nữa, giờ dài cả thước. Động tác của con hầu tinh càng lúc càng nhanh, càng rộng."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hơi thở hôi hám, ôi thiu, dồn dập phả vào cổ  \\n[1]. Hơi nóng làm toàn thân cô run rẩy và nóng ran. Bụng dưới cô không kìm được co thắt vài lần, không biết vì sợ hay mong đợi."]}, {"code": 111, "indent": 1, "parameters": [0, 15, 0]}, {"code": 231, "indent": 2, "parameters": [2, "50-SSZBH2-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Qua những cử động hỗn loạn, không định hướng, cái đầu cho bằng quả óc chó cuối cùng cũng, nhờ vào sự may mắn và dòng mật trơn, lách vào được âm hộ bị khao khát bấy lâu của cô."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Cây gậy tròn trịa, trơn bóng cuối cùng cũng tìm thấy một khe hở khác thường, nơi ấm áp và ẩm ướt nhất. Con hầu tinh biết nó đã tìm được chỗ nó thèm muốn và càng điên cuồng hơn."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Tuy nhiên, chỉ mới vào được một inch, nó dường như gặp phải một rào cản nào đó. Con hầu tinh bối rối, nhưng bộ não nó không đủ sức để nghĩ nhiều."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Nó chỉ ấn mạnh hơn vào trong. Màng trinh thuần khiết, chưa từng bị xâm phạm của cô bị cái thứ cho lớn khủng khiếp ấy thúc vào. Nó kháng cự."]}, {"code": 231, "indent": 2, "parameters": [2, "50-SSZBH3-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 2, "parameters": [{"name": "2-NZQJCR", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Vài cú thúc sau, nó bị phá vỡ. Một dòng máu tươi chảy ra từ âm hộ cô. Cơn đau vô cùng khiến nước mắt  \\n[1] lăn xuống, nhưng con hầu tinh không cho cô cơ hội để thở."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Nó bắt đầu thúc dữ dội. Mũi cô đỏ lên, và cô không kìm được nức nở. Con hầu tinh dĩ nhiên không hiểu sự dịu dàng với phụ nữ, chỉ càng điên cuồng hông hơn."]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 411, "indent": 1, "parameters": []}, {"code": 231, "indent": 2, "parameters": [2, "50-SSZBH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 2, "parameters": [{"name": "2-NZQJH1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Qua những cử động hỗn loạn, không định hướng, cái đầu cho bằng quả óc chó cuối cùng cũng, nhờ vào sự may mắn và dòng mật trơn, lách vào được âm hộ bị khao khát bấy lâu của cô."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Con hầu tinh càng hùng hục thúc hông hơn nữa, mỗi lần thúc lại ấn sâu hơn và sâu hơn vào âm hộ cô. Những âm thanh ướt át, vỗ lách tách không ngừng."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Mật dịch bắn ra theo mỗi lần cây cặc rút ra. Thậm chí nhiều dịch hơn, chưa kịp chảy ra, đã bị thúc ngược trở vào trong âm hộ cô."]}, {"code": 231, "indent": 2, "parameters": [2, "50-SSZBH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 111, "indent": 1, "parameters": [0, 15, 0]}, {"code": 231, "indent": 2, "parameters": [2, "50-SSZBH4-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 411, "indent": 1, "parameters": []}, {"code": 231, "indent": 2, "parameters": [2, "50-SSZBH4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Một tay con hầu tinh nắm eo  \\n[1], ấn xuống theo từng nhịp thúc hông của nó. Cơ thể cô bị mở toang, một cảm giác mất kiểm soát hoàn toàn."]}, {"code": 250, "indent": 1, "parameters": [{"name": "2-NZQJH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Điều đó khiến  \\n[1]  theo bản năng muốn khép chặt chân lại. Nhưng đầu gối con hầu tinh ấn vào đùi cô."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Đôi chân nó, khéo léo như tay, nắm lấy mắt cá chân  \\n[1] và kéo ra ngoài, làm cho việc đâm sâu vào cơ thể  \\n[1] dễ dàng hơn."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Cái lồn gấp khít của cô bám chặt, mút lấy cây gậy dài khủng khiếp màu nâu sẫm. Con hầu tinh chỉ quan tâm đến khoái cảm của riêng nó, điên cuồng và nhanh chóng trút bỏ dục vọng."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Khoái cảm mãnh liệt tích tụ trong bụng dưới cô, rồi tấn công lý trí của  \\n[1] từng đợt từng đợt."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Khoái cảm mãnh liệt đến nghẹt thở khiến chiếc lưỡi xinh đẹp ấy vượt qua khỏi môi. Những tiếng rên hổn hển ngọt ngào, mơ hồ, theo nhịp thúc, được thốt ra không kìm chế."]}, {"code": 111, "indent": 1, "parameters": [0, 15, 0]}, {"code": 357, "indent": 2, "parameters": ["FlyCat_LL_SceneMenu", "setTearPeople", "设置破处者", {"name": "Tinh Tinh", "variablesId": ""}]}, {"code": 657, "indent": 2, "parameters": ["破处者姓名 = Tinh Tinh"]}, {"code": 657, "inde