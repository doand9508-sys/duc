alse, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}], "x": 12, "y": 6}, {"id": 3, "name": "EV003", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 117, "indent": 0, "parameters": [115]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 0, "parameters": ["Lại một lần nữa bước vào căn phòng này… cô bé nằm trên giường nay đã lớn hơn. Trông chừng như một đứa trẻ bảy, tám tuổi. Nhưng gương mặt ấy… lẽ ra phải tràn đầy sức sống tuổi trẻ… giờ đây lại trắng bệch như người chết."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 0, "parameters": ["<qp:1,600,>Cô bé: Mẹ ơi… bụng con đau quá."]}, {"code": 213, "indent": 0, "parameters": [2, 7, true]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 0, "parameters": ["<qp:2,600,>Người phụ nữ nông dân: Ayuan… đều do chúng ta vô dụng cả. Chúng ta biết trồng dược thảo… nhưng lại không hiểu đạo lý chữa bệnh."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 0, "parameters": ["<qp:2,600,>Người phụ nữ nông dân: Anh cả con sắp lấy vợ rồi. Trong nhà thật sự không còn tiền dư. Hãy… cứ cố gắng chịu đựng. Biết đâu… biết đâu con có thể vượt qua được？"]}, {"code": 213, "indent": 0, "parameters": [1, 8, true]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 0, "parameters": ["Cô bé dường như muốn nói thêm điều gì đó. Nhưng cơn đau khiến mỗi lần cất lời đều vô cùng khó khăn. Cô bé cũng muốn… được sống tiếp. Nhưng… nhưng mà… trong nhà không có tiền… có lẽ…？"]}, {"code": 117, "indent": 0, "parameters": [53]}, {"code": 231, "indent": 0, "parameters": [1, "44-YSLH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 0, "parameters": ["Nghèo đói, song hành cùng bệnh tật… đây chính là cuộc sống. Nếu ngươi là cô bé ấy… ngươi sẽ lựa chọn thế nào？"]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[11](Lời của kẻ này đầy rẫy cạm bẫy. Hắn ta thật lòng muốn giúp những người đến đây tiêu trừ tâm ma, củng cố Đạo Tâm sao？)"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[2](Không thể làm theo mạch suy nghĩ của hắn được. Câu hỏi là về 'lựa chọn của cô bé'. Nhưng… lựa chọn của cô bé bây giờ còn quan trọng nữa sao？)"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[11](Vậy thì… câu trả lời của ta là——)"]}, {"code": 401, "indent": 0, "parameters": ["Đạo Tâm hiện tại: \\C[10]\\V[675]\\C[0]"]}, {"code": 102, "indent": 0, "parameters": [["Vạn vật đều có số mệnh an bài. Đã không thể thay đổi… thì chỉ có thể tiếp nhận mà thôi.", "Trong nhà đã có dược thảo… vậy cứ tiếp tục thử đi. Biết đâu cô bé có thể hồi phục.", "Nói chuyện với người mẹ. Giải thích chỉ số sống của mình. Nếu không… chỉ có thể chờ chết."], -1, 0, 1, 0]}, {"code": 402, "indent": 0, "parameters": [0, "Vạn vật đều có số mệnh an bài. Đã không thể thay đổi… thì chỉ có thể tiếp nhận mà thôi."]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Không ngờ, thân là người tu hành, ngươi lại còn tin vào Thiên Mệnh？ Nếu thực sự có Thiên Mệnh… vậy kẻ tu hành có phải nên ngoan ngoãn chết theo số mệnh đó không？"]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Bần tăng chưa từng thấy qua kẻ tu hành nào cam tâm khuất phục số mệnh. Chỉ có những kẻ nghịch thiên mà đi, ngược dòng vận mệnh… mới có thể sống ra chính mình."]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Nếu ngươi thực sự khuất phục số mệnh… làm sao có thể đi đến tận đây？"]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 122, "indent": 1, "parameters": [675, 675, 2, 0, 15]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[10](Không! Không đúng! Có gì đó không ổn! Tại sao hắn lại nói như vậy？ Điều này không nên là… Đây có phải là Luận Đạo nữa không？)"]}, {"code": 401, "indent": 1, "parameters": ["Đạo Tâm hiện tại: \\C[10]\\V[675]\\C[0]"]}, {"code": 117, "indent": 1, "parameters": [115]}, {"code": 201, "indent": 1, "parameters": [0, 299, 12, 9, 8, 0]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [1, "Trong nhà đã có dược thảo… vậy cứ tiếp tục thử đi. Biết đâu cô bé có thể hồi phục."]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Nếu thực sự có ích… thì đã đến nông nỗi này sao？"]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Tiên tử… chẳng lẽ ngươi… chỉ tùy tiện viết bừa thôi sao？"]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Tùy tiện ném ra câu trả lời lung tung… sẽ không thể Luận Đạo thành công được đâu."]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 122, "indent": 1, "parameters": [675, 675, 2, 0, 15]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[10](Không! Không đúng! Có gì đó không ổn! Tại sao hắn lại nói như vậy？ Điều này không nên là… Đây có phải là Luận Đạo nữa không？)"]}, {"code": 401, "indent": 1, "parameters": ["Đạo Tâm hiện tại: \\C[10]\\V[675]\\C[0]"]}, {"code": 117, "indent": 1, "parameters": [115]}, {"code": 201, "indent": 1, "parameters": [0, 299, 12, 9, 8, 0]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [2, "Nói chuyện với người mẹ. Giải thích chỉ số sống của mình. Nếu không… chỉ có thể chờ chết."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[11]Chỉ có nói cho cha mẹ biết chỉ số của ngươi… một chỉ số vượt xa hậu quả của cái chết."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[1]Nơi giường bệnh lâu ngày… sẽ không ai còn kiên nhẫn mãi được. Không có chỉ số… thì chỉ có thể bị vứt bỏ."]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Ngươi nói đúng. Con người chỉ tìm cách khiến bản thân tỏ ra cao thượng. Cuối cùng… tất cả đều là để thỏa mãn cảm giác lương thiện của chính mình."]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[10](Có vấn đề… Cuộc Luận Đạo này có vấn đề. Như vậy không thể tiêu trừ tâm ma… không thể củng cố Đạo Tâm.)"]}, {"code": 401, "indent": 1, "parameters": ["Đạo Tâm hiện tại: \\C[10]\\V[675]\\C[0]"]}, {"code": 117, "indent": 1, "parameters": [115]}, {"code": 201, "indent": 1, "parameters": [0, 299, 12, 9, 8, 0]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 404, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": false, "through": false, "trigger": 3, "walkAnime": true}], "x": 12, "y": 2}, {"id": 4, "name": "Yêu Tăng", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"tileId": 0, "characterName": "13", "direction": 8, "pattern": 1, "characterIndex": 6}, "list": [{"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}], "x": 13, "y": 8}], "parallaxLoopX": false, "parallaxLoopY": false, "parallaxName": "", "parallaxShow": true, "parallaxSx": 0, "parallaxSy": 0}