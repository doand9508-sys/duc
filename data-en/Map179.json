102, "indent": 0, "parameters": [["Quyến rũ (Yêu cầu Cấp độ tha hóa 110).", "Chính nghĩa phẫn nộ (Yêu cầu Danh vọng 30).", "Suy nghĩ lại."], 2, 0, 1, 0]}, {"code": 402, "indent": 0, "parameters": [0, "Quyến rũ (Yêu cầu Cấp độ tha hóa 110)."]}, {"code": 117, "indent": 1, "parameters": [251]}, {"code": 121, "indent": 1, "parameters": [587, 587, 0]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [1, "Chính nghĩa phẫn nộ (Yêu cầu Danh vọng 30)."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:0,600,>\\n[1]: Ta muốn cứu những người đã mất tích. Nếu ngươi biết điều gì… xin hãy nói cho ta biết."]}, {"code": 213, "indent": 1, "parameters": [0, 1, true]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:7,600,>Tịnh Ngộ: Sự chính nghĩa của thí chủ… ta hiểu."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:7,600,>Tịnh Ngộ: Dù sau này có liên lụy đến ta… ta cũng muốn cứu những người đó."]}, {"code": 213, "indent": 1, "parameters": [0, 8, true]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:7,600,>Tịnh Ngộ: Sự thật là… Phật môn vốn có một vị cao tăng trẻ tuổi, giác ngộ. Ông ấy lẽ ra đã có thể phi thăng. Nhưng vào một dịp nọ, một nữ yêu tinh từ Hợp Hoan Tông đã phá vỡ Đạo tâm của ông ấy."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:7,600,>Tịnh Ngộ: Không chỉ không thể phi thăng… ông ấy còn già đi nhanh chóng. Siêu thoát là lựa chọn duy nhất của ông."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:7,600,>Tịnh Ngộ: Không ai biết chính xác chuyện gì đã xảy ra trong lần ông cố gắng siêu thoát. Nhưng khi ông ấy xuất hiện trở lại… ông ấy đã trở nên vô cùng kỳ lạ và quái dị."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:7,600,>Tịnh Ngộ: Ta biết rằng Vô Tâm sư thúc biết tung tích của ông ấy. Ta nghi ngờ… sư thúc cũng có liên quan đến việc này."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:7,600,>Tịnh Ngộ: Vô Tâm sư thúc khá là tham lam. Chỉ cần đưa ông ta 1000 Linh thạch, ông ta sẽ dẫn ngươi đến thảo luận Đạo pháp với người đó."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nhiệm vụ phụ được kích hoạt: \\C[4]Bí mật của Phật Môn\\C[0]. Nhiệm vụ này đã bước vào giai đoạn tiếp theo. Hãy nhớ kiểm tra."]}, {"code": 250, "indent": 1, "parameters": [{"name": "Up1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 357, "indent": 1, "parameters": ["Cat_QuestCore", "nextQuest", "任务进入下一进度", {"type": "支线", "id": "52"}]}, {"code": 657, "indent": 1, "parameters": ["任务类型 = 支线"]}, {"code": 657, "indent": 1, "parameters": ["任务Id号 = 52"]}, {"code": 126, "indent": 1, "parameters": [53, 0, 0, 100]}, {"code": 122, "indent": 1, "parameters": [13, 13, 1, 0, 1]}, {"code": 122, "indent": 1, "parameters": [8, 8, 1, 0, 2]}, {"code": 121, "indent": 1, "parameters": [586, 586, 0]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [2, "Suy nghĩ lại."]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 404, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}, {"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 586, "switch1Vali