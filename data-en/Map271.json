arameters": ["<qp:14,600,>Triệu Tiểu Tiểu: Ngươi… ha…"]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 411, "indent": 1, "parameters": []}, {"code": 101, "indent": 2, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 2, "parameters": ["<qp:14,600,>Triệu Tiểu Tiểu: Lại một người nữa…"]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 411, "indent": 0, "parameters": []}, {"code": 111, "indent": 1, "parameters": [1, 1180, 0, 1, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 2, "parameters": ["<qp:14,600,>Triệu Tiểu Tiểu: Mong rằng thứ này sẽ giúp ích được cho ngươi."]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 411, "indent": 1, "parameters": []}, {"code": 101, "indent": 2, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 2, "parameters": ["<qp:14,600,>Triệu Tiểu Tiểu: Tỷ tỷ, đi lại bên ngoài thì tốt nhất nên mang theo thứ gì đó phòng thân đi. Ai biết được sẽ có kẻ xấu bất ngờ ra tay lúc nào. Ta có chút bản lĩnh gia truyền… có thể làm ra vài thứ có lẽ sẽ hữu ích với ngươi."]}, {"code": 102, "indent": 2, "parameters": [["Để nàng ấy chế tạo.", "Không cần."], 1, 0, 1, 0]}, {"code": 402, "indent": 2, "parameters": [0, "Để nàng ấy chế tạo."]}, {"code": 128, "indent": 3, "parameters": [146, 0, 0, 1, false]}, {"code": 122, "indent": 3, "parameters": [1180, 1180, 0, 0, 1]}, {"code": 0, "indent": 3, "parameters": []}, {"code": 402, "indent": 2, "parameters": [1, "Không cần."]}, {"code": 0, "indent": 3, "parameters": []}, {"code": 404, "indent": 2, "parameters": []}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 412, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}], "x": 16, "y": 10}, {"id": 15, "name": "Hạ Ca", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"tileId": 0, "characterName": "NPC5", "direction": 6, "pattern": 1, "characterIndex": 6}, "list": [{"code": 111, "indent": 0, "parameters": [0, 31, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:15,600,>Hạ Ca: Lại thêm một kẻ đáng thương dấn bước vào con đường không lối về. Nhưng mà… đã đi rồi, thì đừng bỏ dở giữa chừng."]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 411, "indent": 0, "parameters": []}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["<qp:15,600,>Hạ Ca: Đạo hữu, dáng vẻ hiện tại của ngươi… khiến ta nhớ tới chính mình trước đây. Ngươi… sẽ đi được bao xa？"]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 412, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}], "x": 14, "y": 10}, {"id": 16, "name": "", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"tileId": 0, "characterName": "",