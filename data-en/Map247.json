": 0, "parameters": ["Đạo tâm hiện tại: \\C[10]\\V[675]\\C[0]"]}, {"code": 102, "indent": 0, "parameters": [["Sinh đại biểu cho khởi đầu của vạn vật, sinh mệnh mới, hy vọng.", "Sinh đại biểu cho khởi đầu của hành trình bước tới cái chết."], -1, 0, 1, 0]}, {"code": 402, "indent": 0, "parameters": [0, "Sinh đại biểu cho khởi đầu của vạn vật, sinh mệnh mới, hy vọng."]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Phải vậy không？ Nhưng mà… khoảnh khắc một người sinh ra, cái chết liền đã được định đoạt. Dù là thọ nguyên có được nhờ Tiên Đồ, cũng có điểm cuối. Cõi đời này, phàm là chúng sinh, nào có mấy ai có thể phi thăng Thiên Giới？"]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Thế nên, không ai có thể tránh khỏi. Số mệnh tử vong… từ giây phút sinh ra đã được định sẵn."]}, {"code": 122, "indent": 1, "parameters": [675, 675, 2, 0, 25]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[11]Không ai có thể tránh khỏi… Không ai có thể tránh khỏi… Quả thực… đúng là như vậy…"]}, {"code": 401, "indent": 1, "parameters": ["Đạo tâm hiện tại: \\C[10]\\V[675]\\C[0]"]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Thí chủ, chúng ta đi đến vị tiếp theo thôi."]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 117, "indent": 1, "parameters": [52]}, {"code": 201, "indent": 1, "parameters": [0, 298, 12, 8, 8, 0]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [1, "Sinh đại biểu cho khởi đầu của hành trình bước 