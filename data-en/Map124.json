ent": 2, "parameters": ["\\CT[1]Hũ mật đó, như thể thỏa mãn, bắt đầu háo hức chào đón cây cặc, rên rỉ."]}, {"code": 250, "indent": 2, "parameters": [{"name": "2-NZQJCR", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 2, "parameters": [2, "MRH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Nn~ Mm~ Ah~ Ah~!"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Hoa Ma Quỷ: Ehehehehe~ Hehehehe~"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Dù là thực vật, con cặc dây leo đó lại chuyển động như một cơ quan sống, linh hoạt đâm tới lui bên trong âm hộ của  \\N[1], tiết ra chất nhầy kích dục."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Sau nhiều lần đâm tới lui, âm hộ cô đã bị lấp đầy hoàn toàn. Dù  \\N[1]  có không muốn thế nào đi nữa, thì cơ thể cô đã từ bỏ kháng cự, đắm chìm trong khoái cảm kỳ lạ tuyệt diệu đó."]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]Cô thậm chí bắt đầu chủ động đón lấy những cú thúc của cây cặc."]}, {"code": 250, "indent": 2, "parameters": [{"name": "2-NZQJH1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameters": ["\\CT[1]\\n[1]: Nn~ Mm~ Ah~ Ah~! Đâm nữa… thật thoải mái… Nn~ Hmm~ Ah~ Ah~!"]}, {"code": 101, "indent": 2, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 2, "parameters": [""]}, {"code": 401, "indent": 2, "parameter