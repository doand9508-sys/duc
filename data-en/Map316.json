ent": 1, "parameters": ["Tôi đã bảo đừng lại gần mà! Tại sao？! Ngươi… ngươi cũng giống như bọn họ sao？!"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[5]Ngươi đang nói cái gì vậy？! Không thấy ngươi gần như không cử động nổi sao？ Ta đánh ngất ngươi rồi mang đi là được!"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["Hàn Vũ muốn nói thêm… nhưng chàng đã chịu đựng đến cực hạn. Thậm chí chàng còn không nghe rõ  \\n[1]  nói gì sau đó. Chàng hung hăng vồ lấy  \\n[1]."]}, {"code": 213, "indent": 1, "parameters": [-1, 1, true]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[5]Ngươi làm gì vậy？! Sao ngươi không ngất đi？! DỪNG LẠI! Y phục của ta!!!"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 1, "parameters": ["Hàn Vũ không hề dừng lại. Đôi mắt… tâm trí… của chàng hoàn toàn đặt trên bộ ngực đầy đặn căng mọng, cơ thể mềm mại non nớt của  \\n[1]. Thơm quá… Chàng thực sự muốn… chơi đùa nàng thật đàng hoàng."]}, {"code": 117, "indent": 1, "parameters": [115]}, {"code": 357, "indent": 1, "parameters": ["TitleCg", "openLock", "解锁指定Cg", {"id": "132"}]}, {"code": 657, "indent": 1, "parameters": ["CgId = 132"]}, {"code": 241, "indent": 1, "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 221, "indent": 1, "parameters": []}, {"code": 235, "indent": 1, "parameters": [2]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1][P35]: Không! Hàn Vũ, tỉnh lại đi! Vững vàng thân thể! Chúng ta có thể… a…"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1] \\n[1], hoàn toàn lõa lồ, bị đè xuống đất. Côn thịt hơi nóng của Hàn Vũ chen chặt vào giữa hai chân [P35]."]}, {"code": 231, "indent": 1, "parameters": [1, "44-FZHYH2-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 222, "indent": 1, "parameters": []}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1][P35]: Bình tĩnh! Ngươi là phật tu! Không thể… …"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hàn Vũ: Cho ta… cho ta…"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hàn Vũ chỉ cảm thấy toàn thân nóng bừng. Giờ đây hắn chỉ muốn trút bỏ dục vọng trong lòng. Hắn chỉ là một đệ tử thế tục. Có gì mà sợ？"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1][P35]: Không… không đúng… tỉnh lại đi… a a a a a~~~"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hàn Vũ hoàn toàn không nghe lọt. Côn thịt cứng ngắc của hắn đã hung hăng đâm vào lồn của  \\n[1]. Một cảm giác thoải mái khó tả khiến cả linh hồn hắn cũng run rẩy."]}, {"code": 231, "indent": 1, "parameters": [1, "44-FZHYH2-2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1][P36]: To quá, nóng quá… lồn ta bị lấp đầy hoàn toàn… Sắp nứt ra rồi."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hàn Vũ bắt đầu không ngừng đâm vào lồn của  \\n[1]. Là kẻ mới vào nghề, hắn chẳng có kỹ thuật gì, chỉ lỗ mãng đâm loạn xạ, khiến  \\n[1]  rên rỉ không ngừng."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1][P38]: Ưm, ưm, ưm, chậm lại! Đừng vào sâu thế… A a… chậm… a~~~"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hàn Vũ giữ chặt  \\n[1]. Thân thể họ quấn quýt vào nhau. Hơi thở nóng rực không ngừng quyện chặt. Chẳng mấy chốc, cả hai đều ướt đẫm mồ hôi."]}, {"code": 231, "indent": 1, "parameters": [1, "44-FZHYH2-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1][P39]: Ưm~~~~ Nóng quá~~~ Tan chảy mất."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hàn Vũ: Thì ra cơ thể nữ nhân là thế này？ Thoải mái quá, mềm mại quá. Cảm giác chỉ cần dùng lực thêm một chút là sẽ vỡ tan."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hàn Vũ trải nghiệm sự mềm mại của vách trong  \\n[1] và sự bao bọc của các nếp gấp lồi lên. Dâm thủy của cô làm ướt lồn. Mỗi lần đâm vào, nó lại kẹp chặt lấy côn thịt hắn, nhưng dâm thủy lại khiến hắn dễ dàng vào tới sâu nhất trong lồn cô."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hắn không muốn rời đi. Hắn muốn cảm nhận sự mềm mại này nhiều hơn nữa.  \\n[1]  đã sớm bị ham muốn này nuốt chửng, lắc lư eo theo nhịp chuyển động của Hàn Vũ."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Xoẹt, xoẹt~~~"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nơi họ kết hợp đã bắt đầu phát ra những âm thanh khiến tim đập thình thịch. Cả hai đắm chìm trong cuộc giao hoan này, không biết mệt."]}, {"code": 231, "indent": 1, "parameters": [1, "44-FZHYH2-4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hai người quấn quýt không chút kiêng dè.  \\n[1]  rên rỉ liên tục. Cả hơi thở của cô cũng mang mùi dâm dục. Cứ như chỉ có họ tồn tại giữa đất trời."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Thân thể họ va vào nhau. Từng đợt thịt rung động. Lồn cô bị vắt kiệt không thương tiếc. Dâm thủy không ngừng, không ngớt chảy ra."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1] [P42] chỉ cảm thấy côn thịt trong lồn cô càng lúc càng cứng. Quy đầu giật liên hồi, đẩy từng cơn nóng rực từ bụng dưới thẳng lên đỉnh đầu cô."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1][P42]: Ừm~~~~ Ta sắp lên đỉnh~~~~ Ta ra đây~~~~❤"]}, {"code": 231, "indent": 1, "parameters": [1, "44-FZHYH2-5", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 1, "parameters": [{"name": "Poison", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hàn Vũ: Tốt quá! Tuyệt quá! Đây… đây chính là cảm giác của cơ thể nữ nhân sao？!"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1][P42]: A a~~~ Bên trong bị rót đầy rồi! Bụng ta đầy tinh dịch đặc quánh."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hàn Vũ: Chưa đủ! Cho ta thêm nữa!"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]\\n[1][P42]: Ừm~~ Không còn nữa đâu~~~ Lồn ta sắp rách rồi~~~"]}, {"code": 122, "indent": 1, "parameters": [227, 227, 0, 0, 1]}, {"code": 111, "indent": 1, "parameters": [0, 15, 0]}, {"code": 357, "indent": 2, "parameters": ["FlyCat_LL_SceneMenu", "setTearPeople", "设置破处者", {"name": "Hàn Vũ", "variablesId": ""}]}, {"code": 657, "indent": 2, "parameters": ["破处者姓名 = Hàn Vũ"]}, {"code": 657, "indent": 2, "parameters": ["指定回传破处者姓名的变量 = "]}, {"code": 122, "indent": 2, "parameters": [4, 4, 1, 0, 5]}, {"code": 122, "indent": 2, "parameters": [24, 24, 1, 0, 5]}, {"code": 117, "indent": 2, "parameters": [17]}, {"code": 117, "indent": 2, "parameters": [18]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 411, "indent": 1, "parameters": []}, {"code": 122, "indent": 2, "parameters": [4, 4, 1, 0, 5]}, {"code": 122, "indent": 2, "parameters": [24, 24, 1, 0, 5]}, {"code": 117, "indent": 2, "parameters": [17]}, {"code": 117, "indent": 2, "parameters": [18]}, {"code": 0, "indent": 2, "parameters": []}, {"code": 412, "indent": 1, "parameters": []}, {"code": 221, "indent": 1, "parameters": []}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hàn Vũ không biết mệt mỏi điều khiển  \\n[1]  vào đủ loại tư thế.  \\n[1]  chỉ cảm thấy mình như một chiếc lá nhỏ trôi dạt giữa biển cả mênh mông. Trong sự lắc lư không ngừng, không dứt, nàng cảm thấy như eo mình sắp gãy đến nơi."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Hai chân nàng run rẩy không kiểm soát. Nàng đã không nhớ nổi mình đã lên đỉnh bao nhiêu lần. Giọng nàng khàn đặc và vỡ vụn, chỉ có thể phát ra những tiếng rên rỉ yếu ớt, đáng thương."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Còn bên ngoài căn phòng… một nhóm nữ tu của Hợp Hoan Tông đang xem với niềm thích thú vô cùng."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nữ Tu A: A… mà mình còn định giữ hắn làm của riêng cơ…"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nữ Tu B: Thảo nào lúc trước hắn cứ khăng khăng từ chối chúng ta… Thì ra trong lòng đã có người rồi."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nữ Tu A: Ăn không được… thì đành tiễn hắn đi vậy! Chứ cứ thế này thì nghẹn chết mất! Nhìn thân hình đó… cơ bắp kia…"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Nữ Tu B: Các sư huynh, sư đệ cũng có mà! Lần này cứ bỏ qua cho cô ta vậy. Nếu nàng ta còn đến nữa… nhất định phải để các sư huynh, sư đệ 'yêu thương' cô ta cho tốt."]}, {"code": 101, "indent": 1, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 1, "parameters": [""]}, {"code": 401, "indent": 1, "parameters": ["\\CT[1]Khi  \\n[1]  và Hàn Vũ tỉnh lại lần nữa… bọn họ đã ở bên ngoài Hợp Hoan Tông… …"]}, {"code": 201, "indent": 1, "parameters": [0, 144, 13, 49, 2, 0]}, {"code": 121, "indent": 1, "parameters": [713, 713, 0]}, {"code": 121, "indent": 1, "parameters": [659, 659, 0]}, {"code": 117, "indent": 1, "parameters": [52]}, {"code": 222, "indent": 1, "parameters": []}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [1, "Suy nghĩ đã"]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 404, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 1, "stepAnime": false, "through": false, "trigger": 0, "walkAnime": true}], "x": 7, "y": 6}], "parallaxLoopX": false, "parallaxLoopY": false, "parallaxName": "", "parallaxShow": true, "parallaxSx": 0, "parallaxSy": 0}