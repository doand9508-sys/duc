Valid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"tileId": 0, "characterName": "!Flame", "direction": 6, "pattern": 1, "characterIndex": 4}, "list": [{"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 4, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 4, "moveType": 1, "priorityType": 1, "stepAnime": false, "through": true, "trigger": 0, "walkAnime": true}], "x": 2, "y": 7}, {"id": 11, "name": "EV011", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"tileId": 0, "characterName": "!Flame", "direction": 6, "pattern": 1, "characterIndex": 4}, "list": [{"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 4, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 4, "moveType": 1, "priorityType": 1, "stepAnime": false, "through": true, "trigger": 0, "walkAnime": true}], "x": 11, "y": 11}, {"id": 12, "name": "Cốt truyện", "note": "", "pages": [{"conditions": {"actorId": 1, "actorValid": false, "itemId": 1, "itemValid": false, "selfSwitchCh": "A", "selfSwitchValid": false, "switch1Id": 1, "switch1Valid": false, "switch2Id": 1, "switch2Valid": false, "variableId": 1, "variableValid": false, "variableValue": 0}, "directionFix": false, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 0, "parameters": ["<qp:2,600,>Thiếu nữ: Vậy là… cuối cùng ta cũng chết rồi sao？"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 0, "parameters": ["Thân hình gầy guộc yếu ớt của thiếu nữ… như chiếc lá trong gió thu. Khuôn mặt vốn từng có chút hồng hào ửng đỏ, nay đã hoàn toàn trắng bệch, xanh xao như người chết. Đôi má hốc hác đến mức lõm cả vào trong."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 0, "parameters": ["Nàng vẫn còn nhớ… lúc bước vào Lưu phủ. Mình đã bị hành hạ ngược đãi ra sao. Đã phải hầu hạ Lưu lão gia trong vô vọng thế nào. Nàng cứ ngỡ cuộc đời mình sẽ mãi… mãi như thế. Nàng vốn nhút nhát, lại không giỏi ăn nói. Lẽ ra nàng không nên bị nhắm vào."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 0, "parameters": ["Nhưng… vì không được sủng ái đặc biệt… nên chẳng thể gửi được nhiều tiền về nhà. Cuối cùng, chị dâu đã đem hết mọi chuyện về nàng… và người thợ săn kia nói cho Lưu lão gia."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 0, "parameters": ["Bởi chị dâu phát hiện ra anh trai mình thật sự vô dụng. Sau khi nàng rời đi, phần lớn việc nhà đều đổ dồn lên đầu ả. Thế nhưng, bản thân ả lại sống khá thoải mái. Ả giận dữ. Bất chấp hậu quả, liền đi báo cho Lưu lão gia."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 0, "parameters": ["Và thế là… Lưu lão gia nổi cơn thịnh nộ… thậm chí chẳng buồn điều tra… đã nhốt nàng vào một căn phòng ọp ẹp, tồi tàn… rồi bỏ mặc cho nàng chết đói."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, ""]}, {"code": 401, "indent": 0, "parameters": ["<qp:2,600,>Thiếu nữ: Ta còn phải… trải qua một kiếp khác nữa sao？ Có nhất thiết… phải làm người nữa không？"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 1, ""]}, {"code": 401, "indent": 0, "parameters": ["Thiếu nữ chỉ cảm thấy sự căm phẫn không cam lòng và nỗi đau đớn thấm đẫm khắp cơ thể. Nàng sợ hãi… sợ rằng kiếp sau sẽ còn tồi tệ hơn. Một cuộc đời đắng cay đau khổ như thế… nàng thực sự không muốn nếm trải thêm một lần nào nữa."]}, {"code": 117, "indent": 0, "parameters": [53]}, {"code": 231, "indent": 0, "parameters": [1, "44-YSLH1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 0, "parameters": ["Cái chết… có thật sự là dấu chấm hết？ Tiên tử… liệu người có tin rằng một tu sĩ chết vì dục vọng của kẻ khác là chính đáng không？"]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 101, "indent": 0, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 0, "parameters": ["\\Face[11](Đây có lẽ là câu hỏi cuối cùng… Vậy ta nên trả lời thế nào đây？)"]}, {"code": 401, "indent": 0, "parameters": ["Đạo tâm hiện tại: \\C[10]\\V[675]\\C[0]"]}, {"code": 102, "indent": 0, "parameters": [["Nếu là điều chúng sinh mong mỏi… thì hy sinh bản thân vì đại nghĩa là chính đáng.", "Nếu chỉ là vì thể diện bề ngoài… thì ta tin rằng tuyệt đối không cần phải hy sinh bản thân vì ý thích nhất thời và lòng tự tôn của kẻ khác."], -1, 0, 1, 0]}, {"code": 402, "indent": 0, "parameters": [0, "Nếu là điều chúng sinh mong mỏi… thì hy sinh bản thân vì đại nghĩa là chính đáng."]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Điều mà chúng sinh mong mỏi… liệu có phải lúc nào cũng đúng？"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Hy sinh bản thân vì ý thích nhất thời của đám đông… Ai sẽ thèm biết ơn chứ？ Chẳng qua chỉ là sự tự tôn vinh bản thân mà thôi."]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Chẳng lẽ tiên tử cũng là người tìm kiếm sự tự tôn vinh bản thân như vậy sao？"]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Nếu đúng như thế… thì tiên tử thật đáng thương làm sao. Với Đạo tâm như vậy… liệu người có thực sự đi đến được tận cùng không？"]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 122, "indent": 1, "parameters": [675, 675, 2, 0, 15]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[2](Lời hắn nói… quả thực có vẻ đúng. Lòng ta… giờ đây có chút dao động rồi.)"]}, {"code": 401, "indent": 1, "parameters": ["Đạo tâm hiện tại: \\C[10]\\V[675]\\C[0]"]}, {"code": 117, "indent": 1, "parameters": [52]}, {"code": 201, "indent": 1, "parameters": [0, 303, 12, 12, 8, 0]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 402, "indent": 0, "parameters": [1, "Nếu chỉ là vì thể diện bề ngoài… thì ta tin rằng tuyệt đối không cần phải hy sinh bản thân vì ý thích nhất thời và lòng tự tôn của kẻ khác."]}, {"code": 231, "indent": 1, "parameters": [1, "44-YSLH4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "Yêu Tăng"]}, {"code": 401, "indent": 1, "parameters": ["Không tệ. Tiên tử quả thực có chút ngộ tính. Vậy thì, Đạo tâm của tiên tử hẳn là kiên định không lay chuyển rồi."]}, {"code": 235, "indent": 1, "parameters": [1]}, {"code": 101, "indent": 1, "parameters": ["", 0, 0, 2, "\\n[1]"]}, {"code": 401, "indent": 1, "parameters": ["\\Face[6](Một cảm giác bất an, kỳ quái dâng lên trong lòng… …)"]}, {"code": 117, "indent": 1, "parameters": [52]}, {"code": 201, "indent": 1, "parameters": [0, 303, 12, 12, 8, 0]}, {"code": 0, "indent": 1, "parameters": []}, {"code": 404, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": false, "through": false, "trigger": 3, "walkAnime": true}], "x": 13, "y": 3}], "parallaxLoopX": false, "parallaxLoopY": false, "parallaxName": "", "parallaxShow": true, "parallaxSx": 0, "parallaxSy": 0}