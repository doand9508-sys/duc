alse, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 357, "indent": 0, "parameters": ["TitleCg", "openLock", "解锁指定Cg", {"id": "85"}]}, {"code": 657, "indent": 0, "parameters": ["CgId = 85"]}, {"code": 223, "indent": 0, "parameters": [[-68, -68, 0, 68], 60, false]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Trong lúc mơ màng,  \\n[1] cảm thấy nhẹ bẫng, lâng lâng. Ngay cả ý thức cũng thấy mơ hồ, chóng mặt. Dường như có ai đó đang dắt tay nàng đi… …"]}, {"code": 222, "indent": 0, "parameters": []}, {"code": 241, "indent": 0, "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Trên con phố lớn náo nhiệt, đông đúc, một người phụ nữ bước đi với khuôn mặt vô cảm, loạng choạng không vững. Khiến người ta không khỏi lo lắng nhìn nàng."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Đám đông mỗi lúc một lớn hơn. Nàng ngước đôi mắt trống rỗng, vô hồn lên, có vẻ như hơi kháng cự, nhưng lại không thể từ chối."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Đám đông nhìn thoáng qua liền nghĩ: \"Ố! Đây chẳng phải là con mụ Bồ Tát dâm đãng hôm trước, cái con sẵn sàng khoe ngực cho mọi người xem sao？\""]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Lần này,  \\n[1] không chỉ để lộ ngực. Nàng còn vén váy lên, để lộ một đôi chân dài tuyệt mỹ, trắng như ngọc, và cái hũ mật mềm mại, trơn mượt, non mềm ấy. Điều này khiến đám đông hoàn toàn náo loạn."]}, {"code": 231, "indent": 0, "parameters": [1, "47-KZLCXX1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Cặp vú căng tròn đầy đặn, bắp đùi trắng nhợt, một đám đông xô bồ, cuồn cuộn."]}, {"code": 101, "indent": 0, "parameters": ["", 1, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Công Tử: Đẹp quá! Nếu có thể thọc sâu vào trong cái lồn nhỏ ấy, chắc chắn sẽ là chuyện tuyệt vời."]}, {"code": 101, "indent": 0, "parameters": ["", 3, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Thợ Rèn: Quá dâm đãng! Người phụ nữ này tuyệt đối không còn chút xấu hổ nào! Ngay cả gái điếm cũng không lộ liễu như ả."]}, {"code": 101, "indent": 0, "parameters": ["", 3, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Ăn Mày: Hahaha! Một người phụ nữ đẹp như tiên nữ. Được thấy nàng bị vấy bẩn… thật là tuyệt vời biết bao."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Tất cả những lời dâm ô của đám đông lọt vào tai \\n[1]. Điều đó chỉ khiến lòng \\n[1]cảm thấy kích động và bồn chồn. Một ham muốn vặn vẹo nào đó bắt đầu thức tỉnh từ sâu bên trong cơ thể nàng."]}, {"code": 231, "indent": 0, "parameters": [1, "47-KZLCXX2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Thèm khát được nhìn ngắm. Thấy vẻ mặt sốt ruột của họ, hũ mật của nàng bắt đầu tiết ra mật tình, chầm chậm chảy từ hũ mật xuống bắp đùi."]}, {"code": 101, "indent": 0, "parameters": ["", 1, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Công Tử: Nhìn kìa, mau lên! Con đĩ này thực sự bắt đầu rỉ nước rồi!"]}, {"code": 101, "indent": 0, "parameters": ["", 4, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Thầy Lang: Lão già này hành nghề y bao năm chưa thấy ai dâm đãng như thế này. Chỉ bị đám đông nhìn chằm chằm thôi cũng đủ khiến ả chảy nước. Thực sự quá dâm đãng."]}, {"code": 101, "indent": 0, "parameters": ["", 3, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Ăn Mày: Ta nói luôn bây giờ! Nếu nàng bằng lòng, ta nhất định sẽ làm thỏa mãn nàng bằng cái côn thịt cho bẩn thỉu của ta! Không người phụ nữ nào có thể cưỡng lại sự cám dỗ của cặc to!"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]\\n[1] nhìn những người này, từng người một đều nhìn nàng như những con sói đói lâu năm chưa thấy thịt."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Một số thậm chí bắt đầu tự sờ mó hạ thể của mình. Đặc biệt là tên ăn mày ấy - qua lớp áo quần mỏng, cũ nát, có thể thấy cái côn thịt đồ sộ của hắn."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Chỉ nghĩ đến đủ loại cặc cho nhỏ khác nhau thô bạo thọc vào hũ mật của mình… Một công chúa cao quý và là tu sĩ… thật là nhục nhã biết bao."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Sự sỉ nhục vô cùng ấy đi kèm với một cảm giác hồi hộp kỳ lạ không thể tả còn lớn hơn nữa. Bị vây quanh bởi đám đàn ông này, chỉ cần sơ sẩy một chút thôi là có thể bị chịch dữ dội."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Dù tâm trí nàng mụ mị và cơ thể đang bị người khác điều khiển… nhưng phản ứng của cơ thể là chân thực nhất."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Sự phô bày trắng trợn này, ngực và hũ mật phơi bày cho bất cứ ai xem… Chỉ nghĩ đến đó thôi đã khiến một luồng nhiệt lao thẳng xuống hũ mật nàng."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]\\n[1]: Aaaaaaaahhh~~~❤"]}, {"code": 231, "indent": 0, "parameters": [1, "47-KZLCXX3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Hết đợt khoái cảm này đến đợt khác dồn thẳng lên đỉnh đầu. Hũ mật nàng phun ra càng nhiều mật tình hơn."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Cơn cực lạc của cao trào khiến \\n[1] quên đi nỗi nhục nhã bị phô bày và vây quanh bởi đám đông."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Lúc này, đám đông không thể nhịn được nữa. Họ xông tới hàng loạt, sờ soạng và mơn trớn khắp người \\n[1] ."]}, {"code": 231, "indent": 0, "parameters": [2, "35-XX2-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [2, "35-XX2-2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [2, "35-XX2-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [2, "35-XX2-2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [2, "35-XX2-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [2, "35-XX2-4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]\\n[1]: Aaaahhh~~~❤"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Nghe tiếng rên rỉ của \\n[1], hạ thể của đám đông càng trở nên đau đớn vì cương cứng. Kẻ nào cũng ước gì có thể đè \\n[1] xuống ngay tại chỗ mà âu yếm nàng một cách đàng hoàng."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Giờ thì, tên thợ rèn đã đưa tay ra và thọc những ngón tay thô ráp, chai sạn của hắn vào cái hũ mật mềm mại, non mướt của \\n[1]."]}, {"code": 231, "indent": 0, "parameters": [2, "35-RX1-2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [2, "35-RX1-2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [2, "35-RX1-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [2, "35-RX1-4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]\\n[1]: Aaaaaaaahhh~~~❤❤❤"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Lúc này, đã có kẻ kéo quần xuống, phơi bày côn thịt của mình, sẵn sàng lên tiên và hưởng lạc thú tột đỉnh."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Nhưng rồi, họ chỉ cảm thấy một cơn choáng váng và mất phương hướng. Khi tỉnh dậy,  \\n[1] đã biến mất."]}, {"code": 221, "indent": 0, "parameters": []}, {"code": 235, "indent": 0, "parameters": [2]}, {"code": 235, "indent": 0, "parameters": [1]}, {"code": 122, "indent": 0, "parameters": [4, 4, 1, 0, 4]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]\\n[1] Cảm thấy như mình vừa mới ngủ vậy. Nàng mơ màng mở mắt ra thì thấy trời đã sáng."]}, {"code": 121, "indent": 0, "parameters": [652, 652, 1]}, {"code": 121, "indent": 0, "parameters": [18, 18, 1]}, {"code": 117, "indent": 0, "parameters": [53]}, {"code": 117, "indent": 0, "parameters": [9]}, {"code": 121, "indent": 0, "parameters": [325, 325, 1]}, {"code": 201, "indent": 0, "parameters": [0, 93, 5, 4, 2, 0]}, {"code": 211, "indent": 0, "parameters": [1]}, {"code": 223, "indent": 0, "parameters": [[0, 0, 0, 0], 60, false]}, {"code": 222, "indent": 0, "parameters": []}, {"code": 0, "indent": 0, "parameters": []}], "moveFrequency": 3, "moveRoute": {"list": [{"code": 0, "parameters": []}], "repeat": true, "skippable": false, "wait": false}, "moveSpeed": 3, "moveType": 0, "priorityType": 0, "stepAnime": false, "through": false, "trigger": 3, "walkAnime": true}], "x": 9, "y": 2}], "parallaxLoopX": false, "parallaxLoopY": false, "parallaxName": "LCJQDT1", "parallaxShow": true, "parallaxSx": 0, "parallaxSy": 0}