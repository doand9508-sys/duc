d": false, "variableValue": 0}, "directionFix": false, "image": {"characterIndex": 0, "characterName": "", "direction": 2, "pattern": 0, "tileId": 0}, "list": [{"code": 117, "indent": 0, "parameters": [115]}, {"code": 357, "indent": 0, "parameters": ["TitleCg", "openLock", "解锁指定Cg", {"id": "212"}]}, {"code": 657, "indent": 0, "parameters": ["CgId = 212"]}, {"code": 241, "indent": 0, "parameters": [{"name": "DHCM1_BGM02_Opening1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-1", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Một ngày mới lại bắt đầu. Trong một con hẻm nhỏ, thiếu nữ từng muốn báo thù… giờ đây dang rộng hai chân, toàn thân dơ bẩn. Từ miệng nàng, ngoài những tiếng 'A a' vô thức, không còn gì thoát ra."]}, {"code": 222, "indent": 0, "parameters": []}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Như thể trời cao không còn che chở cho nàng nữa. Chẳng bao lâu, ngày càng nhiều người kéo đến."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Họ lôi ra những cây gậy đã khát khao từ lâu, đầy nóng vội. Dù người phụ nữ trước mặt đang mang thai và hoàn toàn ô uế."]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-2", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Là đám cặn bã xã hội, chỉ cần có niềm vui, ai quan tâm nàng trong tình trạng nào？ Miễn là nàng chưa chết… là được."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Như thể trời cao không còn che chở cho nàng nữa. Chẳng bao lâu, ngày càng nhiều người kéo đến."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Rất nhanh, có kẻ bước đến, túm lấy bắp chân của  \\n[1] và hung hăng đâm vào."]}, {"code": 250, "indent": 0, "parameters": [{"name": "1-NZCR", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 0, "parameters": [{"name": "1-NZSFH1", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Đàn ông A: Tối qua, nó không còn kêu được nữa. Giọng đã khàn đặc. Thế mà hôm nay chơi nó một lúc, lại bắt đầu rên rỉ."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Đàn ông B: Đúng, đúng! Xứng đáng là tu sĩ. Sức bền của nó thật khó tin."]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Đàn ông C: Dù sao cũng không chết được, lại còn đẻ con cho chúng ta. Hoàng đế quả là một người đàn ông tuyệt vời!"]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Đàn ông A: Phải không？! Người phụ nữ xinh đẹp đáng yêu thế này… cứ thế mà ban cho chúng ta. Này, ngươi—nhanh lên! Ta cũng muốn đến lượt!"]}, {"code": 250, "indent": 0, "parameters": [{"name": "4-DLPYH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-4", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 250, "indent": 0, "parameters": [{"name": "1-NZSFH2", "volume": 90, "pitch": 100, "pan": 0}]}, {"code": 101, "indent": 0, "parameters": ["", 0, 1, 2, ""]}, {"code": 401, "indent": 0, "parameters": [""]}, {"code": 401, "indent": 0, "parameters": ["\\CT[1]Đàn ông C: Đồ đĩ thối! Rên rỉ mặt trờig sướng thế… định quyến rũ ai đây？!"]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-3", 0, 0, 0, 0, 100, 100, 255, 0]}, {"code": 230, "indent": 0, "parameters": [30]}, {"code": 231, "indent": 0, "parameters": [1, "11-HJJ1-4", 0, 0, 0, 0, 100, 100, 255, 0]