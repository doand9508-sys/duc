:["\\CT[1]Cặp vú đầy đặn, núng nính và những đầu vú hồng hào, mềm mại ấy khiến người ta không thể rời mắt."]},{"code":101,"indent":0,"parameters":["",1,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Con Quan: Lại là ả đó! Thực sự quá dâm đãng! Ả không biết xấu hổ là gì sao？!"]},{"code":101,"indent":0,"parameters":["",3,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Thợ Rèn: A! Ta không chịu nổi nữa! Ả đang quyến rũ ta! Lần này, nhất định phải sờ mó đàng hoàng cặp vú dâm đãng này!"]},{"code":101,"indent":0,"parameters":["",3,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Ăn Mày: Ta nữa! Ta nữa! Đã như vậy rồi, thì ngay cả loại như ta chắc cũng được đúng không？ Hahaha~~~ Hôm nay đúng là có phúc."]},{"code":101,"indent":0,"parameters":["",1,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Con Quan: Cút đi! Ta là người đầu tiên!"]},{"code":101,"indent":0,"parameters":["",3,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Thợ Rèn: Công tử! Với nắm đấm sắt cứng của ta, ta khuyên cậu nên tránh ra!!!"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Đám đông hiểu ra. Dù họ có làm gì đi nữa, người phụ nữ này cũng sẽ không chống cự. Vậy thì ai có thể nhịn được đây？"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Như những con sói đói, mắt đỏ ngầu, thở hồng hộc, chúng hoàn toàn vây kín \\n[1]."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1] muốn chạy trốn, nhưng nàng không thể nào thoát ra được. Nàng chỉ có thể nhắm mắt và phớt lờ những người đang xông tới. Đám 