{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Ngay lúc đó, bóng người xuất hiện ở cửa cung điện, la hét điều gì đó, không ngừng đập và lao vào cánh cửa."]},{"code":250,"indent":0,"parameters":[{"name":"Close2","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[30]},{"code":250,"indent":0,"parameters":[{"name":"Close2","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Bầu không khí vốn đã căng thẳng càng thêm điên cuồng. Những năm gần đây thua trận liên tiếp, việc bắt lính liên miên, thậm chí cả bọn du côn cũng bị kéo vào."]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Dù quân số tăng lên, nhưng chất lượng binh lính giảm sút dần. Vốn đã có lời đồn về việc quan quân xông vào nhà dân, nhưng không thể ngờ chúng dám xông vào cung điện."]},{"code":231,"indent":0,"parameters":[1,"13HG4",0,0,0,0,100,100,255,0]},{"code":231,"indent":0,"parameters":[2,"2-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"Hoàng hậu Bai Piaopiao"]},{"code":401,"indent":0,"parameters":["Yue'er, chạy nhanh đi."]},{"code":231,"indent":0,"parameters":[2,"1-XSH",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["Mẹ…"]},{"code":250,"indent":0,"parameters":[{"name":"Close2","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[30]},{"code":250,"indent":0,"parameters":[{"name":"Close2","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":0,"parameters":[1,"13HG4",0,0,0,0,100,100,255,0]},{"code":231,"indent":0,"parameters":[2,"2-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"Hoàng hậu Bai Piaopiao"]},{"code":401,"indent":0,"parameters":["Đừng sợ. Mẹ có cách của mẹ, rồi sẽ đuổi kịp Yue'er."]},{"code":101,"indent":0,"parameters":["",0,0,2,"Hoàng hậu Bai Piaopiao"]},{"code":401,"indent":0,"parameters":["Vậy, Yue'er, đi ngay đi. Đừng ngoái lại. Mẹ sẽ dõi theo bóng lưng con.\\C[0]"]},{"code":231,"indent":0,"parameters":[2,"1-XSH",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["Mẹ…"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["Con hiểu rồi. Mẹ nhất định phải theo sau nhé."]},{"code":250,"indent":0,"parameters":[{"name":"Open1","volume":90,"pitch":100,"pan":0}]},{"code":250,"indent":0,"parameters":[{"name":"Close1","volume":90,"pitch":100,"pan":0}]},{"code":235,"indent":0,"parameters":[2]},{"code":111,"indent":0,"parameters":[0,10,0]},{"code":231,"indent":1,"parameters":[2,"HS",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["Cô gắng hết sức kìm nén cơn thôi thúc ngoái đầu lại trong lòng."]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["\\n[1]Nàng đã sớm mắt ướt lệ, lao nhanh về phía trước."]},{"code":201,"indent":1,"parameters":[0,3,15,5,2,0]},{"code":235,"indent":1,"parameters":[2]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["Nói xong, \\n[1] chạy không ngoái đầu, chỉ nghe thấy sau lưng giọng nói quyến rũ của mẹ mình."]},{"code":250,"indent":1,"parameters":[{"name":"Splash","volume":90,"pitch":100,"pan":0}]},{"code":241,"indent":1,"parameters":[{"name":"DHCM1_BGM02_Opening1","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":1,"parameters":[1,"13HG3",0,0,0,0,100,100,255,0]},{"code":231,"indent":1,"parameters":[2,"2-LH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nữ Hoàng Bai Piaopiao: Vương gia muốn gì cũng được. Chỉ cần Vương gia khao khát, Vương gia có thể có nó ngay lập tức."]},{"code":235,"indent":1,"parameters":[2]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Trong ánh nến mờ ảo, bước chân của những người đàn ông dừng lại. Người phụ nữ trước mặt họ run rẩy nhẹ, nhưng vẫn vươn tay và tự mở y phục của mình ra."]},{"code":231,"indent":1,"parameters":[2,"2-CG1",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Vóc dáng tinh xảo và khuôn mặt lộng lẫy ấy khác xa mọi thứ những người đàn ông từng thấy. Vào lúc này, mọi người đều hiểu ý nghĩa lời nói của bà."]},{"code":231,"indent":1,"parameters":[2,"2-CG2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Chờ đợi đám đông là một bữa tiệc thơm tho và xinh đẹp. Những người đàn ông đặt vũ khí xuống, từng người một bước về phía người phụ nữ."]},{"code":235,"indent":1,"parameters":[1]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ1",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nữ Hoàng Bai Piaopiao: Ah~~ Tất cả các ngươi, nhẹ nhàng thôi~~"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Lính Nổi Loạn Zhou Da: Được lên giường với Nữ Hoàng của một quốc gia… dù có chết vào giây tiếp theo, cũng đáng."]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Đám đông, những tên côn đồ tạp nham bị bắt đi lính để canh giữ Hoàng Thành, giờ đây phải đối mặt với một quốc gia sụp đổ và chính mạng sống của chúng đang lâm nguy. Những ý nghĩ xấu xa nổi lên không thể kiểm soát, những con cặc bẩn thỉu của chúng áp sát vào Nữ Hoàng."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nữ Hoàng Bai Piaopiao: Chậm thôi~~ Bản cung sẽ thỏa mãn tất cả các ngươi."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Giọng nói quyến rũ đó mê hoặc tâm hồn họ, ai cũng khao khát được cắm vào cơ thể bà và nếm trải thân hình chín muồi, gợi cảm này."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Lính Nổi Loạn Wang Xi: Ta luôn nghĩ Nữ Hoàng Lục Quốc là một người phụ nữ mạnh mẽ, nhưng hóa ra cũng chỉ là một con đĩ."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Lính Nổi Loạn Li Yu: Ha, đây thực sự là Nữ Hoàng sao？ Sao lại hành xử như một con điếm vậy？ Chỉ nghĩ đến việc đàn bà của Hoàng Đế giờ đây hành xử như một con điếm thực thụ thôi cũng khiến ta cương cứng hết cả lên rồi."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Lính Nổi Loạn Zhou Da: Tuy Công Chúa Yue'er xinh đẹp, nhưng Nữ Hoàng này thật lộng lẫy tuyệt trần, khiến người ta không thể rời mắt."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nhiều năm được nuông chiều ẩn cư trong nội cung, vóc dáng duyên dáng ấy từ lâu đã khiến cặc lũ đàn ông cứng không chịu nổi. Nữ Hoàng, mang trong lòng ý định cho phép con gái mình trốn thoát, tự nhiên trút bỏ tôn nghiêm và không hề kháng cự."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nữ Hoàng Bai Piaopiao: Hừm~~ Có bản cung rồi, các ngươi còn nghĩ đến con nhóc ngây thơ đó sao？ Làm sao nó có thể biết cách phục vụ đàn ông như bản cung chứ？"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Lính Nổi Loạn Wang Xi: Ơ, miệng của Nữ Hoàng nói ngọt thật đấy. Được rồi, anh em, đừng khách sáo nữa."]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ3",0,0,0,0,100,100,255,0]},{"code":250,"indent":1,"parameters":[{"name":"4-DLPYKJ","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Con cặc hôi hám đâm vào miệng bà. Trước khi Nữ Hoàng kịp thốt ra một lời, bà đã bị đâm không thương tiếc. Đám đông sờ soạng khắp cơ thể chín muồi, trêu ngươi của bà; xúc giác mềm mại ấy khiến họ càng thêm say mê trong hành động."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nữ Hoàng Bai Piaopiao: (Từ khi sinh ra Thái Tử, Bệ Hạ hiếm khi đến thăm ta… Ta…)"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Cảm nhận phản ứng của cơ thể mình, lồn mình đang rỉ dịch tình yêu, lưỡi bà bắt đầu liếm láp con cặc hôi hám đó. Những người đàn ông bên cạnh không thể kiềm chế thêm được nữa."]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ4",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Lính Nổi Loạn Li Yu: Nữ Hoàng của một quốc gia cái gì？ Hóa ra cũng chỉ là một con đĩ."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nói rồi, con cặc hắn tàn nhẫn cắm phập vào lồn của Nữ Hoàng Bai Piaopiao."]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ5",0,0,0,0,100,100,255,0]},{"code":250,"indent":1,"parameters":[{"name":"2-SFCR","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Một cái lồn đã lâu không được dùng đến, dù đã sinh con, vẫn có phần khít. Hơn nữa, Nữ Hoàng vẫn đang trong thời kỳ đỉnh cao rực rỡ của mình."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nữ Hoàng Bai Piaopiao: (Hừm… to quá… đau quá… không… mình đang nghĩ gì vậy… chỉ cần Yue'er có thể trốn thoát, ta sẽ làm bất cứ điều gì.)"]},{"code":250,"indent":1,"parameters":[{"name":"4-PPH1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nghĩ vậy, những người đàn ông trên người bà vẫn không thể không hung hăng thúc mạnh. Có lẽ đây là điều cuối cùng họ từng làm trong đời."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Như những con thú hoang, họ nuốt chửng người phụ nữ bên dưới, để lại khắp cơ thể bà những dấu ấn thuộc về họ. Như thể qua việc này, họ vẫn có thể cảm thấy mình còn sống trên cõi trần tục này."]},{"code":250,"indent":1,"parameters":[{"name":"2-SFQPH1","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ6",0,0,0,0,100,100,255,0]},{"code":230,"indent":1,"parameters":[30]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ5",0,0,0,0,100,100,255,0]},{"code":230,"indent":1,"parameters":[30]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ6",0,0,0,0,100,100,255,0]},{"code":231,"indent":1,"parameters":[2,"2-KJLJ8",0,0,0,0,100,100,255,0]},{"code":250,"indent":1,"parameters":[{"name":"Poison","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,