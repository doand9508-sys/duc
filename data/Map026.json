oveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":12,"y":12},{"id":6,"name":"EV006","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"!Flame","direction":4,"pattern":0,"characterIndex":7},"list":[{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["                                        —Kỳ Văn Tu Tiên Giới Kỳ San—"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Tương truyền Tông chủ Linh Thú Tông, Vạn Thành Hào, có dung mạo cực kỳ tuấn mỹ, là vẻ đẹp thanh tú mang nét nữ tính, chỉ nhìn từ xa thôi đã thấy đẹp tựa nữ nhân."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Tông chủ Vạn rời tông môn tìm kiếm cơ duyên đột phá, tình cờ gặp được đệ nhị mỹ nhân tu tiên giới, Dao Hoa tiên tử, hai người vừa gặp đã yêu, quyết định cùng nhau nhập thế lịch luyện."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Hai người đi tới thôn phàm trần Đào Hoa Thôn, cải trang thành một đôi phu thê bình thường mộc mạc. Ban đầu thôn dân còn hơi bàn tán về sự xuất hiện của bọn họ."]},{"code":401,"indent":0,"parameters":["Nhưng lâu ngày, mọi người đều thực lòng đối đãi chân thành với đôi phu thê."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Dù Tông chủ Vạn cực kỳ thông minh, cũng không ngờ rằng trong Đào Hoa Thôn lại ẩn giấu một Ma Tu, kẻ này từ lâu đã thèm muốn Dao Hoa tiên tử."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Gã liếc mắt đã nhìn thấu phép thuật cải trang của Dao Hoa, chỉ chờ thời cơ. Đúng ngày tiệc đầy tháng đứa con đầu lòng của đôi phu thê,"]},{"code":401,"indent":0,"parameters":["phu thê mở tiệc chiêu đãi toàn bộ người trong thôn. Kết cục không ai ngờ tới là Tông chủ Vạn bị phế bỏ, Dao Hoa tiên tử cùng hài tử không rõ tung tích."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Đồn rằng Ma Tu ấy dùng tà thuật khống chế Thôn trưởng, hạ độc rượu, còn dụ dỗ tỷ muội kết nghĩa của Dao Hoa tiên tử trong thôn."]},{"code":401,"indent":0,"parameters":["Nữ tử đó là kẻ đáng thương, bị trượng phu ghẻ lạnh, phòng không chiếc bóng. Tên Ma Tu kia tinh thông thuật phòng the, khiến ả sa vào bẫy."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Đêm đó, tất cả nam nhân dự tiệc đều mê man. Còn các nữ nhân, liệu có chung cảnh ngộ không thì không rõ, chỉ biết mỗi người đều có chút dị thường."]},{"code":401,"indent":0,"parameters":["Về phần tỷ muội của Dao Hoa tiên tử, nghe đồn cuối cùng phải vào kỹ viện của Hoan Hợp Tông. Giá cả phải chăng, đêm nào cũng không ngủ được."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":6},{"id":7,"name":"EV007","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"!Flame","direction":4,"pattern":0,"characterIndex":7},"list":[{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["                                          —Linh Căn—"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Linh Căn là thứ duy nhất phân biệt phàm nhân và tu sĩ."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Linh Căn được phân loại theo số lượng thuộc tính ngũ hành. Ngũ Linh Căn (Kim, Mộc, Thủy, Hỏa, Thổ) và Tứ Linh Căn đều là Ngụy Linh Căn, người sở hữu loại linh căn này chỉ khá hơn người thường một chút, có thể tu luyện nhưng tốc độ cực chậm."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Phần lớn đều chết già ở cảnh giới Luyện Khí, tuổi thọ hết trước khi tốc độ tu luyện theo kịp."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Tiếp theo là Tam Linh Căn, nhìn qua thì có vẻ khá hơn hai loại trước, nhưng tốc độ tu luyện vẫn rất chậm, đa phần những tu sĩ này đều dừng bước ở cảnh giới Trúc Cơ."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Những người sở hữu Song Linh Căn lại là kẻ may mắn, thường được các đại tông môn thu làm Nội Môn Đệ Tử để trực tiếp dạy dỗ."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Tiếp đến là những người có Đơn Linh Căn, họ nhận được rất nhiều tài nguyên tốt nhất của tông môn, mục đích là đào tạo thành siêu cấp cao thủ để sau này bảo vệ tông môn."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Những người này dễ dàng trở thành thân truyền đệ tử cuối cùng của các trưởng lão tông môn."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Tuy nhiên, trên cả những thứ đó còn có Dị Linh Căn: Phong, Lôi, Băng, ba loại này cực kỳ hiếm gặp, khi kết hợp với công pháp phù hợp, uy lực lớn hơn hẳn Ngũ Hành Linh Căn."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Rồi còn có Thiên Linh Căn còn hiếm hơn nữa, thật sự là thiên chi kiêu tử, tốc độ tu luyện ngày ngàn dặm, khi đột phá cảnh giới hiếm khi gặp Tâm Ma."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":true}],"x":14,"y":6},{"id":8,"name":"EV008","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":18,"y":5},{"id":9,"name":"EV009","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"!Flame","direction":4,"pattern":0,"characterIndex":7},"list":[{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["                                        — Lô Đỉnh —"]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Lô Đỉnh là một loại thể chất, chủ yếu tồn tại ở nữ tu."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Những tu sĩ này phần lớn là Thủy Linh Căn, bởi linh khí hệ Thủy ôn hòa thích hợp để mọi linh căn hấp thu."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Đúng vậy, cái gọi là Lô Đỉnh tức là linh khí của mình có thể bị các tu sĩ khác thông qua Song Tu mà chiếm đoạt lấy."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Nhờ vậy tăng cường linh lực cho tu sĩ khác, thậm chí trong một số tình huống còn có thể giúp kẻ đó đột phá bình cảnh."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Nhưng nữ tu làm Lô Đỉnh sẽ bị giảm mạnh tu vi, nhỡ gặp phải kẻ không ra gì còn có thể nguy hiểm đến tính mạng."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Vì thế có rất ít nữ tu muốn nói cho người khác biết mình là thể chất Lô Đỉnh, đa số đều giấu kín thân phận này."]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Nhưng nghe nói Hoan Hợp Tông có một môn bí thuật, có thể giúp Lô Đỉnh cũng hấp thu tu vi của tu sĩ khác."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":true}],"x":11,"y":6},{"id":10,"name":"EV010","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":19,"y":5},{"id":11,"name":"EV011","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"sel