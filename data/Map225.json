":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]: Công tử, người thấy nô tỳ có đẹp không？"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Nhị Đại Giàu: A, tiểu nương tử đẹp lắm, đẹp lắm. Tiểu nương tử, nàng đang… …"]},{"code":231,"indent":0,"parameters":[1,"47-KZLUXX3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Nhị Đại Giàu chưa kịp nói hết, hắn đã thấy có thêm nhiều người tiến vào."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Thợ Rèn: Là đồ đĩ! Một con đĩ ướt nhẹp! Cặp vú khổng lồ ấy, cái mông to ấy! Con đĩ, muốn cặc của ông nội không hả？!"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Nhị Đại Giàu cau mày khó chịu. Ngay lúc này… …"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]: Chưa đủ đâu, thêm chút nữa đi~~~❤"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1] lên tiếng một cách nũng nịu, giọng nói quyến rũ và cám dỗ. Khiến cho gã đàn ông mới tới không thể kiểm soát bản thân, muốn lao vào nàng ngay lập tức."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Ngay khi nàng vừa dứt lời, một người khác lại bước vào."]},{"code":231,"indent":0,"parameters":[1,"47-KZLUXX4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Những kẻ đi theo không biết chuyện cũng vào theo. Càng ngày càng có nhiều người bị thu hút lại."]},{"code":231,"indent":0,"parameters":[1,"47-KZLUXX5",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1] nhìn thấy đông người như vậy không khỏi cảm thấy chân nhũn ra. Nghĩ tới những gì sắp xảy ra tiếp theo, tim nàng đập nhanh liên hồi."]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Tần Chính Kinh: Tiên tử, xin hãy nghe theo ham muốn của lòng mình~~~ Món đồ chơi đáng yêu của ta, mang đến cho ta niềm vui lớn hơn đi nào."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]Trái tim của, vốn bị ràng buộc bởi đạo đức thường ngày, đã vỡ vụn rồi. Chỉ có cực lạc của tình dục mới khiến nàng cảm thấy vui sướng."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1] nhấc chân lên, để lộ cái lồn mềm mại và lỗ đít hồng hào, non mềm của mình, cho tự do bất cứ kẻ nào muốn hái."]},{"code":231,"indent":0,"parameters":[1,"47-KZLULJ1",0,0,0,0,100,100,255,0]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Nhị Đại Giàu, kẻ đã vào trước đó, đã sớm trút bỏ quần áo trần truồng. Cặc của hắn đã dựng đứng được một lúc, chỉ chờ để tiến vào lồn nàng mà thúc mạnh."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]: Hãy vào trong đi, thọc mạnh vào nô tỳ đi ❤"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Nhị Đại Giàu: Đúng là xứng đáng là một con đĩ, thật dâm đãng. Xem ta làm cho con đĩ nhỏ này quằn quại trong cực lạc đây."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Nói rồi, Nhị Đại Giàu thúc mạnh vào lồn của \\n[1]. Hắn chỉ cảm thấy côn thịt của mình bị hút chặt vào trong lồn nàng, bị thành trong của nàng quấn chặt lấy."]},{"code":231,"indent":0,"parameters":[1,"47-KZLULJ2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]: Thật tuyệt vời. Cặc của công tử thật to và dày. Nô tỳ thích quá. Xin hãy chịch nô tỳ thật mạnh đi."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Nhị Đại Giàu: Đồ đĩ! Xem công tử đây dùng côn thịt to này tàn phá lồn ngươi thế nào đây."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Hắn vừa nói, vừa hung hãn bắt đầu thúc. Cùng lúc đó, một gã đàn ông khác cũng sốt sắng lao tới."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Thợ Rèn: Đồ đĩ! Chỉ một bên chắc cô đơn lắm nhỉ？ Ta đến đây!!!"]},{"code":231,"indent":0,"parameters":[1,"47-KZLULJ3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Côn thịt dày, đồ sộ của hắn áp vào lỗ đít của \\n[1], háo hức muốn được thọc vào ngay lập tức."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\n[1]: A~~~ Hảo ca ca, mau vào trong đi~~~"]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameter