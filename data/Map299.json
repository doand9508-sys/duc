ons":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:1,600,>Cô gái: Anh trai! Em van anh… đó là sính lễ nhà họ Lưu gửi tới. Nếu anh dùng nó… em chắc chắn phải gả vào nhà họ rồi."]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>Anh trai: Thì đã sao？ Vẫn còn nghĩ đến gã thợ săn nghèo của mày à？ Nằm mơ đi! Mày sinh ra… chỉ là vì tao thôi. Nếu mày không xinh đẹp thế này… tao đã để mày chết từ hồi bị bệnh rồi!"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>Anh trai: Tiền chữa bệnh cho mày… đều là tiền tao tiết kiệm để cưới vợ đấy!!"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>Anh trai: Mà mày còn muốn gả cho gã thợ săn nghèo đó ư？! ĐỪNG CÓ MƠ!!!"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:1,600,>Cô gái:(Tại sao…？ Em đã trả hết tiền cho anh trai rồi mà… Tại sao… lại đối xử với em như vậy…？)"]},{"code":117,"indent":0,"parameters":[53]},{"code":231,"indent":0,"parameters":[1,"44-YSLH1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":0,"parameters":["Nghèo đói, song hành cùng bệnh tật… đây chính là cuộc sống. Nếu ngươi là cô bé ấy… ngươi sẽ lựa chọn thế nào？"]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[2](Không thể đạt được… Ta không thể suy nghĩ theo hướng này. Nếu là ta… nên xử lý thế nào đây？)"]},{"code":401,"indent":0,"parameters":["Đạo tâm hiện tại: \\C[10]\\V[675]\\C[0]"]},{"code":102,"indent":0,"parameters":[["Nhẫn nhịn. Hạ độc giết cả nhà.","Đứng lên ngay bây giờ, cùng chết với anh trai."],-1,0,1,0]},{"code":402,"indent":0,"parameters":[0,"Nhẫn nhịn. Hạ độc giết cả nhà."]},{"code":231,"indent":1,"parameters":[1,"44-YSLH3",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":1,"parameters":["Quả thật… khi chênh lệch sức mạnh quá lớn, hành động ngay lúc này chỉ là sự liều lĩnh. Đối mặt với gia đình như vậy… hạ độc họ có phần quá tàn nhẫn."]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[12]Nhưng gia đình cô ta có từng coi cô ta là người nhà không？ Trong thế giới tu tiên, kẻ mạnh nuốt kẻ yếu. Người phàm đều là thánh nhân sao？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":1,"parameters":["Điều ngươi nói… cũng không sai hoàn toàn？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[5]Lấy ân báo oán… theo ta thấy… chẳng qua chỉ là sự thỏa hiệp của những kẻ không có sức mạnh để báo thù."]},{"code":231,"indent":1,"parameters":[1,"44-YSLH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":1,"parameters":["Ngươi nói rất đúng. Vậy ta tiếp tục vòng luận đạo tiếp theo."]},{"code":235,"indent":1,"parameters":[1]},{"code":117,"indent":1,"parameters":[52]},{"code":201,"indent":1,"parameters":[0,300,13,10,8,0]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"Đứng lên ngay bây giờ, cùng chết với anh trai."]},{"code":231,"indent":1,"parameters":[1,"44-YSLH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":1,"parameters":["Ngươi thực sự cho rằng một cô gái với sức mạnh như cô ta có thể thắng ngay lúc này sao？ Ở đây không có công cụ gì có thể dùng được."]},{"code":2