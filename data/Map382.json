ndent":1,"parameters":[{"name":"DHCM1_BGM02_Opening1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Cơ thể phụ nữ trần truồng hoàn toàn của cô ấy còn đầy đặn hơn trước. Thuật bí truyền của Hợp Hoan Tông tăng thêm vẻ quyến rũ dâm đãng. Ngay cả vị Sư huynh đã tu luyện nhiều năm cũng bị dục vọng khuấy động."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Hee hee. Sư huynh… lại đây."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1] cười khúc khích và lao vào vòng tay của Sư huynh. Sau một hồi quằn quại, nàng ngồi lên người chàng, đặt mình lên cây gậy đã cứng như đá của chàng. Chỉ một động tác, nàng đâm sâu vào trong."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Ah~ Của Sư huynh to quá! Nó vào hết luôn rồi! Em không chịu nổi nữa! Sướng quá đi!"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Trước khi nàng kịp có động tác gì thêm, một bàn tay khác từ phía sau túm lấy cánh tay nàng, rõ ràng là không hài lòng vì bị bỏ rơi."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Aiya! Là lỗi của em đã hờ hững với Sư huynh. Mau, vào trong đi."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1] nhẹ nhàng banh mông nàng ra, để lộ cửa sau hồng hào, mỏng manh. Cây gậy từ phía sau trượt dọc sống lưng nàng xuống tận eo."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Rồi, dưới sự dẫn đường của nàng, nó không chút do dự đâm vào lối đi chật hẹp đó. Hai con cặc to lớn, chỉ cách nhau bởi một lớp thịt mỏng manh, nhồi đầy cả hai lỗ của nàng."]},{"code":231,"indent":1,"parameters":[1,"59-HHZYYJJH2-1",0,0,0,0,100,100,255,0]},{"code":222,"indent":1,"parameters":[]},{"code":250,"indent":1,"parameters":[{"name":"1-NZCR","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: …Các Sư huynh… của các huynh to quá… Không vừa nữa rồi… Cơ thể của Tiểu muội sắp vỡ ra rồi…"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bàn tay to lớn phía sau mạnh mẽ kéo ngược cơ thể nàng về sau. Mỗi cú thúc của cây gậy trong cửa sau kéo ra một tiếng rên rỉ uyển chuyển, quyến rũ."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Vị Sư huynh bên dưới nàng cũng không chịu thua kém. Chàng vòng tay ôm lấy eo nàng đang lắc lư, chuyển động như pít-tông và cũng bắt đầu vận động mạnh bạo lên xuống. Không thương tiếc, chàng còn ngậm lấy núm vú hồng hào của nàng, mút mạnh bạo."]},{"code":250,"indent":1,"parameters":[{"name":"1-NZSFH1","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":1,"parameters":[1,"59-HHZYYJJH2-2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Aaaaaaaahhh! Nhẹ! Nhẹ thôi! Sướng quá! Sư huynh… nhẹ-… a! Không! Đừng! Huynh làm em vỡ ra rồi! Huynh làm em chết mất!"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]*Bạch bạch bạch bạch bạch bạch bạch*"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Tiếng kêu trêu ghẹo, khiêu khích của nàng chỉ càng kích thích thêm hai vị Sư huynh. Lực và tốc độ thúc đẩy chỉ tăng lên. \\n[1]'s má đỏ bừng. Nàng nhắm mắt, đắm chìm trong dục vọng của hai vị Sư huynh."]},{"code":250,"indent":1,"parameters":[{"name":"2-NZQJH2","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Mỗi khi lên đỉnh, nàng sẽ rên rỉ không kiềm chế. Mái tóc trắng như tuyết của nàng cũng lắc lư và tung bay theo mỗi cú thúc."]},{"code":231,"indent":1,"parameters":[1,"59-HHZYYJJH2-3",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Cho đến khi một nhịp đập mạnh mẽ hơn nhiều. Hai vị Sư huynh gần như cùng lúc xuất tinh. Hai dòng chất lỏng nóng hổi, quyện linh lực, bắn sâu vào cơ thể nàng từ cả phía trước và phía sau."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]giữa cơn cực lạc của cao trào, cơ thể nàng co giật nhẹ, hấp thụ hoàn toàn tinh chất bên trong."]},{"code":221,"indent":1,"parameters":[]},{"code":111,"indent":1,"parameters":[0,15,0]},{"code":357,"indent":2,"parameters":["FlyCat_LL_SceneMenu","setTearPeople","设置破处者",{"name":"Nam tu Hợp Hoan Tông","variablesId":""}]},{"code":657,"indent":2,"parameters":["破处者姓名 = Nam tu Hợp Hoan Tông"]},{"code":657,"indent":2,"parameters":["指定回传破处者姓名的变量 = "]},{"code":121,"indent":2,"parameters":[15,15,1]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":250,"indent":1,"parameters":[{"name":"1-NZSFGC","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":1,"parameters":[30]},{"code":251,"indent":1,"parameters":[]},{"code":122,"ind