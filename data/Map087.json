ters":["\\Face[5]Van xin ngươi, thả ta đi! Muốn ta làm gì cũng được! Chỉ cầu ngươi thả ta đi!"]},{"code":213,"indent":0,"parameters":[2,5,true]},{"code":101,"indent":0,"parameters":["",0,0,2,"Bà chủ."]},{"code":401,"indent":0,"parameters":["Câm miệng! Lão nương bỏ ra bao nhiêu bạc trắng mới mua được ngươi về đấy."]},{"code":101,"indent":0,"parameters":["",0,0,2,"Bà chủ."]},{"code":401,"indent":0,"parameters":["(Nghe tên giao người tới nói, quả thực là một cô nhi vô thân vô thế, còn lớn lên xinh đẹp như vậy. Phen này thực sự nhặt được bảo bối lớn rồi.)"]},{"code":213,"indent":0,"parameters":[-1,11,false]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[3]Ta sẽ cố gắng kiếm tiền! Van xin ngươi…"]},{"code":213,"indent":0,"parameters":[2,8,true]},{"code":101,"indent":0,"parameters":["",0,0,2,"Bà chủ."]},{"code":401,"indent":0,"parameters":["Không phải là không thể. Chỉ cần ngươi lên được chức hoa khôi, gặp được người chuộc thân đưa ngươi đi… Nếu vậy, ta sẽ không cản."]},{"code":213,"indent":0,"parameters":[-1,4,false]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[6]Thật sao？"]},{"code":101,"indent":0,"parameters":["",0,0,2,"Bà chủ."]},{"code":401,"indent":0,"parameters":["Đương nhiên là thật. Nhưng mà trước hết… ngươi phải kiếm về cho ta 500 lượng bạc. 500 lượng bạc xong… ngươi mới có thể rời khỏi căn phòng này."]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[3]Ta không muốn bán thân."]},{"code":101,"indent":0,"parameters":["",0,0,2,"Bà chủ."]},{"code":401,"indent":0,"parameters":["Ngươi bán thân hay không… lão nương không quản. Ngươi chỉ cần kiếm đủ 500 lượng là có thể rời khỏi căn phòng này."]},{"code":101,"indent":0,"parameters":["",0,0,2,"Bà chủ."]},{"code":401,"indent":0,"parameters":["(Nếu đến 500 lượng cũng không kiếm được… vậy thì cũng không cần bồi dưỡng làm gì. Một mầm non tốt như vậy… có lẽ còn có thể đưa nàng đến… …)"]},{"code":213,"indent":0,"parameters":[-1,8,false]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11]Ta hiểu rồi."]},{"code":101,"indent":0,"parameters":["",0,0,2,"Bà chủ."]},{"code":401,"indent":0,"parameters":["Vậy thì tốt nhất. Ta đã sắp xếp cho ngươi một ả nha hoàn. Nếu muốn tiếp khách… cứ việc nói với nàng ta."]},{"code":117,"indent":0,"parameters":[53]},{"code":230,"indent":0,"parameters":[30]},{"code":117,"indent":0,"parameters":[115]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":["Dặn dò xong xuôi, thấy dáng vẻ mềm mỏng dễ bảo của \\n[1], Mụ Mụ liền vui vẻ rời đi. Không bao lâu sau, một ả nha hoàn đã bước vào phòng \\n[1], im lặng đứng sang một bên, không nói một lời."]},{"code":121,"indent":0,"parameters":[350,350,0]},{"code":122,"indent":0,"parameters":[242,242,0,0,0]},{"code":222,"indent":0,"parameters":[]},{"code":117,"indent":0,"parameters":[116]},{"code":230,"indent":0,"parameters":[30]},{"code":117,"indent":0,"parameters":[52]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[1](Một khi ta hạ quyết tâm tiếp khách… sẽ nói với nàng.)"]},{"code":126,"indent":0,"parameters":[53,0,0,200]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]\\C[6]Nhiệm vụ chính\\C[0] đã hoàn thành. Phần thưởng đã được gửi!~~~"]},{"code":250,"indent":0,"parameters":[{"name":"Up1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,0,1,""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["\\CT[1]Nội dung \\C[6]Nhiệm vụ chính\\C[0] mới đã được cập nhật. Vui lòng kiểm tra \\C[2]Ngọc Thư Nhiệm vụ\\C[0] kịp thời."]},{"code":250,"indent":0,"parameters":[{"name":"Up1","volume":90,"pitch":100,"pan":0}]},{"code":357,"indent":0,"par