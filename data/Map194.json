igger":4,"walkAnime":true}],"x":16,"y":8},{"id":5,"name":"Mo Tai Yunqi","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"2024-8-24-1","direction":2,"pattern":1,"characterIndex":6},"list":[{"code":111,"indent":0,"parameters":[1,1204,0,1,0]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["<qp:5,600,>Mo Tai Yunqi: Thân thể thật hoàn mỹ tinh xảo. *Liếm môi* Ngay cả khi là nữ nhân với nhau… Ta cũng không khỏi ghen tị với ngươi đó~ Thật muốn giữ ngươi bên mình làm con chó nhỏ của ta… Tiếc thật… Không thể được rồi. Đi đi, mỹ nhân tương lai… Chúng ta… sau này sẽ gặp lại."]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":111,"indent":1,"parameters":[0,680,0]},{"code":122,"indent":2,"parameters":[242,242,0,3,0,929,0]},{"code":122,"indent":2,"parameters":[243,243,0,3,0,930,0]},{"code":111,"indent":2,"parameters":[1,242,0,3,1]},{"code":111,"indent":3,"parameters":[1,243,0,5,1]},{"code":213,"indent":4,"parameters":[0,1,true]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:5,600,>Mo Tai Yunqi: Để ta nói cho ngươi biết, bảo bối à~ Kỹ thuật này và những nguyên liệu này là bí phương của ta. Sau khi ta làm xong… sẽ chia cho ngươi một ít."]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:5,600,>Mo Tai Yunqi: *Xoa đầu \\n[1].*"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:5,600,>Mo Tai Yunqi: Đứa trẻ… trong thế giới tu chân này, nữ nhân chúng ta khó tránh khỏi chịu thiệt thòi. Chỉ khi nào có được thực lực chân chính thì mới có thể muốn làm gì thì làm. Ta sẽ không khuyên ngươi hướng thiện hay hướng ác. Ta chỉ mong… ngươi có thể giữ vững tâm nguyên bản. Đó… mới là điều quan trọng nhất."]},{"code":126,"indent":4,"parameters":[929,1,0,3]},{"code":126,"indent":4,"parameters":[930,1,0,5]},{"code":126,"indent":4,"parameters":[53,0,0,300]},{"code":122,"indent":4,"parameters":[13,13,1,0,2]},{"code":122,"indent":4,"parameters":[8,8,1,0,1]},{"code":121,"indent":4,"parameters":[680,680,1]},{"code":101,"indent":4,"parameters":["",0,0,1,""]},{"code":401,"indent":4,"parameters":[""]},{"code":401,"indent":4,"parameters":["\\CT[1]Nhiệm vụ phụ \\C[5]Thỉnh cầu của Mo Tai Yunqi\\C[0] hoàn thành! Chúc mừng đã hoàn thành nhiệm vụ!"]},{"code":250,"indent":4,"parameters":[{"name":"Up1","volume":90,"pitch":100,"pan":0}]},{"code":357,"indent":4,"parameters":["Cat_QuestCore","removeQuest","主线/支线任务完成",{"type":"支线","id":"66"}]},{"code":657,"indent":4,"parameters":["任务类型 = 支线"]},{"code":657,"indent":4,"parameters":["任务Id号 = 66"]},{"code":122,"indent":4,"parameters":[1204,1204,0,0,1]},{"code":0,"indent":4,"parameters":[]},{"code":411,"indent":3,"parameters":[]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:5,600,>Mo Tai Yunqi: Úi chà~ Để ta nói cho ngươi biết, bảo bối à~ Những bông hoa đó ngọt vô cùng. Rất ít người biết đến chúng. Chính ta cũng chỉ tình cờ phát hiện thôi. Nếu làm thành bánh ngọt, chúng còn thơm ngọt hơn nữa. Mau đi lấy chúng rồi về sớm đi. Khi về rồi thì ở với ta một lúc nữa."]},{"code":0,"indent":4,"parameters":[]},{"code":412,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":411,"indent":2,"parameters":[]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["<qp:5,600,>Mo Tai Yunqi: Úi chà~ Để ta nói cho ngươi biết, bảo bối à~ Những bông hoa đó ngọt vô cùng. Rất ít người biết đến chúng. Chính ta cũng chỉ tình cờ phát hiện thôi. Nếu làm thành bánh ngọt, chúng còn thơm ngọt hơn nữa. Mau đi lấy chúng rồi về sớm đi. Khi về rồi thì ở với ta một lúc nữa."]},{"code":0,"indent":3,"parameters":[]},{"code":412,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":411,"indent":1,"parameters":[]},{"code":111,"indent":2,"parameters":[0,9,0]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["<qp:5,600,>Mo Tai Yunqi: Ngươi…! Ngươi dám làm tới mức này sao… Vậy đây… chính là con người thực sự mà ngươi đã thức tỉnh đó ư… A… Thật đáng tiếc… Thôi, với dáng vóc như của ngươi… nếu nghiêm túc, chuyển sang Hợp Hoang Tông… trở thành một mỹ nhân tuyệt thế cũng không phải không thể."]},{"code":0,"indent":3,"parameters":[]},{"code":411,"indent":2,"parameters":[]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["<qp:5,600,>Mo Tai Yunqi: Khí diễm chí tôn, tựa mây phiêu đãng dật. Thân tịnh như thai, kiêu ngạo giữa trần gian. Mong ngươi chuyên tâm tu hành, sớm ngộ bản chân."]},{"code":0,"indent":3,"parameters":[]},{"code":412,"indent":2,"parameters":[]},{"code":111,"indent":2,"parameters":[0,8,0]},{"code":102,"indent":3,"parameters":[["Nhận nhiệm vụ","Quyến rũ","Từ chối"],1,0,1,0]},{"code":402,"indent":3,"parameters":[0,"Nhận nhiệm vụ"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:5,600,>Mo Tai Yunqi: Lại đây, cô nương. Con đường tu luyện không dễ dàng. Lúc nào cũng căng thẳng cũng không tốt đâu. Phải cân bằng giữa công việc và nghỉ ngơi. Đi mua cánh hoa ăn được cho ta đi. Ta thèm bánh ngọt hoa rồi."]},{"code":102,"indent":4,"parameters":[["Nhận","Từ chối"],1,0,1,0]},{"code":402,"indent":4,"parameters":[0,"Nhận"]},{"code":101,"indent":5,"parameters":["",0,0,1,""]},{"code":401,"indent":5,"parameters":[""]},{"code":401,"indent":5,"parameters":["\\CT[1]Nhiệm vụ phụ được kích hoạt: \\C[5]Thỉnh cầu của Mo Tai Yunqi\\C[0]. Nhiệm vụ này đã được ghi nhận vào Ngọc Giản Nhiệm Vụ trong phần Nhiệm Vụ Phụ. Hãy nhớ kiểm tra nhé."]},{"code":250,"indent":5,"parameters":[{"name":"Up1","volume":90,"pitch":100,"pan":0}]},{"code":121,"indent":5,"parameters":[680,680,0]},{"code":357,"indent":5,"parameters":["Cat_QuestCore","addQuest","添加主线/支线任务",{"type":"支线","id":"66"}]},{"code":657,"indent":5,"parameters":["任务类型 = 支线"]},{"code":657,"indent":5,"parameters":["任务Id号 = 66"]},{"code":0,"indent":5,"parameters":[]},{"code":402,"indent":4,"parameters":[1,"Từ chối"]},{"code":0,"indent":5,"parameters":[]},{"code":404,"indent":4,"parameters":[]},{"code":0,"indent":4,"parameters":[]},{"code":402,"indent":3,"parameters":[1,"Quyến rũ"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:5,600,>Mo Tai Yunqi: Ta thực sự không hề muốn thế này. Chính ngươi cứ liên tục cám dỗ ta, khiêu khích ta. Giờ thì… đừng trách ta ra tay trên thân thể của ngươi. Nhìn xem thân thể này… đúng là chất liệu bẩm sinh cho một con đĩ rẻ tiền."]},{"code":117,"indent":4,"parameters":[356]},{"code":122,"indent":4,"parameters":[1204,1204,0,0,1]},{"code":0,"indent":4,"parameters":[]},{"code":402,"indent":3,"parameters":[2,"Từ chối"]},{"code":0,"indent":4,"parameters":[]},{"code":404,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":411,"indent":2,"parameters":[]},{"code":102,"indent":3,"parameters":[["Nhận nhiệm vụ","Từ chối"],1,0,1,0]},{"code":402,"indent":3,"parameters":[0,"Nhận nhiệm vụ"]},{"code":101,"indent":4,"parameters":["",0,0,2,""]},{"code":401,"indent":4,"parameters":["<qp:5,600,>Mo Tai Yunqi: Lại đây, cô nương. Con đường tu luyện không dễ dàng. Lúc nào cũng căng thẳng cũng không tốt đâu. Phải cân bằng giữa công việc và nghỉ ngơi. Đi mua cánh hoa ăn được cho ta đi. Ta thèm bánh ngọt hoa rồi."]},{"code":102,"indent":4,"parameters":[["Nhận","Từ chối"],1,0,1,0]},{"code":402,"indent":4,"parameters":[0,"Nhận"]},{"code":101,"indent":5,"parameters":["",0,0,1,""]},{"code":401,"indent":5,"parameters":[""]},{"code":401,"indent":5,"parameters":["\\CT[1]Nhiệm vụ phụ được kích hoạt: \\C[5]Thỉnh cầu của Mo Tai Yunqi\\C[0]. Nhiệm vụ này đã được ghi nhận vào Ngọc Giản Nhiệm Vụ trong phần Nhiệm Vụ Phụ. Hãy nhớ kiểm tra nhé."]},{"code":250,"indent":5,"parameters":[{"name":"Up1","volume":90,"pitch":100,"pan":0}]},{"code":121,"indent":5,"parameters":[680,680,0]},{"code":357,"indent":5,"parameters":["Cat_QuestCore","addQuest","添加主线/支线任务",{"type":"支线","id":"66"}]},{"code":657,"indent":5,"parameters":["任务类型 = 支线"]},{"code":657,"indent":5,"parameters":["任务Id号 = 66"]},{"code":0,"indent":5,"parameters":[]},{"code":402,"indent":4,"parameters":[1,"Từ chối"]},{"code":0,"indent":5,"parameters":[]},{"code":404,"indent":4,"parameters":[]},{"code":0,"indent":4,"parameters":[]},{"code":402,"indent":3,"parameters":[1,"Từ chối"]},{"code":0,"indent":4,"parameters":[]},{"code":404,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":412,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":10,"y":13}]}