t":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[11]Hoa Tín biểu tỷ… ta có thể…"]},{"code":101,"indent":1,"parameters":["",0,0,2,"Công chúa Hoa Tín"]},{"code":401,"indent":1,"parameters":["Ta biết muội có thể cứu ta. Nhưng muội cũng chỉ cứu được cái thân xác da thịt này. Trái tim ta… đã chết từ lâu rồi. Chi bằng… cứ để ta đi đi."]},{"code":117,"indent":1,"parameters":[22]},{"code":117,"indent":1,"parameters":[115]},{"code":231,"indent":1,"parameters":[1,"6-EZLH1-2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Vũ Văn Cảnh Thành"]},{"code":401,"indent":1,"parameters":["Mẫu thân! Mẫu thân! Người vẫn còn có con mà!"]},{"code":231,"indent":1,"parameters":[1,"6-BJLH",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Công chúa Hoa Tín"]},{"code":401,"indent":1,"parameters":["Cảnh Nhi… mẫu thân quá mệt mỏi rồi… Để mẫu thân nghỉ ngơi một chút, được không？"]},{"code":231,"indent":1,"parameters":[1,"6-EZLH1-3",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Vũ Văn Cảnh Thành"]},{"code":401,"indent":1,"parameters":["Đừng đi mà, mẫu thân… con sẽ ngoan ngoãn… Mẫu thân, đừng bỏ Cảnh Thành lại!"]},{"code":231,"indent":1,"parameters":[1,"11-BJBW1",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Hoa Hân Công chúa: Thanh nhi, đừng buồn. Mẫu thân đã chịu đựng quá nhiều năm rồi. Nàng thực sự không thể gắng gượng thêm được nữa."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Hoa Hân biểu tỷ… …"]},{"code":231,"indent":1,"parameters":[1,"11-BJBW2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,"Công chúa Hoa Tín"]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Hoa Hân Công chúa: Tất cả những chuyện này không phải lỗi của con. Chỉ là do ta. Năm xưa, ta liên tục chạy trốn, điều đó làm sức khỏe của ta suy sụp. Cái phủ Vương gia này cũng chẳng phải chỗ tốt lành gì. Việc sinh ra Cảnh Thanh càng khiến sức khỏe của ta tồi tệ hơn."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Hoa Hân Công chúa: Chỉ là nghĩ đến tương lai của Cảnh Thanh… ta không thể yên lòng ra đi. Thực sự, giờ của ta đã đến… Ta chưa bao giờ ngờ lại có thể gặp lại Tịch Nguyệt biểu muội."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Hoa Hân Công chúa: Thanh nhi, hãy đi cùng Nguyệt di đi. Rời khỏi nơi này, và đừng bao giờ quay lại."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Vũ Văn Cảnh Thanh: Mẫu thân, không! Mẫu thân, con muốn ở bên Người mãi mãi!"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Hoa Hân Công chúa: Thanh nhi, ta không thể bảo vệ con thêm nữa. Hãy đi cùng Nguyệt di. Trở nên mạnh mẽ hơn, để tự bảo vệ bản thân tốt hơn."]},{"code":231,"indent":1,"parameters":[1,"11-BJBW3",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Hoa Hân Công chúa: Nguyệt biểu muội, dù ta đã từng oán trách muội, nhưng giờ đây muội là người duy nhất có thể bảo vệ Cảnh Thanh của ta. Ta cầu xin muội, hãy đưa thằng bé rời khỏi nơi đây."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Hoa Hân biểu tỷ… …"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Ta hứ