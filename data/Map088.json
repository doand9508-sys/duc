:"DHCM1_BGM02_Opening1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Sau khi bị bắt, A Hoan bị ai đó lột sạch quần áo và trói chặt tay chân trong một tư thế vô cùng nhục nhã."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Madam: Một cô gái xinh đẹp như vậy. Sao phải làm khó mình？ Cùng chia sẻ niềm vui thú chốn trần gian này thì có gì là sai？"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Vị Madam lớn tuổi nhưng vẫn còn quyến rũ, mái tóc cài đầy trâm ngọc, dùng bàn tay ngọc lan cầm khăn lụa, khẽ phẩy qua mặt A Hoàn—nửa thật nửa giả."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bà ta là một phụ nữ từng trải. Bà hơi khâm phục lòng trung thành và tận tụy của cô gái nhỏ này, nhưng cũng cảm thấy cô gái nhỏ sẽ không thể chống cự lâu. Lúc này, nàng chỉ đang tỏ ra mạnh mẽ, tự chuốc khổ vào thân. Một chút thủ đoạn nhỏ là có thể dễ dàng khuất phục nàng."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bà đã thuần hóa được cả những người phụ nữ hung dữ và bướng bỉnh nhất. Huống chi là cô gái này, ai nhìn một cái cũng biết vẫn còn ngây thơ và thiếu kinh nghiệm."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Vì vậy, chỉ nhìn hai lần, bà liền gọi người và đi nghỉ trước, uống trà, yên lặng chờ khoảng nửa nén hương. Khi ấy, cô gái này sẽ hoàn toàn sẵn sàng cho mùa xuân thu hoạch."]},{"code":222,"indent":1,"parameters":[]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ1",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Sự xấu hổ khiến mặt nàng đỏ bừng, lan đến tận tai. A Hoàn cắn chặt răng trắng như ngọc, không chịu thốt ra tiếng. Nàng đã quá bất cẩn. Vốn muốn chia sẻ lo lắng với tiểu thư nhà mình, bây giờ xem ra chỉ làm liên lụy thêm cho tiểu thư."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Ngực nàng bị dây trói siết nổi bật hơn. Hai tay cũng bị trói sau lưng, không thể cử động. Phần không thể nói ra nhất là đôi chân—bắp chân bị gập lại vào đùi."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Và bị banh rộng sang hai bên. Thứ rõ ràng là vùng cực kỳ riêng tư giờ lại phơi bày hoàn toàn trước mắt mọi người."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Khoảnh khắc Madam bước ra khỏi phòng, người đàn ông đang chờ đợi liền tiến đến. A Hoàn cảm thấy hắn ta ngày càng đến gần. Nàng muốn trốn, nhưng không còn nơi nào để đi."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Càng giãy giụa, dây trói càng siết chặt hơn. Sợi gai thô ráp làm xước làn da mỏng manh của nàng. Chỉ trong chốc lát, vùng da trắng như tuyết nơi dây giao nhau đã lốm đốm những mảng đỏ như sao, vừa đau vừa ngứa, như thể bị kiến cắn."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Thấy cảnh này, người đàn ông như phát hiện ra báu vật. Hắn lấy ra một cây roi da đen, nắm chặt cán trong lòng bàn tay, khẽ giật nhẹ, tạo ra âm thanh giòn giã, sắc nhọn trong không khí."]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Tim A Hoàn run lên. Nhưng nàng vẫn không mở miệng. Cho đến khi cây roi mảnh quất ngang người nàng, khiến nàng giật mình không kịp phản ứng. Sau tiếng kêu kinh ngạc, nàng lập tức cắn môi trở lại."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nơi roi quất trúng, ban đầu không cảm thấy đau."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Tuy nhiên, ngay sau đó, một cảm giác đau đớn khủng khiếp lóe lên rồi tiếp nối. Sau khoảnh khắc đau đớn ấy, một cơn ngứa rát, dai dẳng từ từ thay thế."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Khi nàng vừa cố gắng vượt qua cảm giác khó chịu đó, nhát roi tiếp theo lại giáng xuống. Cảm giác đau rồi ngứa tương tự quay trở lại. Những giọt mồ hôi rịn ra từ vầng trán nhẵn nhụi và chóp mũi, lăn dài xuống."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Người đàn ông, mặt khác, thích thú tận hưởng vẻ đẹp trước mắt. Trên làn da trắng như sữa của nàng, đầu tiên xuất hiện một vết hằn trắng bệch chết chóc, rồi ngay lập tức, sưng tấy và đỏ lên, như một đóa hoa mai mùa đông. Giữa tiếng roi vun vút, từng đóa hoa lần lượt nở rộ."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Người đàn ông giơ tay mân mê kiệt tác của chính mình. Những vết thương vốn đã bỏng rát, đau đớn, dưới cái chạm của hắn, khiến toàn thân A Hoàn càng run rẩy vì đau."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Đã hoàn toàn bị kích thích, người đàn ông xoay ngược cây roi, dùng cán roi khều khều vào chiếc bình mật đáng thương, đang rụt rè run rẩy của A Hoàn. Miệng bình ướt đẫm, nhầy nhụa những thứ dịch mật. Cán roi từ từ được vặn xoáy và đẩy vào trong."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nước mắt lưng tròng, chực trào ra nhưng không rơi. Người đàn ông rút cán roi ra, lấy thanh gậy của chính mình, áp vào cửa mình của A Hoàn. Đôi bàn tay to lớn thô bạo nhào nặn bộ ngực trắng như tuyết đã bị bỏ bê từ lâu của nàng."]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ3",0,0,0,0,100,100,255,0]},{"code":230,"indent":1,"parameters":[60]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ4",0,0,0,0,100,100,255,0]},{"code":230,"indent":1,"parameters":[40]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ5",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Ngay khi cơ thể căng cứng của A Hoàn vừa hơi thả lỏng, hắn đột ngột thúc mạnh vào."]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ6",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Đau! Một giọt lệ lớn lăn xuống. Những tiếng nấc nghẹn ngào rơi ra từ kẽ môi."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Sau một hồi đắn đo, người đàn ông lấy ra một hũ thuốc mỡ, bôi một lượng nhỏ lên hạt mật của A Hoàn và bên trong âm hộ nàng."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Lúc đầu là cảm giác mát lạnh. Nhưng dần dần, nó biến thành một sức nóng bỏng rát, một cơn ngứa khiến nàng thèm khát được giày vò."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Sau khi bôi thuốc, người đàn ông thỏa sức mân mê hạt mật của nàng một lúc. Nhờ thứ mật mới tiết ra, thanh gậy của hắn lại được đâm vào trong âm hộ nàng một lần nữa. Lần này, rõ ràng nó nhận được sự tiếp đón ngoan ngoãn và cuồng nhiệt hơn lần đầu."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Lúc này, hắn không vội vàng. Dùng chiêu thức chín cạn một sâu, buộc A Hoàn phải khẽ nâng hông lên đón."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Người đàn ông trực tiếp khai thác nàng, vỗ vỗ vào cặp mông trắng như tuyết đầy sẹo của A Hoàn. Từng đợt thịt gợn sóng, quả thực là một cảnh tượng đẹp mắt."]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ7",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Rõ ràng phải là đau đớn không thể chịu nổi. Nhưng từ nỗi đau này, những đợt khoái cảm sắc nhọn, sảng khoái lại được rút ra một cách kỳ lạ."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Nàng không muốn bị đánh, không muốn chịu đau… nhưng, nàng cũng muốn bị vỗ thêm vài cái, để làm dịu cơn ngứa này…"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Tim A Hoàn đập nhanh hơn. Những suy nghĩ mâu thuẫn xé nát ý thức nàng."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Người đàn ông bất ngờ tung ra đòn tấn công dữ dội như vũ bão. Nó làm tan vỡ ý chí vốn đã lung lay của A Hoàn. Âm hộ nàng bắt đầu co thắt và thít chặt liên tục. Nàng sắp đạt đến đỉnh cao. Người đàn ông đột ngột rút ra, bỏ mặc A Hoàn lơ lửng khô khốc."]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ5",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Hắn cố ý cúi đầu thì thầm nhẹ vào tai nàng."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Ma cô: Tiểu nương tử, có muốn hay không？"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]A Hoàn vẫn muốn chống cự. Bàn tay người đàn ông bóp chặt hạt mật nàng, nhẹ nhàng nhào nặn. Bên trong âm hộ nàng, thảm thương thay, lại càng rỉ ra nhiều dịch trong suốt hơn. Nàng muốn nó. Chỉ thêm một chút nữa là sẽ lên đỉnh."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]A Hoàn không thể chịu đựng được nữa. Với giọng nức nở, nàng cầu xin người đàn ông đâm vào."]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ7",0,0,0,0,100,100,255,0]},{"code":230,"indent":1,"parameters":[50]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ8",0,0,0,0,100,100,255,0]},{"code":230,"indent":1,"parameters":[40]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ9",0,0,0,0,100,100,255,0]},{"code":230,"indent":1,"parameters":[30]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ10",0,0,0,0,100,100,255,0]},{"code":230,"indent":1,"parameters":[30]},{"code":231,"indent":1,"parameters":[1,"29-3-TJ12",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Khi Madam trở lại, A Hoàn đã biến thành một con đĩ nhỏ, đang vui vẻ khoái lạc."]},{"code":122,"indent":1,"parameters":[143,143,0,0,1]},