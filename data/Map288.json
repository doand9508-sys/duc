de":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[6]Ngươi… nhận ra ta sao？"]},{"code":231,"indent":0,"parameters":[1,"55-MZLH5",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"Ma Quân Yuyan"]},{"code":401,"indent":0,"parameters":["Chậc. Có vẻ như có nhiều chuyện ngươi không biết nhỉ？ Ta cảm nhận được sức mạnh của kẻ đó trong cơ thể ngươi. Ta cứ tưởng ngươi đã biết."]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[11](Sức mạnh trong cơ thể ta… Đó hẳn là sức mạnh của Hắc Long… và còn cả… Yuwen Yu nữa？)"]},{"code":101,"indent":0,"parameters":["",0,0,2,"Ma Quân Yuyan"]},{"code":401,"indent":0,"parameters":["Ngươi có vẻ đã nghĩ ra điều gì à？ Thôi, cũng chẳng có gì to tát cả. Vậy, Tiên Tử… nói đi. Ngươi tới đây làm gì？"]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[1]Ta biết ở Ma Giới có một tấm gương, có thể soi rọi chân tướng của vạn vật. Ta muốn… được xem thử. Tất nhiên, ta sẽ không xem không đâu. Trong khả năng của mình, ta sẵn sàng trao đổi để có cơ hội soi gương."]},{"code":231,"indent":0,"parameters":[1,"55-MZLH3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"Ma Quân Yuyan"]},{"code":401,"indent":0,"parameters":["Gương Thiên Nguyên, hử？ Ừm… để ngươi mượn xem một chút cũng chẳng phiền hà gì. Dù sao thì, ngay cả ta… à, ngay cả ta cũng thấy khó lòng từ chối lời thỉnh cầu của ngươi. Tuy nhiên——"]},{"code":231,"indent":0,"parameters":[1,"55-MZLH5",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"Ma Quân Yuyan"]},{"code":401,"indent":0,"parameters":["Để sử dụng Gương Thiên Nguyên, ngươi sẽ cần một vài nguyên liệu. Nếu ngươi có thể cung cấp đủ nguyên liệu, thì cứ việc dùng."]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[6](Chỉ cần cung cấp nguyên liệu thôi sao？ Nghe có vẻ đơn giản… nhưng