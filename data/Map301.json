te":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"NPC6","direction":6,"pattern":1,"characterIndex":7},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":13,"y":4},{"id":3,"name":"Thợ săn","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"NPC11","direction":4,"pattern":1,"characterIndex":4},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":15,"y":4},{"id":4,"name":"Tình tiết số","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>Cô gái: Tôi xin lỗi… …"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:3,600,>Thợ săn: Đừng tự trách mình. Tất cả là lỗi của tôi… Tôi quá vô dụng… Tôi không thể cứu được em."]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>Cô gái: Sao tôi có thể trách anh？ Tất cả đều là lòng tham của cha mẹ và anh trai tôi… Tôi cũng không có cách nào thoát ra."]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>Cô gái: Nhưng… cảm ơn anh. Thật sự… cảm ơn. Vì đã cho một người như tôi… vài kỷ niệm đẹp."]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>Cô gái: Vậy nên… tôi cũng xứng đáng… được ai đó quan tâm… được ai đó nhớ đến."]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:3,600,>Thợ săn: …Chúng ta có nên… chạy trốn ngay bây giờ không？!"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>Cô gái: Bây giờ chúng ta có thể chạy… nhưng sau đó thì sao？ Cuộc sống vẫn phải tiếp diễn. Chúng ta không thể trốn trong núi sâu mãi mãi. Chúng ta vẫn sẽ có con cái… anh có sẵn lòng để con cái chúng ta theo chúng ta sống một cuộc đời ẩn núp, với tên giả không？"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:3,600,>Thợ săn: Tôi… tôi xin lỗi… tôi không nghĩ xa đến vậy."]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>Cô gái: Cảm ơn anh… tôi hiểu. Hãy để mọi thứ dừng lại ở đây. Sau ngày mai… con đường rộng mở đến tận trời cao. Mỗi người chúng ta đi con đường riêng của mình."]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["<qp:2,600,>Cô gái: Anh… cũng phải cố gắng sống tiếp. Sống… hạnh phúc nhé."]},{"code":117,"indent":0,"parameters":[53]},{"code":231,"indent":0,"parameters":[1,"44-YSLH1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":0,"parameters":["Tình yêu, hận thù, tham lam, ảo tưởng—không ai trần tục có thể thoát khỏi chúng. Bạn có tin rằng người tu tiên có thể thoát khỏi chúng không？"]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[2](Người tu tiên… Có phải anh ấy đang nói đến Đạo Đoạn Tình？ Nhưng… ít người tu luyện đạo đó nữa rồi…？)"]},{"code":401,"indent":0,"parameters":["Tâm Đạo hiện tại: \\C[10]\\V[675]\\C[0]"]},{"code":102,"indent":0,"parameters":[["Tu luyện Đạo Đoạn Tình. Cắt đứt Thất Tình Lục Dục. Người ta có thể siêu việt phàm tục và trở nên phi thường.","Chính vì có Thất Tình Lục Dục mà con người tiếp tục tiến lên. Tu tiên chỉ là chống lại trời để mong một cơ hội số phận… chứ không phải thoát khỏi bản tính con người. Sớm muộn gì, nó sẽ phản tác dụng."],-1,0,1,0]},{"code":402,"indent":0,"parameters":[0,"Tu luyện Đạo Đoạn Tình. Cắt đứt Thất Tình Lục Dục. Người ta có thể siêu việt phàm tục và trở nên phi thường."]},{"code":231,"indent":1,"parameters":[1,"44-YSLH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":1,"parameters":["Tiên tử đã quên rồi sao？ Năm mươi năm trước, ở thời đại trước… vì một lý do không rõ, giết vợ để chứng đạo, đoạn tình để phi thăng, đã trở nên cực kỳ thịnh hành."]},{"code":231,"indent":1,"parameters":[1,"44-YSLH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":1,"parameters":["Và kết quả là gì？ Ngay sau khi phi thăng, họ sẽ đau đớn mà rơi xuống. Cái gọi là 'Đoạn tình'… chẳng qua chỉ là sự kìm nén tạm thời tất cả cảm xúc. Nhưng vòng tuần hoàn nhân quả… làm sao mà thoát khỏi được？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":1,"parameters":["Chẳng qua chỉ là tự lừa dối mình. Tiên tử… liệu ngươi có muốn tự lừa dối mình như vậy không？"]},{"code":235,"indent":1,"parameters":[1]},{"code":122,"indent":1,"parameters":[675,675,2,0,15]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[11](Tôi suýt quên mất chuyện đó. Dù sao… đã nhiều năm rồi, chưa có một tu sĩ Đoạn tình nào cả.)"]},{"code":401,"indent":1,"parameters":["Tâm Đạo hiện tại: \\C[10]\\V[675]\\C[0]"]},{"code":117,"indent":1,"parameters":[52]},{"code":201,"indent":1,"parameters":[0,302,9,7,6,0]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"Chính vì có Thất Tình Lục Dục mà con người tiếp tục tiến lên. Tu tiên chỉ là chống lại trời để mong một cơ hội số phận… chứ không phải thoát khỏi bản tính con người. Sớm muộn gì, nó sẽ phản tác dụng."]},{"code":231,"indent":1,"parameters":[1,"44-YSLH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":1,"parameters":["Đúng vậy! Các tu sĩ Đoạn tình ở thời đại trước chỉ bị lừa để kìm nén Thất Tình Lục Dục. Họ thực sự tin rằng mình đã thành công. Cuối cùng, khi phi thăng, tất cả đều chịu phản ứng dữ dội. Nhân quả… sẽ không bao giờ đơn giản biến mất."]},{"code":235,"indent":1,"parameters":[1]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[11](Không còn nhiều thời gian nữa… Tôi phải kiên trì đến phút cuối cùng. Có vẻ… những tu sĩ mất tích đó hoàn toàn có liên hệ với hắn.)"]},{"code":117,"indent":1,"parameters":[52]},{"code":201,"indent":1,"parameters":[0,302,9,7,6,0]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":14,"y":1},{"id":5,"name":"EV005","note":"Ánh sáng 1000 #5f65a0","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":14,"y":2}]}