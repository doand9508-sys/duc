indent":0,"parameters":[-1,1,false]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[3]Vậy… khi thu con làm đồ đệ… cũng chỉ là để dùng con làm Lò Đỉnh thôi sao？"]},{"code":231,"indent":0,"parameters":[1,"8-LH1",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"Hoàng Vũ Thư"]},{"code":401,"indent":0,"parameters":["Ta đã kẹt ở đỉnh phong Nguyên Anh kỳ quá lâu rồi. Nếu không đột phá được… thọ mệnh của ta cũng sắp hết. Vốn dĩ ta không định như vậy. Nhưng ai bảo con có Thể Chất Lò Đỉnh chứ. Không dùng thì thật lãng phí."]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":0,"parameters":["\\Face[5]Nếu con không có Thể Chất Lò Đỉnh… liệu có khác đi không？ Đó chẳng qua chỉ là cái cớ tự lừa dối mình mà thôi. Sư Tôn… đây là lần cuối cùng con gọi người là Sư Tôn."]},{"code":231,"indent":0,"parameters":[1,"5-LZ3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"Đỗ Vân"]},{"code":401,"indent":0,"parameters":["Sư Tôn… …"]},{"code":235,"indent":0,"parameters":[1]},{"code":231,"indent":0,"parameters":[1,"8-LH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"Hoàng Vũ Thư"]},{"code":401,"indent":0,"parameters":["Ta đã nuôi con bao nhiêu năm nay! Cũng đến lúc con phải báo đáp ta rồi! ĐỖ VÂN!! "]},{"code":401,"indent":0,"parameters":["\\C[10]Gợi ý: Chỉ khi đánh bại Sư Tôn mới có thể thông quan."]},{"code":235,"indent":0,"parameters":[1]},{"code":301,"indent":0,"parameters":[0,103,false,true]},{"code":601,"indent":0,"parameters":[]},{"code":314,"indent":1,"parameters":[0,1]},{"code":301,"indent":1,"parameters":[0,102,false,true]},{"code":601,"indent":1,"parameters":[]},{"code":314,"indent":2,"parameters":[0,1]},{"code":301,"indent":2,"parameters":[0,101,false,true]},{"code":601,"indent":2,"parameters":[]},{"code":314,"indent":3,"parameters":[0,1]},{"code":301,"indent":3,"parameters":[0,104,false,tru