"parameters":[1]},{"code":117,"indent":2,"parameters":[115]},{"code":243,"indent":2,"parameters":[]},{"code":357,"indent":2,"parameters":["TitleCg","openLock","解锁指定Cg",{"id":"123"}]},{"code":657,"indent":2,"parameters":["CgId = 123"]},{"code":241,"indent":2,"parameters":[{"name":"DHCM1_BGM02_Opening1","volume":90,"pitch":100,"pan":0}]},{"code":221,"indent":2,"parameters":[]},{"code":250,"indent":2,"parameters":[{"name":"Blow1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Nguyệt Nhi, đến giúp sư phụ con một lần cuối. Khi sư phụ đột phá lên giai đoạn Hóa Thần, người nhất định sẽ nhớ công lao của con."]},{"code":231,"indent":2,"parameters":[1,"60-ZMXSFZB1",0,0,0,0,100,100,255,0]},{"code":222,"indent":2,"parameters":[]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Hoàng Ngọc Lưu nhìn chằm chằm vào  \\n[1]. Nhìn cơ thể trẻ trung tràn đầy linh khí ấy, lòng tham không kiềm chế được trỗi dậy. Hắn đã mắc kẹt ở đỉnh Nguyên Anh kỳ quá lâu rồi."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Cứ tiếp tục như vậy, sớm muộn gì hắn cũng qua đời. Hắn không cam lòng. Chỉ vì tư chất kém, lẽ nào phải dừng lại ở đây？"]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Song tu – lấy Âm bổ Dương – là con đường thích hợp nhất."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Để đột phá cảnh giới… hy sinh một đệ tử cũng chẳng là gì."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Hắn dùng pháp thuật siết cổ Thượng Quan Nguyệt. Nhìn  \\n[1] tuyệt vọng, vùng vẫy trong vô vọng, khóe miệng hắn không khỏi cong lên."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Côn thịt phía dưới đã cương cứng. Nhìn cái lồn nhỏ hồng hào, non nớt của  \\n[1], hắn dồn lực đâm vào."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]\\n[1]: Ah~~~"]},{"code":231,"indent":2,"parameters":[1,"60-ZMXSFZB2",0,0,0,0,100,100,255,0]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Một tiếng kêu thê lương vang lên, một tiếng rên thoát ra từ  \\n[1]. Dường như có thứ gì đó đâm vào cơ thể cô. Lồn cô bị lấp đầy hoàn toàn. Cảm giác sung mãn đó suýt khiến cô phát điên. Cứ như thể cô bị xé toạc ra vậy."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Cơ thể cô nhấp nhô theo chuyển động của Hoàng Vũ Thù. Đôi chân cũng run rẩy không ngừng, theo nhịp lắc lư của hắn."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Côn thịt càng vào sâu, pháp thuật trong tay Hoàng Vũ Thù càng siết chặt thêm. Cảm giác nghẹt thở khiến lồn của  \\n[1] co thắt, ôm chặt lấy côn thịt của Hoàng Vũ Thù."]},{"code":231,"indent":2,"parameters":[1,"60-ZMXSFZB3",0,0,0,0,100,100,255,0]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Côn thịt của Hoàng Vũ Thù đã âm thầm to ra hơn. Bên trong lồn  \\n[1], quy đầu áp vào thành tử cung cô."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]\\n[1]Lồn của [P5] khít chặt như miệng em bé, cọ xát qua lại với quy đầu. Hoàng Vũ Thù cảm thấy côn thịt căng phồng biết mình sắp bắn tinh."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]\\n[1][P6]: Ô ô a a a a a a a a!!!"]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Côn thịt đột nhiên phình to ra cực kỳ. Lồn của  \\n[1] bị bỏng rát bởi một dòng tinh dịch nóng bỏng."]},{"code":231,"indent":2,"parameters":[1,"60-ZMXSFZB4",0,0,0,0,100,100,255,0]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Côn thịt giật mạnh trong lồn cô. Từng đợt tinh dịch bắn thẳng vào thành trong tử cung của  \\n[1]."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Ngay sau đó, lượng lớn linh khí trong cơ thể  \\n[1] điên cuồng chảy qua côn thịt vào cơ thể Hoàng Vũ Thù."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Hoàng Vũ Thù: Cảm ơn… đồ đệ ngoan của ta."]},{"code":101,"indent":2,"parameters":["",0,1,2,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]Tuy nhiên,  \\n[1]  không thể nghe thấy hắn nữa. Cơn cực khoái đến nghẹt thở khiến cô mất đi ý thức."]},{"code":221,"indent":2,"parameters":[]},{"code":243,"indent":2,"parameters":[]},{"code":241,"indent":2,"parameters":[{"name":"4-QXYY2","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":2,"parameters":["",0,0,1,""]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":["\\CT[1]\\C[2]Đừng từ bỏ. Hãy trở lại trước khi tất cả bắt đầu. Sau khi khám phá sự thật, hãy chấm dứt cơn ác mộng bẩn thỉu này."]},{"code":101,"indent":2,"parameters":["",0,0,1,""]},{"co