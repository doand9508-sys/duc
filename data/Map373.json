arameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bạch Phong Hoa: Phiêu Phiêu… lại nói dối rồi. Nàng đang ở ngay đây với ta mà. Xem này… chúng ta đang kết nối chặt chẽ làm một đây."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bạch Phong Hoa cảm thấy rằng mong nhớ bao năm của hắn cuối cùng đã được đáp đền ngay tại khoảnh khắc này."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bạch Phong Hoa: Phiêu Phiêu… Phiêu Phiêu… Ta nhất định sẽ bảo vệ nàng mãi mãi."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bạch Phong Hoa thúc đẩy dữ dội. Dương vật không ngừng cọ xát vào thành nội bích của âm huyệt. Dịch tình yêu liên tục tuôn trào."]},{"code":231,"indent":1,"parameters":[1,"81-ATMBFH3-3",0,0,0,0,100,100,255,0]},{"code":250,"indent":1,"parameters":[{"name":"1-NZSFH2","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Aaaaaaaaaahhh~~~~~"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Đừng thô bạo như vậy! Ngh ngh ngh… Âm huyệt nhỏ của em bị nhét đầy hoàn toàn rồi."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bạch Phong Hoa: Phiêu Phiêu… đừng rời xa ta. Lần này… ta sẽ không buông tay nữa đâu."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bạch Phong Hoa: Hãy để ta cảm nhận nàng thật trọn vẹn, Phiêu Phiêu. Ta đã chờ đợi bao nhiêu năm rồi."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Nngh~~~ Em sắp ra… sắp lên đỉnh rồi~~~❤"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bạch Phong Hoa: Phiêu Phiêu… Ta cũng sắp ra rồi."]},{"code":231,"indent":1,"parameters":[1,"81-ATMBFH3-4",0,0,0,0,100,100,255,0]},{"code":250,"indent":1,"parameters":[{"name":"Poison","volume":90,"pitch":100,"pan":0}]},{"code":250,"indent":1,"parameters":[{"name":"1-NZSFGC","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Aaaaaaahhhh~~~~~❤"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bạch Phong Hoa: Phiêu Phiêu… nàng cũng cảm thấy tuyệt vời, phải không？"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bạch Phong Hoa: Phiêu Phiêu… Ta hạnh phúc quá. Cuối cùng ta đã có được nàng."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]\\n[1]: Nngh~~ Tiền bối, xin tỉnh lại đi… Tôi không phải Phiêu Phiêu… …"]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":[""]},{"code":401,"indent":1,"parameters":["\\CT[1]Bạch Phong Hoa: Sao nàng lại không phải là Phiêu Phiêu？ Nàng trông giống nàng ấy quá mà. Nàng còn có… chiếc vòng ngọc Bạch gia truyền đời, vật gia truyền của dòng chính nữa. Làm sao nàng không phải là Phiêu Phiêu được？"]},{"code":221,"indent":1,"parameters":[]},{"code":250,"indent":1,"parameters":[{"name":"Blow1","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":1,"parameters":[30]},{"code":235,"indent":1,"parameters":[1]},{"code":222,"indent":1,"parameters":[]},{"code":117,"indent":1,"parameters":[116]},{"code":117,"indent":1,"parameters":[53]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["Ngươi biết chiếc vòng này？ Rốt cuộc ngươi… là gì của mẫu thân ta？"]},{"code":231,"indent":1,"parameters":[2,"80-ZNJJLH",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Mẫu thân？ Con… con là hài tử của Phiêu Phiêu？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[2]Ừm. Đúng vậy. Nhưng mà… mẫu thân chưa từng nhắc đến chuyện quá khứ của mình. Ta thậm chí còn không biết tên của mẫu thân là Phiêu Phiêu. Nhưng… chiếc vòng này… là mẫu thân cho ta."]},{"code":231,"indent":1,"parameters":[2,"80-ZNJJLH",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Sao lại như vậy… Ta vậy mà… đã làm ra chuyện này… với chính con gái của Phiêu Phiêu？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[10](Bộ dạng này của hắn… giống như sắp tan vỡ hoàn toàn vậy. Trước khi hắn tan vỡ… nhất định phải biết được chân tướng của những chuyện này!)"]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["Làm ơn… hãy nói cho ta biết mọi chuyện về mẫu thân… Van cầu ngươi… Ta thật sự không biết gì cả."]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Phiêu Phiêu… là đích trưởng nữ của Bạch gia chính tông. Bạch gia… vốn là gia tộc tu tiên. Đã từng rất nhiều đời, liên tục xuất hiện tu sĩ có Thiên Linh Căn. Nhưng không biết tại sao… khi gia chủ Liễu gia - Liễu Càn Khôn biết được việc này…"]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Lợi dụng lúc dòng chính Bạch gia đã mấy đời không xuất hiện tu sĩ, mà vị tu sĩ cuối cùng kia vừa hay đã phi thăng, không thể bảo hộ Bạch gia, liền giam cầm toàn bộ Bạch gia trong Ngạo Thiên Tông của hắn ta."]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Mà Bạch Phiêu Phiêu… chính là đích nữ được công nhận có hi vọng có Linh Căn nhất. Nhưng không ai ngờ rằng… nàng ấy lại không hề có Linh Căn. Nhưng mà… Phiêu Phiêu cực kỳ xinh đẹp. Liễu Càn Khôn muốn giữ nàng ấy làm của riêng… để xem có thể sinh ra hài tử mang Thiên Linh Căn hay không."]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[5]Sao… Sao có thể như vậy？! Liễu gia… ĐÁNG CHẾT!"]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Lúc đó… phụ mẫu của Phiêu Phiêu, tức gia chủ dòng chính Bạch gia, vẫn còn sống. Liễu Càn Khôn dùng bọn họ ra uy hiếp nàng. Phiêu Phiêu sống chết không chịu… liều mạng tìm đến ta, một kẻ bà con xa nghèo hèn này, nhờ giúp đỡ."]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Phiêu Phiêu và ta… gần như chẳng có quan hệ huyết thống gì. Nhưng… ta yêu Phiêu Phiêu. Cho nên… ta đã lén lút sau lưng Liễu Càn Khôn… giúp Phiêu Phiêu trốn khỏi Ngạo Thiên Tông. Dù rằng… chỉ có thể trơ mắt nhìn nàng ấy rời khỏi nơi này."]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Cái giá phải trả chính là… ta vẫn luôn ở lại chỗ này. Hoặc là sinh ra một hậu duệ có Thiên Linh Căn… hoặc là chết già ở ngay tại đây."]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[4]Vậy… ông bà ngoại của ta…？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Đã chết. Đơn giản là không chịu nổi cuộc sống bị nhốt trong lồng ở đây. Cứ thế… ra đi trong u uất."]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Còn ta… ôm một tia hi vọng xa vời… chờ mẫu thân con xuất hiện trước mặt ta một lần nữa."]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Vậy mẫu thân của ngươi… bà ấy…"]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[2]…Để cứu ta…"]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Thì ra là vậy… Đúng rồi, còn có món đồ này… là do ông bà ngoại con để lại… cho hài tử của Phiêu Phiêu. Cũng chính là… thuộc về con."]},{"code":128,"indent":1,"parameters":[37,0,0,1,false]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[2]Cảm ơn ngươi."]},{"code":101,"indent":1,"parameters":["",0,0,2,"Bai Fenghua"]},{"code":401,"indent":1,"parameters":["Không có gì phải cảm ơn. Vốn dĩ là đồ của con mà. Được rồi… Để ta yên tĩnh một mình một lát."]},{"code":117,"indent":1,"parameters":[22]},{"code":117,"indent":1,"parameters":[52]},{"code":121,"indent":1,"parameters":[846,846,0]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"Chạy trốn."]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":846,"switch1Valid":true,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"$NZJJ","direction":2,"pattern":1,"characterIndex":0},"list":[{"code":231,"indent":0,"parameters":[2,"80-ZNJJLH",0,0,0,0,100,100,255,0]},{"code":101,"indent":0