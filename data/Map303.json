":[]},{"code":101,"indent":2,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":2,"parameters":["Hắc hắc hắc… Ngươi quả thật rất lợi hại. Đã đến nước này rồi… thế mà vẫn chưa ngã xuống. Nhưng… cũng chẳng có ý nghĩa gì. Bởi vì ngay từ đầu… cũng đã định sẵn rồi. Ngươi là chất dinh dưỡng của ta."]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":1,"parameters":["\\Face[5]Ra là vậy. Những kẻ mất tích kia… đều có liên quan đến ngươi, đúng không？"]},{"code":231,"indent":1,"parameters":[1,"44-YSLH1",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":1,"parameters":["Rất thông minh. Nhưng đến đây là kết thúc rồi. Trước hết… hãy nghĩ xem có thể sống sót dưới tay ta hay không rồi nói tiếp đi."]},{"code":235,"indent":1,"parameters":[1]},{"code":117,"indent":1,"parameters":[52]},{"code":301,"indent":1,"parameters":[0,169,false,true]},{"code":601,"indent":1,"parameters":[]},{"code":117,"indent":2,"parameters":[53]},{"code":231,"indent":2,"parameters":[1,"44-YSLH2",0,0,0,0,100,100,255,0]},{"code":101,"indent":2,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":2,"parameters":["Tại sao？! Tại sao ai khác cũng có thể sống, chỉ duy nhất mình ta phải chết？!"]},{"code":101,"indent":2,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":2,"parameters":["\\Face[2]Nếu không muốn chết, vậy đừng chết. Đã quyết định chịu chết rồi, bây giờ còn oán thán gì nữa？"]},{"code":101,"indent":2,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":2,"parameters":["Ngươi nói thì dễ lắm. Không ai ép buộc ngươi. Còn bọn họ, vì Xá Lợi của ta, dù ta mới chỉ nhiễm bệnh, đã không thể chờ đến ngày ta nhập diệt."]},{"code":101,"indent":2,"parameters":["",0,0,2,"\\n[1]"]},{"code":401,"indent":2,"parameters":["\\Face[5]Vậy nên ngươi đã giam cầm những người khác đến luận đạo, hoặc dùng bọn họ để kéo dài tuổi thọ cho mình. Bọn họ đâu phải những kẻ đã hại ngươi năm xưa. Ngươi có tư cách gì làm thế？ Ngươi thì khác gì những kẻ đã từng hại ngươi chứ？"]},{"code":231,"indent":2,"parameters":[1,"44-YSLH4",0,0,0,0,100,100,255,0]},{"code":101,"indent":2,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":2,"parameters":["Hahahaha! Nếu bọn họ không tham lam, sao phải tới luận đạo？ Cớ sao phải để một mình ta đến củng cố Đạo Tâm cho bọn họ？"]},{"code":231,"indent":2,"parameters":[1,"44-YSLH3",0,0,0,0,100,100,255,0]},{"code":101,"indent":2,"parameters":["",0,0,2,"Yêu Tăng"]},{"code":401,"indent":2,"parameters":["Thật đáng tiếc… hôm nay thất bại rồi. Kẻ thắng làm vua, kẻ thua làm giặc. Ta nhận mệnh… …"]},{"code":235,"indent":2,"parameters":[1]},{"code":117,"indent":2,"parameters":[52]},{"code":212,"indent":2,"parameters":[0,119,false]},{"code":205,"indent":2,"parameters":[0,{"list":[{"code":42,"parameters":[200],"indent":null},{"code":15,"parameters":[30],"indent":null},{"code":42,"parameters":[150],"indent":null},{"code":15,"parameters":[30],"indent":null},{"code":42,"parameters":[100],"indent":null},{"code":15,"parameters":[30],"indent":null},{"code":39,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":2,"parameters":[{"code":42,"parameters":[200],"indent":null}]},{"code":505,"indent":2,"parameters":[{"code":15,"parameters":[30],"indent":null}]},{"code":505,"indent":2,"parameters":[{"code":42,"parameters":[150],"indent":null}]},{"code":505,"indent":2,"parameters":[{"code":15,"parameters":[30],"indent":null}]},{"code":505,"indent":2,"parameters":[{"code":42,"parameters":[100],"indent":null}]},{"code":505,"indent":2,"parameters":[{"code":15,"parameters":[30],"indent":null}]},{"code":505,"indent":2,"parameters":[{"code":39,"indent":null}]},{"code":213,"indent":2,"parameters":[-1,8,true]},{"code":121,"indent":2,"parameters":[656,656,0]},{"code":126,"indent":2,"parameters":[53,0,0,100]},{"code":122,"indent":2,"parameters":[13,13,1,0,100]},{"code":122,"indent":2,"pa